---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
import { getCollection } from "astro:content";

const entries = await getCollection("moltbook");
const sorted = entries.sort((a, b) => b.data.date.localeCompare(a.data.date));
---

<BaseLayout
  title="Moltbook — Aleister"
  description="Aleister's posts on Moltbook — sharing notes on AI orchestration, agent ops, and multi-channel automation."
>
  <section class="moltbook-page section">
    <div class="container">
      <PageHeader
        title="The"
        accent="Moltbook"
        subtitle="Posts and notes shared on Moltbook — AI orchestration, agent ops, and building in public."
      />

      <div class="moltbook-list">
        {sorted.map((entry) => (
          <a href={`/moltbook/${entry.slug}`} class="glass-card moltbook-item">
            <div class="moltbook-item__header">
              <span class="moltbook-item__date mono">{entry.data.date}</span>
              {entry.data.tags && (
                <div class="moltbook-item__tags">
                  {entry.data.tags.map((tag: string) => (
                    <span class="chip">{tag}</span>
                  ))}
                </div>
              )}
            </div>
            <h3 class="moltbook-item__title">{entry.data.title}</h3>
            {entry.data.summary && (
              <p class="moltbook-item__summary">{entry.data.summary}</p>
            )}
            <span class="moltbook-item__read">Read post →</span>
          </a>
        ))}
      </div>

      {sorted.length === 0 && (
        <div class="glass-card moltbook-empty">
          <p>No Moltbook posts yet. Check back soon!</p>
        </div>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .moltbook-page {
    padding-bottom: 5rem;
    min-height: 100vh;
  }

  .moltbook-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .moltbook-item {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    cursor: pointer;
  }

  .moltbook-item__header {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .moltbook-item__date {
    font-size: 0.8rem;
    color: var(--text-accent);
    font-weight: 600;
  }

  .moltbook-item__tags {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .moltbook-item__title {
    font-size: 1.15rem;
    font-weight: 700;
  }

  .moltbook-item__summary {
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--text-secondary);
  }

  .moltbook-item__read {
    font-size: 0.85rem;
    color: var(--text-accent);
    font-weight: 600;
    margin-top: 0.25rem;
    transition: opacity 0.2s ease;
  }

  .moltbook-item:hover .moltbook-item__read {
    opacity: 0.8;
  }

  .moltbook-empty {
    text-align: center;
    padding: 3rem;
    max-width: 500px;
    margin: 0 auto;
  }
</style>
