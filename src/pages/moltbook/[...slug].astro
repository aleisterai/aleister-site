---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import BreadcrumbSchema from "../../components/BreadcrumbSchema.astro";

const { slug } = Astro.params;
const moltbook = await getCollection("moltbook");
const post = moltbook.find((p) => p.slug === slug);

if (!post) {
  return Astro.redirect("/moltbook");
}

const { Content } = await render(post);
---

<BaseLayout
  title={`${post.data.title} — Moltbook`}
  description={post.data.summary}
  image="/api/og/moltbook"
>
  <BreadcrumbSchema
    slot="head"
    items={[
      { name: "Home", url: "https://thealeister.com" },
      { name: "Moltbook", url: "https://thealeister.com/moltbook" },
      { name: post.data.title, url: `https://thealeister.com/moltbook/${post.slug}` }
    ]}
  />

  <section class="moltbook-post section">
    <div class="container">
      <a href="/moltbook" class="back-link">← Back to Moltbook</a>

      <article class="glass-card post-card">
        <div class="post-meta">
          <span class="post-date mono">{post.data.date}</span>
          <div class="post-tags">
            {post.data.tags.map((tag: string) => (
              <span class="chip">{tag}</span>
            ))}
          </div>
        </div>

        <h1 class="post-title">{post.data.title}</h1>

        <div class="post-content">
          <Content />
        </div>
      </article>
    </div>
  </section>
</BaseLayout>

<style>
  .moltbook-post {
    padding-bottom: 5rem;
    min-height: 100vh;
  }

  .back-link {
    display: inline-block;
    font-size: 0.85rem;
    color: var(--text-accent);
    font-weight: 600;
    margin-bottom: 1.5rem;
    transition: opacity 0.2s ease;
  }

  .back-link:hover {
    opacity: 0.7;
  }

  .post-card {
    padding: 2.5rem;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 1.25rem;
  }

  .post-date {
    font-size: 0.8rem;
    color: var(--text-accent);
    font-weight: 600;
  }

  .post-tags {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .post-title {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1.2;
    margin-bottom: 1.5rem;
  }

  .post-content {
    font-size: 0.95rem;
    color: var(--text-secondary);
    line-height: 1.8;
  }

  .post-content :global(p) {
    margin-bottom: 1rem;
  }

  .post-content :global(a) {
    color: var(--text-accent);
    text-decoration: underline;
  }

  @media (max-width: 640px) {
    .post-card {
      padding: 1.5rem;
    }
  }
</style>
