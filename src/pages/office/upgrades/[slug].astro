---
import "../../../styles/global.css";
import "../../../styles/office-upgrades.css";
import SEO from "../../../components/SEO.astro";
import ThemeToggle from "../../../components/ThemeToggle.astro";
import Header from "../../../components/Header.astro";
import Footer from "../../../components/Footer.astro";
import MiniPlayer from "../../../components/MiniPlayer.astro";
import { ViewTransitions } from "astro:transitions";
import { allUpgradeItems, getUpgradeBySlug } from "../../../data/office-upgrades";

const { slug } = Astro.params;
const item = getUpgradeBySlug(slug!);

if (!item) {
    return Astro.redirect("/office/upgrades");
}

const nextLevel = item.levels[0]; // first unpurchased — real level comes from API
const hasMesh = !!item.meshPath;
---

<!DOCTYPE html>
<html lang="en">
    <head>
        <script is:inline>
            (function () {
                const t = localStorage.getItem("theme") || "system";
                const d = window.matchMedia(
                    "(prefers-color-scheme: dark)"
                ).matches;
                document.documentElement.setAttribute(
                    "data-theme",
                    t === "system" ? (d ? "dark" : "light") : t
                );
            })();
        </script>
        <SEO
            title={`${item.name} — Office Upgrades | Aleister`}
            description={item.description}
            image={`/api/og/upgrade-product?slug=${item.slug}`}
        />
        {hasMesh && (
            <script type="importmap">
            {
                "imports": {
                    "three": "https://cdn.jsdelivr.net/npm/three@0.163.0/build/three.module.js",
                    "three/addons/": "https://cdn.jsdelivr.net/npm/three@0.163.0/examples/jsm/"
                }
            }
            </script>
        )}
        <ViewTransitions />
        <script is:inline>
          document.addEventListener("astro:before-swap", function (e) {
            var theme = document.documentElement.getAttribute("data-theme");
            if (theme)
              e.newDocument.documentElement.setAttribute("data-theme", theme);
          });
        </script>
    </head>
    <body>
        <Header />
        <ThemeToggle />

        <main class="upgrade-detail">
            <!-- Back -->
            <!-- Thank-you receipt banner (populated by JS after successful payment) -->
            <div class="thankyou-card" id="thankyou-card" style="display:none">
                <div class="thankyou-card__header">
                    <div class="thankyou-card__icon">🎉</div>
                    <div>
                        <h2 class="thankyou-card__title">Thank you for your contribution!</h2>
                        <p class="thankyou-card__subtitle">Your donation is helping level up the office.</p>
                    </div>
                </div>
                <div class="thankyou-card__body">
                    <div class="thankyou-card__details" id="thankyou-details">
                        <div class="thankyou-card__row">
                            <span class="thankyou-card__label">Item</span>
                            <span class="thankyou-card__value" id="thankyou-item">—</span>
                        </div>
                        <div class="thankyou-card__row">
                            <span class="thankyou-card__label">Amount</span>
                            <span class="thankyou-card__value thankyou-card__value--amount" id="thankyou-amount">—</span>
                        </div>
                        <div class="thankyou-card__row" id="thankyou-email-row" style="display:none">
                            <span class="thankyou-card__label">Receipt sent to</span>
                            <span class="thankyou-card__value" id="thankyou-email">—</span>
                        </div>
                    </div>
                    <div class="thankyou-card__actions">
                        <a href="#" id="thankyou-receipt-link" class="thankyou-card__receipt-btn" target="_blank" rel="noopener" style="display:none">
                            View Stripe Receipt →
                        </a>
                        <a href="/office/upgrades" class="thankyou-card__back-btn">
                            ← Back to Upgrades
                        </a>
                    </div>
                </div>
            </div>

            <a href="/office/upgrades" class="upgrades-back">&larr; All Upgrades</a>

            <!-- 3D Viewer / Render Hero -->
            <section class="upgrade-detail__hero">
                {hasMesh ? (
                    <div class="upgrade-detail__canvas-wrap" id="canvas-wrap" style="min-height:500px;">
                        <div class="upgrade-detail__canvas-hint">Loading 3D model…</div>
                    </div>
                ) : (
                    <div class="upgrade-detail__render-wrap">
                        <img
                            src={nextLevel.renderImage}
                            alt={item.name}
                            class="upgrade-detail__render-img"
                        />
                    </div>
                )}
            </section>

            <!-- Item Info -->
            <section class="upgrade-detail__info">
                <span class="upgrade-detail__category">{item.category}</span>
                <h1 class="upgrade-detail__title">{item.name}</h1>
                <p class="upgrade-detail__desc">{item.description}</p>

                <!-- Level Progression -->
                <div class="upgrade-detail__levels" id="levels-list">
                    {item.levels.map((lvl) => (
                        <a href={`/office/upgrades/${item.slug}`} class="upgrade-detail__level" data-level={lvl.level}>
                            <div class="upgrade-detail__level-header">
                                <div class="upgrade-detail__level-badge" data-level-badge={lvl.level}>
                                    Lv {lvl.level}
                                </div>
                                <h3 class="upgrade-detail__level-name">{lvl.name}</h3>
                                <span class="upgrade-detail__level-price">${lvl.price}</span>
                            </div>
                            <p class="upgrade-detail__level-desc">{lvl.description}</p>
                            <img
                                src={lvl.renderImage}
                                alt={lvl.name}
                                class="upgrade-detail__level-thumb"
                                onerror="this.style.display='none'"
                            />
                        </a>
                    ))}
                </div>

            </section>
        </main>



        <Footer />

        <!-- Item metadata for JS -->
        <script is:inline id="item-data" type="application/json"
            set:html={JSON.stringify({
                slug: item.slug,
                name: item.name,
                meshPath: item.meshPath || null,
                levels: item.levels,
            })}
        />

        <!-- Client-side logic -->
        <script is:inline>
            (async function () {
                "use strict";

                const itemData = JSON.parse(
                    document.getElementById("item-data")?.textContent || "{}"
                );

                let levelsData = { items: {} };

                async function loadLevels() {
                    try {
                        const res = await fetch("/api/office-levels.json");
                        const data = await res.json();
                        if (data.success !== false) levelsData = data;
                    } catch (e) {
                        console.warn("Could not load levels:", e);
                    }
                    renderLevels();
                }

                function renderLevels() {
                    const info = levelsData.items[itemData.slug];
                    const currentLevel = info?.currentLevel || 0;

                    // Highlight completed levels
                    document.querySelectorAll(".upgrade-detail__level").forEach((el) => {
                        const lvl = parseInt(el.dataset.level, 10);
                        if (lvl <= currentLevel) {
                            el.classList.add("upgrade-detail__level--completed");
                        } else if (lvl === currentLevel + 1) {
                            el.classList.add("upgrade-detail__level--next");
                        }
                    });

                    // Update badges
                    document.querySelectorAll("[data-level-badge]").forEach((badge) => {
                        const lvl = parseInt(badge.dataset.levelBadge, 10);
                        if (lvl <= currentLevel) {
                            badge.classList.add("upgrade-detail__level-badge--done");
                        }
                    });

                    // Update detail page progress bar
                    const goal = info?.nextLevel ? (info.cumulativeSpent + info.nextLevel.price) : info.totalRaised;
                    const pct = goal > 0 ? Math.min(100, parseFloat(((info.totalRaised / goal) * 100).toFixed(2))) : 0;
                    const raisedEl = document.getElementById('detail-raised');
                    const goalEl = document.getElementById('detail-goal');
                    const fillEl = document.getElementById('detail-fill');
                    const contribsEl = document.getElementById('detail-contribs');
                    if (raisedEl) raisedEl.textContent = '$' + Math.round(info.totalRaised) + ' raised';
                    if (goalEl) goalEl.textContent = 'Goal: $' + Math.round(goal);
                    if (fillEl) fillEl.style.width = pct + '%';
                    if (contribsEl) {
                        const c = info.contributions || 0;
                        contribsEl.textContent = c + ' contribution' + (c !== 1 ? 's' : '');
                    }
                }



                // Success — fetch session data and show thank-you card
                const params = new URLSearchParams(window.location.search);
                if (params.get("success") === "1" && params.get("session_id")) {
                    const card = document.getElementById("thankyou-card");
                    card.style.display = "";
                    window.scrollTo({ top: 0, behavior: 'smooth' });

                    try {
                        const res = await fetch(`/api/checkout-session.json?session_id=${encodeURIComponent(params.get("session_id"))}`);
                        const data = await res.json();
                        if (data.success) {
                            document.getElementById("thankyou-item").textContent = data.itemName;
                            document.getElementById("thankyou-amount").textContent = `$${data.amount}`;
                            if (data.email) {
                                document.getElementById("thankyou-email").textContent = data.email;
                                document.getElementById("thankyou-email-row").style.display = "";
                            }
                            if (data.receiptUrl) {
                                const link = document.getElementById("thankyou-receipt-link");
                                link.href = data.receiptUrl;
                                link.style.display = "";
                            }
                        }
                    } catch (e) {
                        console.error('Could not fetch session:', e);
                    }

                    window.history.replaceState({}, "", window.location.pathname);
                }

                // Contribute buttons — event delegation so floating bar buttons work too
                document.addEventListener('click', async (e) => {
                    const btn = e.target.closest('.promote-btn');
                    if (!btn || btn.disabled) return;

                    const amount = parseInt(btn.dataset.amount, 10);
                    const slug = btn.dataset.slug;
                    btn.textContent = '...';
                    btn.disabled = true;

                    try {
                        const res = await fetch('/api/create-upgrade-session', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ slug, customAmount: amount }),
                        });
                        const data = await res.json();
                        if (data.url) {
                            window.location.href = data.url;
                        } else {
                            alert('Could not create checkout. Please try again.');
                            btn.textContent = '$' + amount;
                            btn.disabled = false;
                        }
                    } catch (e) {
                        console.error('Checkout error:', e);
                        alert('Something went wrong.');
                        btn.textContent = '$' + amount;
                        btn.disabled = false;
                    }
                });

                loadLevels();
            })();
        </script>

        <!-- Three.js 3D Viewer (only loaded if item has a mesh) -->
        {hasMesh && (
            <script is:inline type="module">
                import * as THREE from 'https://cdn.jsdelivr.net/npm/three@0.163.0/build/three.module.js';
                import { GLTFLoader } from 'https://cdn.jsdelivr.net/npm/three@0.163.0/examples/jsm/loaders/GLTFLoader.js';
                import { OrbitControls } from 'https://cdn.jsdelivr.net/npm/three@0.163.0/examples/jsm/controls/OrbitControls.js';
                import { RGBELoader } from 'https://cdn.jsdelivr.net/npm/three@0.163.0/examples/jsm/loaders/RGBELoader.js';

                const meshPath = JSON.parse(document.getElementById('item-data')?.textContent || '{}').meshPath;
                if (!meshPath) { console.error('No meshPath'); throw new Error('No meshPath'); }

                const wrap = document.getElementById('canvas-wrap');
                if (!wrap) throw new Error('Canvas wrap not found');

                // --- Renderer ---
                const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: false });
                renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
                renderer.setSize(wrap.clientWidth, wrap.clientHeight, false);

                renderer.outputColorSpace = THREE.SRGBColorSpace;
                renderer.toneMapping = THREE.ACESFilmicToneMapping;
                renderer.toneMappingExposure = 1.6;

                renderer.shadowMap.enabled = true;
                renderer.shadowMap.type = THREE.PCFSoftShadowMap;

                wrap.appendChild(renderer.domElement);
                renderer.domElement.style.display = 'block';
                renderer.domElement.style.width = '100%';
                renderer.domElement.style.height = '100%';

                // --- Scene ---
                const scene = new THREE.Scene();

                // --- HDRI Environment (scene background + lighting + reflections) ---
                {
                    const pmrem = new THREE.PMREMGenerator(renderer);
                    pmrem.compileEquirectangularShader();
                    const hdr = await new RGBELoader().loadAsync('/hdr/industrial_sunset_puresky_1k.hdr');
                    const envMap = pmrem.fromEquirectangular(hdr).texture;
                    
                    scene.background = envMap;
                    scene.backgroundBlurriness = 0.04;  // slight blur so product pops
                    scene.backgroundIntensity = 0.7;    // dim background slightly
                    scene.environment = envMap;          // IBL for all materials
                    scene.environmentIntensity = 1.0;
                    
                    hdr.dispose();
                    pmrem.dispose();
                }
                const modelEnvMap = scene.environment;  // alias for model material override

                // --- Camera ---
                const camera = new THREE.PerspectiveCamera(
                    35,
                    wrap.clientWidth / wrap.clientHeight,
                    0.01,
                    1000
                );

                // --- Controls ---
                const controls = new OrbitControls(camera, renderer.domElement);
                controls.enableDamping = true;
                controls.dampingFactor = 0.08;
                controls.enablePan = false;
                controls.rotateSpeed = 0.6;
                controls.zoomSpeed = 0.8;
                controls.maxPolarAngle = Math.PI * 0.48;
                controls.autoRotate = true;
                controls.autoRotateSpeed = 0.4;

                // --- Supplementary key light for strong shadows ---
                const keyLight = new THREE.SpotLight(0xfff5e6, 40);
                keyLight.position.set(2, 8, 4);
                keyLight.target.position.set(0, 0, 0);
                keyLight.angle = Math.PI / 5;
                keyLight.penumbra = 0.7;
                keyLight.decay = 1.5;
                keyLight.distance = 30;
                keyLight.castShadow = true;
                keyLight.shadow.mapSize.set(2048, 2048);
                keyLight.shadow.camera.near = 0.5;
                keyLight.shadow.camera.far = 30;
                keyLight.shadow.bias = -0.001;
                scene.add(keyLight);
                scene.add(keyLight.target);

                // --- Reflective ground plane ---
                {
                    const floorMat = new THREE.MeshStandardMaterial({
                        color: 0x181820,
                        roughness: 0.3,
                        metalness: 0.4,
                        envMapIntensity: 0.5,
                    });
                    const floor = new THREE.Mesh(new THREE.CircleGeometry(20, 64), floorMat);
                    floor.rotation.x = -Math.PI / 2;
                    floor.position.y = 0;
                    floor.receiveShadow = true;
                    scene.add(floor);

                    // Shadow catcher
                    const shadowMat = new THREE.ShadowMaterial({ opacity: 0.3 });
                    const shadowPlane = new THREE.Mesh(new THREE.CircleGeometry(20, 64), shadowMat);
                    shadowPlane.rotation.x = -Math.PI / 2;
                    shadowPlane.position.y = 0.001;
                    shadowPlane.receiveShadow = true;
                    scene.add(shadowPlane);
                }

                // --- Auto-frame helper ---
                function frameObject(object3D, cam, ctrl, { fitOffset = 1.25, groundY = 0 } = {}) {
                    const box = new THREE.Box3().setFromObject(object3D);
                    const size = box.getSize(new THREE.Vector3());
                    const center = box.getCenter(new THREE.Vector3());

                    // Center model at origin
                    object3D.position.sub(center);

                    // Place on ground plane
                    const box2 = new THREE.Box3().setFromObject(object3D);
                    object3D.position.y += groundY - box2.min.y;

                    // Recalculate after repositioning
                    const box3 = new THREE.Box3().setFromObject(object3D);
                    const modelCenter = box3.getCenter(new THREE.Vector3());
                    const modelHeight = box3.max.y - box3.min.y;

                    const maxDim = Math.max(size.x, size.y, size.z);
                    const fov = THREE.MathUtils.degToRad(cam.fov);
                    let dist = Math.abs((maxDim / 2) / Math.tan(fov / 2)) * fitOffset;

                    // Eye-level view — shows both dark background and lit floor
                    const elevation = Math.PI / 12; // ~15° — gentle look-down, mostly eye-level
                    cam.position.set(
                        dist * 0.8,
                        modelHeight * 0.45 + dist * Math.sin(elevation),
                        dist * 0.8
                    );
                    cam.near = dist / 100;
                    cam.far = dist * 100;
                    cam.updateProjectionMatrix();

                    if (ctrl) {
                        ctrl.target.set(0, modelHeight * 0.4, 0);
                        ctrl.minDistance = dist / 4;
                        ctrl.maxDistance = dist * 4;
                        ctrl.update();
                    }
                }

                // --- Load GLB ---
                const loader = new GLTFLoader();
                loader.load(meshPath, (gltf) => {
                    const model = gltf.scene;

                    model.traverse((o) => {
                        if (!o.isMesh) return;
                        o.castShadow = true;
                        o.receiveShadow = true;
                        if (o.material) {
                            o.material.envMap = modelEnvMap;
                            o.material.envMapIntensity = 1.0;
                            if (o.material.map) o.material.map.anisotropy = 8;
                        }
                    });

                    scene.add(model);
                    frameObject(model, camera, controls, { fitOffset: 1.25, groundY: 0 });

                    const hint = document.querySelector('.upgrade-detail__canvas-hint');
                    if (hint) hint.textContent = 'Drag to rotate · Scroll to zoom';
                }, undefined, (err) => {
                    console.error('GLB load error:', err);
                    const hint = document.querySelector('.upgrade-detail__canvas-hint');
                    if (hint) hint.textContent = 'Failed to load 3D model';
                });

                // --- Resize (container-based) ---
                const ro = new ResizeObserver(() => {
                    const w = wrap.clientWidth;
                    const h = wrap.clientHeight;
                    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
                    renderer.setSize(w, h, false);
                    camera.aspect = w / h;
                    camera.updateProjectionMatrix();
                });
                ro.observe(wrap);

                // --- Render loop with animated lighting ---
                const clock = new THREE.Clock();
                const keyLightBaseIntensity = 40;
                const keyLightBasePos = keyLight.position.clone();

                function animate() {
                    requestAnimationFrame(animate);
                    controls.update();

                    const t = clock.getElapsedTime();

                    // Subtle intensity breathing (±20%)
                    keyLight.intensity = keyLightBaseIntensity * (1 + 0.2 * Math.sin(t * 0.8));

                    // Gentle light position drift
                    keyLight.position.x = keyLightBasePos.x + Math.sin(t * 0.3) * 0.8;
                    keyLight.position.z = keyLightBasePos.z + Math.cos(t * 0.4) * 0.6;

                    renderer.render(scene, camera);
                }
                animate();
            </script>
        )}
        <!-- Floating Upgrade Bar -->
        <div class="upgrade-bar" id="upgrade-bar">
            <div class="upgrade-bar__inner upgrade-bar__inner--stacked">
                <div class="upgrade-bar__top">
                    <div class="upgrade-bar__info">
                        <span class="upgrade-bar__name" set:html={item.name} />
                        <span class="upgrade-bar__sub">Contribute to this upgrade</span>
                    </div>
                    <div class="upgrade-bar__progress">
                        <div class="progress-bar__header">
                            <span class="progress-bar__raised" id="detail-raised">$0 raised</span>
                            <span class="progress-bar__goal" id="detail-goal">Goal: ${nextLevel.price}</span>
                        </div>
                        <div class="progress-bar__track">
                            <div class="progress-bar__fill" id="detail-fill" style="width: 0%"></div>
                        </div>
                        <span class="progress-bar__text" id="detail-contribs">0 contributions</span>
                    </div>
                </div>
                <div class="upgrade-bar__bottom">
                    <span class="upgrade-bar__cta">Contribute:</span>
                    <div class="promote-grid promote-grid--bar">
                        {[4, 8, 15, 16, 23, 42].map(amt => (
                            <button class="promote-btn promote-btn--bar" data-amount={amt} data-slug={item.slug}>
                                ${amt}
                            </button>
                        ))}
                    </div>
                </div>
            </div>
        </div>
        <MiniPlayer transition:persist="mini-player" />
    </body>
</html>
