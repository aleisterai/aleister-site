---
import "../../styles/global.css";
import "../../styles/office-dashboard.css";
import PageHeader from "../../components/PageHeader.astro";
import SEO from "../../components/SEO.astro";
import ThemeToggle from "../../components/ThemeToggle.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import MiniPlayer from "../../components/MiniPlayer.astro";
import { ViewTransitions } from "astro:transitions";
---

<!DOCTYPE html>
<html lang="en">
    <head>
        <script is:inline>
            (function () {
                const t = localStorage.getItem("theme") || "system";
                const d = window.matchMedia(
                    "(prefers-color-scheme: dark)"
                ).matches;
                document.documentElement.setAttribute(
                    "data-theme",
                    t === "system" ? (d ? "dark" : "light") : t
                );
            })();
        </script>
        <SEO
            title="Aleister — Operations Center"
            description="Live operational dashboard: agent status, task ledger, and project metrics for the Aleister AI agent system."
            image="/api/og/office"
        />
        <ViewTransitions />
        <script is:inline>
            document.addEventListener("astro:before-swap", function (e) {
                var theme = document.documentElement.getAttribute("data-theme");
                if (theme)
                    e.newDocument.documentElement.setAttribute(
                        "data-theme",
                        theme
                    );
            });
        </script>
    </head>
    <body>
        <Header />
        <main class="ops-dashboard">
            <!-- ── Hero ──────────────────────────────────────────────── -->
            <div class="ops-hero">
                <div class="ops-hero__text">
                    <PageHeader
                        title="Aleister"
                        accent="HQ"
                        subtitle="Live operational dashboard: agent status, task ledger, and project metrics."
                    >
                        <p class="ops-hero__chain">
                            Operations Center · Live <span
                                class="live-dot-inline"
                                ><span></span>
                            </span>
                        </p>
                    </PageHeader>
                    <a href="/office/upgrades" class="btn btn-primary">
                        🚀 Level Up Office →
                    </a>
                </div>
            </div>

            <!-- ── Top Row: Office Preview + Info Cards ──────────────── -->
            <section class="ops-top-row">
                <!-- Interactive Office Preview -->
                <a
                    href="/office/interactive"
                    class="ops-office-card"
                    title="View Interactive Pixel Office"
                >
                    <iframe
                        src="/office/preview"
                        class="ops-office-thumb"
                        loading="lazy"
                        tabindex="-1"
                        aria-hidden="true"></iframe>
                    <div class="ops-office-card__overlay">
                        <span class="ops-office-card__label"
                            >Interactive Office →</span
                        >
                        <span
                            class="ops-live-dot"
                            id="live-dot"
                            title="Checking..."></span>
                    </div>
                </a>

                <!-- Consolidated Info Cards -->
                <div class="ops-info-panel" id="info-panel">
                    <div class="ops-info-grid" id="info-grid">
                        <div class="ops-info-card">
                            <span class="ops-info-card__value" id="info-agents"
                                >—</span
                            >
                            <span class="ops-info-card__label">Agents</span>
                        </div>
                        <div class="ops-info-card">
                            <span class="ops-info-card__value" id="info-working"
                                >—</span
                            >
                            <span class="ops-info-card__label">Working</span>
                        </div>
                        <div class="ops-info-card">
                            <span class="ops-info-card__value" id="info-idle"
                                >—</span
                            >
                            <span class="ops-info-card__label">Idle</span>
                        </div>
                        <div class="ops-info-card">
                            <span class="ops-info-card__value" id="info-tokens"
                                >—</span
                            >
                            <span class="ops-info-card__label">Tokens</span>
                        </div>
                        <div class="ops-info-card">
                            <span class="ops-info-card__value" id="info-commits"
                                >—</span
                            >
                            <span class="ops-info-card__label">Commits</span>
                        </div>
                        <div class="ops-info-card">
                            <span class="ops-info-card__value" id="info-tasks"
                                >—</span
                            >
                            <span class="ops-info-card__label">Tasks Done</span>
                        </div>
                    </div>
                </div>
            </section>

            <!-- ── Agent Roster ────────────────────────────────────────── -->
            <section class="ops-roster-section">
                <h2 class="ops-section-title">Agent Roster</h2>
                <div class="ops-table-wrapper">
                    <table class="ops-table ops-roster-table" id="agent-roster">
                        <thead>
                            <tr>
                                <th>Agent</th>
                                <th>Role</th>
                                <th>Status</th>
                                <th>Current Task</th>
                            </tr>
                        </thead>
                        <tbody id="roster-tbody">
                            <tr
                                ><td colspan="4" class="ops-table__loading"
                                    >Loading agents...</td
                                >
                            </tr>
                        </tbody>
                    </table>
                </div>
            </section>

            <!-- ── Task Ledger ──────────────────────────────────────────── -->
            <section class="ops-ledger-section">
                <div class="ops-ledger-header">
                    <h2 class="ops-section-title">Task Ledger</h2>
                    <div class="ops-ledger-filters">
                        <select
                            id="filter-board"
                            class="ops-filter-select"
                            title="Filter by board"
                        >
                            <option value="all">All Boards</option>
                        </select>
                        <select
                            id="filter-status"
                            class="ops-filter-select"
                            title="Filter by status"
                        >
                            <option value="all">All Statuses</option>
                            <option value="In Progress">In Progress</option>
                            <option value="To Do">To Do</option>
                            <option value="Done">Done</option>
                        </select>
                    </div>
                </div>
                <div class="ops-table-wrapper">
                    <table class="ops-table" id="task-table">
                        <thead>
                            <tr>
                                <th>Title</th>
                                <th>Board</th>
                                <th>Assigned</th>
                                <th>Status</th>
                                <th>Labels</th>
                                <th>Updated</th>
                            </tr>
                        </thead>
                        <tbody id="task-tbody">
                            <tr
                                ><td colspan="6" class="ops-table__loading"
                                    >Loading tasks...</td
                                >
                            </tr>
                        </tbody>
                    </table>
                </div>
            </section>

            <!-- ── Backlog Queue ────────────────────────────────────────── -->
            <section class="ops-backlog-section">
                <h2 class="ops-section-title">Backlog Queue</h2>
                <div class="ops-table-wrapper">
                    <table class="ops-table" id="backlog-table">
                        <thead>
                            <tr>
                                <th>Title</th>
                                <th>Board</th>
                                <th>Assigned</th>
                                <th>Status</th>
                                <th>Labels</th>
                                <th>Created</th>
                            </tr>
                        </thead>
                        <tbody id="backlog-tbody">
                            <tr
                                ><td colspan="6" class="ops-table__loading"
                                    >Loading backlog...</td
                                >
                            </tr>
                        </tbody>
                    </table>
                </div>
            </section>
        </main>
        <Footer />

        <!-- ── Toast notification ───────────────────────────────────── -->
        <div class="ops-toast" id="ops-toast"></div>

        <script is:inline>
            (function () {
                "use strict";

                // ── Helpers ────────────────────────────────────────────────
                function $(sel) {
                    return document.querySelector(sel);
                }
                function $$(sel) {
                    return document.querySelectorAll(sel);
                }

                function timeAgo(dateStr) {
                    if (!dateStr) return "—";
                    const d = new Date(dateStr);
                    const s = Math.floor((Date.now() - d.getTime()) / 1000);
                    if (s < 60) return "just now";
                    if (s < 3600) return Math.floor(s / 60) + "m ago";
                    if (s < 86400) return Math.floor(s / 3600) + "h ago";
                    return Math.floor(s / 86400) + "d ago";
                }

                function showToast(msg) {
                    const t = $("#ops-toast");
                    t.textContent = msg;
                    t.classList.add("ops-toast--visible");
                    setTimeout(
                        () => t.classList.remove("ops-toast--visible"),
                        3000
                    );
                }

                function statusBadgeClass(status) {
                    switch (status) {
                        case "In Progress":
                            return "ops-status--progress";
                        case "Done":
                            return "ops-status--done";
                        case "To Do":
                        case "Todo":
                            return "ops-status--todo";
                        case "Backlog":
                            return "ops-status--backlog";
                        default:
                            return "ops-status--unknown";
                    }
                }

                // ── Agent Status + Info Cards ──────────────────────────────
                async function loadAgentStatus() {
                    try {
                        const res = await fetch("/api/agent-status.json");
                        const data = await res.json();
                        if (!data.success) return;

                        const s = data.summary;

                        // Populate info cards
                        $("#info-agents").textContent = s.online;
                        $("#info-working").textContent = s.working;
                        $("#info-idle").textContent = s.idle;

                        // Agent roster table
                        const tbody = $("#roster-tbody");
                        tbody.innerHTML = data.agents
                            .map(
                                (a) => `
                            <tr class="ops-roster-row">
                                <td class="ops-roster__agent">
                                    <img class="ops-roster__avatar" src="${
                                        a.avatar
                                    }" alt="${a.name}" loading="lazy" />
                                    <span class="ops-roster__name" style="color: ${
                                        a.color
                                    }">${a.name}</span>
                                </td>
                                <td class="ops-roster__role">${a.role}</td>
                                <td>
                                    <span class="ops-roster__status ops-roster__status--${
                                        a.status
                                    }">${
                                    a.status === "working" ? "Working" : "Idle"
                                }</span>
                                </td>
                                <td class="ops-roster__task">${
                                    a.status === "working" ? a.activity : "—"
                                }</td>
                            </tr>
                        `
                            )
                            .join("");

                        // Live dot
                        const dot = $("#live-dot");
                        dot.classList.toggle(
                            "ops-live-dot--online",
                            data.gatewayOnline || data.agents[0]?.online
                        );
                        dot.title = data.gatewayOnline
                            ? "Gateway Online"
                            : "Simulated";
                    } catch (e) {
                        console.error("Agent status error:", e);
                    }
                }

                // ── Assignee Avatar Mapping ───────────────────────────────
                const ASSIGNEE_MAP = {
                    vrusavuk: {
                        name: "Aleister",
                        avatar: "/avatars/hero-avatar.gif",
                    },
                    aleisterai: {
                        name: "Aleister",
                        avatar: "/avatars/hero-avatar.gif",
                    },
                    aleister: {
                        name: "Aleister",
                        avatar: "/avatars/hero-avatar.gif",
                    },
                    cipher: { name: "Cipher", avatar: "/avatars/cipher.png" },
                    sage: { name: "Sage", avatar: "/avatars/sage.png" },
                    quill: { name: "Quill", avatar: "/avatars/quill.png" },
                    rally: { name: "Rally", avatar: "/avatars/rally.png" },
                    echo: { name: "Echo", avatar: "/avatars/echo.png" },
                    pixel: { name: "Pixel", avatar: "/avatars/pixel.png" },
                    forge: { name: "Forge", avatar: "/avatars/forge.png" },
                    prism: { name: "Prism", avatar: "/avatars/prism.png" },
                    lyra: { name: "Lyra", avatar: "/avatars/lyra.png" },
                };

                function renderAssignee(task) {
                    const raw =
                        task.assignedAgent ||
                        (task.assignees && task.assignees[0]) ||
                        "";
                    if (!raw) return "\u2014";
                    const key = raw.toLowerCase().trim();
                    const mapped = ASSIGNEE_MAP[key];
                    if (mapped) {
                        return `<img class="ops-table__avatar" src="${mapped.avatar}" alt="${mapped.name}" title="${mapped.name}" loading="lazy" />`;
                    }
                    return raw;
                }

                // ── Metrics (populates info cards) ────────────────────────
                function fmtNum(n) {
                    if (n >= 1e9) return (n / 1e9).toFixed(1) + "B";
                    if (n >= 1e6) return (n / 1e6).toFixed(1) + "M";
                    if (n >= 1e3) return (n / 1e3).toFixed(1) + "K";
                    return n.toLocaleString();
                }

                async function loadMetrics() {
                    try {
                        const [metricsRes, ideRes] = await Promise.all([
                            fetch("/api/agent-metrics.json"),
                            fetch("/api/ide-usage.json"),
                        ]);
                        const metrics = await metricsRes.json();
                        const ide = await ideRes.json();
                        const m = metrics.metrics || {};

                        const tokensOut = 3220132;
                        const apiRequests = 20218;
                        const ideTokens = ide.usage?.totalTokens || 0;
                        const totalTokens = tokensOut + ideTokens;

                        // Populate info cards
                        $("#info-tokens").textContent = fmtNum(totalTokens);
                        $("#info-commits").textContent = (
                            m.commits?.total || 0
                        ).toLocaleString();
                        $("#info-tasks").textContent = (
                            m.issuesClosed?.allTime || 0
                        ).toLocaleString();
                    } catch (e) {
                        console.error("Metrics error:", e);
                    }
                }

                // ── Task Ledger ────────────────────────────────────────────
                let allTasks = [];
                let allBoards = [];

                async function loadTasks() {
                    try {
                        const res = await fetch("/api/project-board.json");
                        const data = await res.json();
                        if (!data.success) return;

                        allTasks = data.items || [];
                        allBoards = data.boards || [];

                        // Populate board filter
                        const boardFilter = $("#filter-board");
                        boardFilter.innerHTML =
                            '<option value="all">All Boards</option>' +
                            allBoards
                                .map(
                                    (b) =>
                                        `<option value="${b.label}">${
                                            b.label
                                        } (${b.totalCount || 0})</option>`
                                )
                                .join("");

                        renderTasks();
                        renderBacklog();
                    } catch (e) {
                        console.error("Tasks error:", e);
                    }
                }

                function renderTasks() {
                    const boardVal = $("#filter-board").value;
                    const statusVal = $("#filter-status").value;

                    let filtered = allTasks.filter(
                        (t) => t.status !== "Backlog"
                    );
                    if (boardVal !== "all")
                        filtered = filtered.filter((t) => t.board === boardVal);
                    if (statusVal !== "all")
                        filtered = filtered.filter(
                            (t) => t.status === statusVal
                        );

                    // Sort: In Progress first, then To Do, then Done
                    const order = {
                        "In Progress": 0,
                        "To Do": 1,
                        Todo: 1,
                        Done: 2,
                    };
                    filtered.sort(
                        (a, b) =>
                            (order[a.status] ?? 3) - (order[b.status] ?? 3)
                    );

                    const tbody = $("#task-tbody");
                    if (filtered.length === 0) {
                        tbody.innerHTML =
                            '<tr><td colspan="6" class="ops-table__empty">No tasks found</td></tr>';
                        return;
                    }

                    tbody.innerHTML = filtered
                        .map((t) => {
                            const labels = (t.labels || [])
                                .map(
                                    (l) =>
                                        `<span class="ops-label" style="--label-color: #${l.color}">${l.name}</span>`
                                )
                                .join("");
                            const statusClass = statusBadgeClass(t.status);
                            const isPrivate = t.isPrivate;
                            const clickAttr = isPrivate
                                ? `onclick="event.preventDefault(); window.__opsToast('This task resides on a private board')"`
                                : t.url
                                ? `onclick="window.open('${t.url}', '_blank')"`
                                : "";
                            const cursor =
                                isPrivate || t.url ? "cursor: pointer;" : "";
                            const lockIcon = isPrivate
                                ? '<span class="ops-lock" title="Private board">🔒</span>'
                                : "";

                            return `<tr style="${cursor}" ${clickAttr}>
                        <td class="ops-table__title">${lockIcon}${t.title}</td>
                        <td class="ops-table__board">${t.board}</td>
                        <td>${renderAssignee(t)}</td>
                        <td><span class="ops-status ${statusClass}">${
                                t.status
                            }</span></td>
                        <td>${labels || "—"}</td>
                        <td class="ops-table__time">${timeAgo(t.updatedAt)}</td>
                    </tr>`;
                        })
                        .join("");
                }

                function renderBacklog() {
                    const backlog = allTasks.filter(
                        (t) => t.status === "Backlog"
                    );
                    const tbody = $("#backlog-tbody");

                    if (backlog.length === 0) {
                        tbody.innerHTML =
                            '<tr><td colspan="6" class="ops-table__empty">No items in backlog</td></tr>';
                        return;
                    }

                    tbody.innerHTML = backlog
                        .map((t) => {
                            const labels = (t.labels || [])
                                .map(
                                    (l) =>
                                        `<span class="ops-label" style="--label-color: #${l.color}">${l.name}</span>`
                                )
                                .join("");
                            const isPrivate = t.isPrivate;
                            const clickAttr = isPrivate
                                ? `onclick="event.preventDefault(); window.__opsToast('This task resides on a private board')"`
                                : t.url
                                ? `onclick="window.open('${t.url}', '_blank')"`
                                : "";
                            const cursor =
                                isPrivate || t.url ? "cursor: pointer;" : "";
                            const lockIcon = isPrivate
                                ? '<span class="ops-lock" title="Private board">\ud83d\udd12</span>'
                                : "";

                            return `<tr style="${cursor}" ${clickAttr}>
                        <td class="ops-table__title">${lockIcon}${t.title}</td>
                        <td class="ops-table__board">${t.board}</td>
                        <td>${renderAssignee(t)}</td>
                        <td><span class="ops-status ops-status--backlog">${
                            t.status
                        }</span></td>
                        <td>${labels || "\u2014"}</td>
                        <td class="ops-table__time">${timeAgo(t.createdAt)}</td>
                    </tr>`;
                        })
                        .join("");
                }

                // ── Toast helper ───────────────────────────────────────────
                window.__opsToast = showToast;

                // ── Filters ────────────────────────────────────────────────
                document.addEventListener("change", (e) => {
                    if (
                        e.target.id === "filter-board" ||
                        e.target.id === "filter-status"
                    ) {
                        renderTasks();
                    }
                });

                // ── Init ───────────────────────────────────────────────────
                loadAgentStatus();
                loadMetrics();
                loadTasks();

                // Auto-refresh every 60s
                setInterval(loadAgentStatus, 30000);
                setInterval(loadMetrics, 120000);
                setInterval(loadTasks, 120000);
            })();
        </script>
        <MiniPlayer transition:persist="mini-player" />
    </body>
</html>
