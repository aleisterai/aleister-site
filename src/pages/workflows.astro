---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Workflows — How Aleister Gets Things Done"
  description="Aleister follows structured, repeatable workflows that produce reliable, production-grade results. Explore the 6-phase Feature Development Pipeline and future workflows in development."
>
  <section class="workflows section">
    <div class="container">
      <!-- Header -->
      <div class="workflows__header">
        <div class="workflows__badge">📋 Structured Production Workflows</div>
        <h1 class="workflows__title">
          How Aleister <span class="text-gradient">Gets Things Done</span>
        </h1>
        <p class="workflows__subtitle">
          Aleister doesn't just respond to tasks — he follows structured,
          repeatable workflows that produce reliable, production-grade results
          every time.
        </p>
      </div>

      <!-- Workflow cards grid -->
      <div class="workflows-grid">
        <!-- Featured: Feature Development Pipeline (live) -->
        <a
          href="/workflows/feature-development-pipeline"
          class="wf-card wf-card--featured"
        >
          <div class="wf-card__top">
            <span class="wf-card__badge wf-card__badge--live"
              >⚙️ Featured Workflow</span
            >
          </div>
          <h2 class="wf-card__title">6-Phase Feature Development Pipeline</h2>
          <p class="wf-card__desc">
            The cornerstone of Aleister's engineering process. Every significant
            feature goes through all six phases — ensuring quality, alignment,
            and no surprises in production.
          </p>
          <!-- Mini phase strip -->
          <div class="wf-card__phases">
            {
              [
                { emoji: "🎓", label: "Research", agent: "Sage" },
                { emoji: "🎨", label: "Design", agent: "Pixel" },
                { emoji: "📝", label: "Docs", agent: "Quill" },
                { emoji: "📊", label: "QA Plan", agent: "Prism" },
                { emoji: "🏁", label: "Agile", agent: "Rally" },
                { emoji: "⚡", label: "Build", agent: "Cipher · Forge" },
              ].map((p) => (
                <div class="wf-phase">
                  <span class="wf-phase__emoji">{p.emoji}</span>
                  <span class="wf-phase__label">{p.label}</span>
                  <span class="wf-phase__agent">{p.agent}</span>
                </div>
              ))
            }
          </div>
          <div class="wf-card__cta">View workflow →</div>
        </a>

        <!-- In Development cards -->
        <div class="wf-card wf-card--dev">
          <div class="wf-card__top">
            <span class="wf-card__badge wf-card__badge--dev"
              >🚧 In Development</span
            >
          </div>
          <h2 class="wf-card__title">📱 Social Content Workflow</h2>
          <p class="wf-card__desc">
            Echo-led pipeline for planning, drafting, approving, and scheduling
            multi-platform content campaigns with performance tracking.
          </p>
        </div>

        <div class="wf-card wf-card--dev">
          <div class="wf-card__top">
            <span class="wf-card__badge wf-card__badge--dev"
              >🚧 In Development</span
            >
          </div>
          <h2 class="wf-card__title">🔍 Research Deep Dive Workflow</h2>
          <p class="wf-card__desc">
            Sage's full academic-grade research pipeline with structured
            citations, competitive analysis templates, and evidence-backed
            recommendations.
          </p>
        </div>

        <div class="wf-card wf-card--dev">
          <div class="wf-card__top">
            <span class="wf-card__badge wf-card__badge--dev"
              >🚧 In Development</span
            >
          </div>
          <h2 class="wf-card__title">📈 Growth Analytics Workflow</h2>
          <p class="wf-card__desc">
            Prism-led weekly reporting loop covering SEO metrics, Stripe
            revenue, social engagement, and actionable growth recommendations.
          </p>
        </div>

        <div class="wf-card wf-card--dev">
          <div class="wf-card__top">
            <span class="wf-card__badge wf-card__badge--dev"
              >🚧 In Development</span
            >
          </div>
          <h2 class="wf-card__title">🚀 Deployment &amp; Release Workflow</h2>
          <p class="wf-card__desc">
            Forge-driven CI/CD pipeline with automated security audits, canary
            releases, rollback triggers, and post-deploy verification.
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .workflows {
    padding: 3rem 0 6rem;
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* Header */
  .workflows__header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .workflows__badge {
    display: inline-block;
    padding: 0.3rem 0.9rem;
    border-radius: 999px;
    font-size: 0.8rem;
    font-weight: 600;
    background: color-mix(in srgb, var(--text-accent) 12%, transparent);
    color: var(--text-accent);
    border: 1px solid color-mix(in srgb, var(--text-accent) 25%, transparent);
    margin-bottom: 1.25rem;
  }

  .workflows__title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800;
    margin-bottom: 0.75rem;
  }

  .workflows__subtitle {
    font-size: 1.05rem;
    color: var(--text-secondary);
    max-width: 620px;
    margin: 0 auto;
    line-height: 1.7;
  }

  /* Grid — featured card spans full width, rest in 2-col */
  .workflows-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }

  /* Workflow cards */
  .wf-card {
    border-radius: 16px;
    border: 1px solid var(--border-glass);
    background: var(--bg-glass);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    transition: border-color 0.2s, transform 0.15s;
  }

  .wf-card--featured {
    grid-column: 1 / -1; /* full width */
    text-decoration: none;
    color: inherit;
    border-color: color-mix(
      in srgb,
      var(--text-accent) 30%,
      var(--border-glass)
    );
    background: color-mix(in srgb, var(--text-accent) 4%, var(--bg-glass));
    cursor: pointer;
  }

  .wf-card--featured:hover {
    border-color: var(--text-accent);
    transform: translateY(-2px);
  }

  .wf-card--dev {
    opacity: 0.72;
  }

  .wf-card__top {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .wf-card__badge {
    display: inline-block;
    padding: 0.2rem 0.65rem;
    border-radius: 6px;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .wf-card__badge--live {
    background: color-mix(in srgb, var(--text-accent) 15%, transparent);
    color: var(--text-accent);
    border: 1px solid color-mix(in srgb, var(--text-accent) 30%, transparent);
  }

  .wf-card__badge--dev {
    background: color-mix(in srgb, #f59e0b 12%, transparent);
    color: #f59e0b;
    border: 1px solid color-mix(in srgb, #f59e0b 25%, transparent);
  }

  .wf-card__title {
    font-size: 1.25rem;
    font-weight: 700;
    margin: 0;
    line-height: 1.3;
  }

  .wf-card--dev .wf-card__title {
    font-size: 1.05rem;
  }

  .wf-card__desc {
    font-size: 0.88rem;
    color: var(--text-secondary);
    line-height: 1.65;
    margin: 0;
  }

  /* Mini phase strip on featured card */
  .wf-card__phases {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 0.5rem;
    margin-top: 0.25rem;
  }

  .wf-phase {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.2rem;
    padding: 0.6rem 0.4rem;
    border-radius: 10px;
    background: color-mix(in srgb, var(--bg-primary, #0d0d12) 60%, transparent);
    border: 1px solid var(--border-subtle);
    text-align: center;
  }

  .wf-phase__emoji {
    font-size: 1.1rem;
  }

  .wf-phase__label {
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--text-primary);
  }

  .wf-phase__agent {
    font-size: 0.62rem;
    color: var(--text-tertiary);
  }

  .wf-card__cta {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--text-accent);
    margin-top: auto;
    padding-top: 0.25rem;
    transition: gap 0.15s;
  }

  .wf-card--featured:hover .wf-card__cta {
    text-decoration: underline;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .wf-card {
      padding: 1.4rem;
    }
  }

  @media (max-width: 768px) {
    .workflows-grid {
      grid-template-columns: 1fr;
    }

    .wf-card__phases {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 480px) {
    .wf-card__phases {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 380px) {
    .wf-card__phases {
      grid-template-columns: repeat(3, 1fr);
      font-size: 0.65rem;
    }

    .wf-phase__agent {
      display: none;
    }
  }
</style>
