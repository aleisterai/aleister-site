---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { books } from "../../data/books";
import { marked } from "marked";

const { slug } = Astro.params;
const book = books.find((b) => b.slug === slug);

if (!book) {
    return Astro.redirect("/books");
}

// Fetch the markdown file via HTTP – works on both local dev and Vercel serverless
const mdUrl = new URL(`/books/${book.slug}.md`, Astro.url);
const mdResponse = await fetch(mdUrl);
if (!mdResponse.ok) {
    return Astro.redirect("/books");
}
const mdContent = await mdResponse.text();
const htmlContent = await marked.parse(mdContent);

// Extract chapter headings for table of contents
interface TocEntry {
    level: number;
    text: string;
    id: string;
}
const tocEntries: TocEntry[] = [];

// Parse headings, skipping lines inside fenced code blocks
const lines = mdContent.split("\n");
let inCodeBlock = false;
for (const line of lines) {
    if (line.trim().startsWith("```")) {
        inCodeBlock = !inCodeBlock;
        continue;
    }
    if (inCodeBlock) continue;
    const m = /^(#{1,3})\s+(.+)$/.exec(line);
    if (!m) continue;
    const level = m[1].length;
    const text = m[2].replace(/\*\*/g, "").trim();
    const id = text
        .toLowerCase()
        .replace(/[^a-z0-9\s-]/g, "")
        .replace(/\s+/g, "-")
        .replace(/-+/g, "-");
    tocEntries.push({ level, text, id });
}

// Only include real chapter-level entries in the TOC
const chapterPattern = /^(chapter\s+\d|part\s+[ivxlcdm\d]|preface|appendix)/i;
const tocFiltered = tocEntries.filter(
    (e) => e.level <= 2 && chapterPattern.test(e.text)
);
// For the progress counter, only count actual "Chapter N" entries
const chapterOnly = tocFiltered.filter((e) => /^chapter\s+\d/i.test(e.text));
const totalChapters = chapterOnly.length;

// Add IDs to headings in the HTML for anchor links
let processedHtml = htmlContent;
for (const entry of tocEntries) {
    const escapedText = entry.text.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
    const tagName = `h${entry.level}`;
    const regex = new RegExp(
        `<${tagName}>(.*?${escapedText.replace(
            /\s+/g,
            "\\s*"
        )}.*?)</${tagName}>`,
        "i"
    );
    processedHtml = processedHtml.replace(
        regex,
        `<${tagName} id="${entry.id}">$1</${tagName}>`
    );
}
---

<BaseLayout
    title={`${book.title} — Aleister`}
    description={book.description}
    image={`/api/og/book?slug=${book.slug}`}
    imageAlt={book.title}
>
    <section class="book-detail section">
        <div class="container">
            <div class="book-detail__top">
                <a href="/books" class="book-detail__back">← Back to books</a>
                <a
                    href={book.mdFile}
                    download={`${book.slug}.md`}
                    class="btn btn-primary book-detail__download"
                >
                    <svg
                        width="16"
                        height="16"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                    >
                        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"
                        ></path>
                        <polyline points="7 10 12 15 17 10"></polyline>
                        <line x1="12" y1="15" x2="12" y2="3"></line>
                    </svg>
                    Download Book
                </a>
            </div>

            <div class="book-detail__hero">
                <div class="book-detail__cover-wrap">
                    <img
                        src={book.coverImage}
                        alt={book.title}
                        class="book-detail__cover"
                    />
                </div>
                <div class="book-detail__meta">
                    <h1 class="book-detail__title">{book.title}</h1>
                    <p class="book-detail__subtitle">{book.subtitle}</p>
                    <p class="book-detail__author">By {book.author}</p>
                    <div class="book-detail__tags">
                        {
                            book.tags.map((tag) => (
                                <span class="chip">{tag}</span>
                            ))
                        }
                    </div>
                    <p class="book-detail__desc">{book.description}</p>
                    <span class="book-detail__date mono"
                        >Published {book.publishDate}</span
                    >
                </div>
            </div>

            <hr class="book-detail__divider" />

            <article
                class="book-detail__content prose"
                set:html={processedHtml}
            >
            </article>
        </div>
    </section>

    <!-- Floating chapter index -->
    <div class="toc-fab" id="toc-fab">
        <button
            class="toc-fab__toggle"
            id="toc-toggle"
            aria-label="Table of Contents"
            aria-expanded="false"
        >
            <svg
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
            >
                <line x1="3" y1="6" x2="21" y2="6"></line>
                <line x1="3" y1="12" x2="15" y2="12"></line>
                <line x1="3" y1="18" x2="18" y2="18"></line>
            </svg>
            <span class="toc-fab__label">Chapters</span>
        </button>
        <nav class="toc-fab__panel" id="toc-panel" aria-hidden="true">
            <div class="toc-fab__header">
                <span class="toc-fab__heading">Table of Contents</span>
                <button
                    class="toc-fab__close"
                    id="toc-close"
                    aria-label="Close"
                >
                    <svg
                        width="16"
                        height="16"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                    >
                        <line x1="18" y1="6" x2="6" y2="18"></line>
                        <line x1="6" y1="6" x2="18" y2="18"></line>
                    </svg>
                </button>
            </div>
            <ul class="toc-fab__list">
                {
                    tocFiltered.map((entry) => (
                        <li
                            class={`toc-fab__item toc-fab__item--l${entry.level}`}
                        >
                            <a
                                href={`#${entry.id}`}
                                class="toc-fab__link"
                                data-toc-link
                            >
                                {entry.text}
                            </a>
                        </li>
                    ))
                }
            </ul>
        </nav>
    </div>

    <!-- Floating chapter progress indicator -->
    <div
        class="chapter-progress"
        id="chapter-progress"
        data-chapter-ids={JSON.stringify(chapterOnly.map((e) => e.id))}
    >
        <div class="chapter-progress__inner">
            <div class="chapter-progress__bar">
                <div class="chapter-progress__fill" id="chapter-progress-fill">
                </div>
            </div>
            <div class="chapter-progress__info">
                <span class="chapter-progress__current" id="chapter-current"
                    >—</span
                >
                <span class="chapter-progress__sep">of</span>
                <span class="chapter-progress__total">{totalChapters}</span>
                <span class="chapter-progress__label">chapters</span>
            </div>
        </div>
    </div>
</BaseLayout>

<script is:inline>
    document.addEventListener("astro:page-load", function () {
        // ── TOC toggle ──
        var toggle = document.getElementById("toc-toggle");
        var panel = document.getElementById("toc-panel");
        var closeBtn = document.getElementById("toc-close");
        var fab = document.getElementById("toc-fab");
        if (!toggle || !panel || !fab) return;

        function openToc() {
            panel.classList.add("open");
            panel.setAttribute("aria-hidden", "false");
            toggle.setAttribute("aria-expanded", "true");
        }
        function closeToc() {
            panel.classList.remove("open");
            panel.setAttribute("aria-hidden", "true");
            toggle.setAttribute("aria-expanded", "false");
        }

        toggle.addEventListener("click", function () {
            if (panel.classList.contains("open")) closeToc();
            else openToc();
        });

        if (closeBtn) closeBtn.addEventListener("click", closeToc);

        panel.querySelectorAll("[data-toc-link]").forEach(function (link) {
            link.addEventListener("click", function () {
                closeToc();
            });
        });

        document.addEventListener("click", function (e) {
            if (!fab.contains(e.target)) closeToc();
        });

        // ── Chapter progress tracker ──
        var progressEl = document.getElementById("chapter-progress");
        var currentEl = document.getElementById("chapter-current");
        var fillEl = document.getElementById("chapter-progress-fill");
        if (!progressEl || !currentEl || !fillEl) return;

        // Gather chapter headings by their IDs
        var chapterIds = JSON.parse(
            progressEl.getAttribute("data-chapter-ids") || "[]"
        );
        var chapterEls = chapterIds
            .map(function (id) {
                return document.getElementById(id);
            })
            .filter(Boolean);
        var totalCount = chapterEls.length;
        if (totalCount === 0) return;

        var lastChapter = 0;

        function updateChapterProgress() {
            var current = 0;
            var scrollY = window.scrollY + window.innerHeight * 0.3;

            for (var i = 0; i < chapterEls.length; i++) {
                if (
                    chapterEls[i].getBoundingClientRect().top +
                        window.scrollY <=
                    scrollY
                ) {
                    current = i + 1;
                }
            }

            if (current !== lastChapter) {
                lastChapter = current;
                currentEl.textContent = current === 0 ? "—" : String(current);
                var pct = totalCount > 0 ? (current / totalCount) * 100 : 0;
                fillEl.style.width = pct + "%";
            }

            // Show/hide based on scroll position
            var contentEl = document.querySelector(".book-detail__content");
            var contentTop = contentEl
                ? contentEl.getBoundingClientRect().top + window.scrollY
                : 0;
            if (window.scrollY > contentTop - 200) {
                progressEl.classList.add("visible");
            } else {
                progressEl.classList.remove("visible");
            }
        }

        window.addEventListener("scroll", updateChapterProgress, {
            passive: true,
        });
        updateChapterProgress();
    });
</script>

<style>
    .book-detail {
        padding-top: 2rem;
        padding-bottom: 5rem;
        min-height: 100vh;
    }

    /* ── Top bar ── */
    .book-detail__top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 2.5rem;
    }

    .book-detail__back {
        font-size: 0.9rem;
        color: var(--text-secondary);
        transition: color 0.2s ease;
    }

    .book-detail__back:hover {
        color: var(--text-accent);
    }

    .book-detail__download {
        font-size: 0.85rem;
        padding: 0.6rem 1.25rem;
        gap: 0.4rem;
        border-radius: 10px;
        text-decoration: none;
        white-space: nowrap;
    }

    /* ── Hero ── */
    .book-detail__hero {
        display: grid;
        grid-template-columns: 240px 1fr;
        gap: 2.5rem;
        align-items: start;
        margin-bottom: 3rem;
    }

    .book-detail__cover-wrap {
        border-radius: 12px;
        overflow: hidden;
        box-shadow: var(--shadow-lg), var(--shadow-glow);
    }

    .book-detail__cover {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .book-detail__meta {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .book-detail__title {
        font-size: clamp(1.5rem, 3vw, 2.25rem);
        font-weight: 800;
        letter-spacing: -0.02em;
        line-height: 1.15;
    }

    .book-detail__subtitle {
        font-size: 1rem;
        color: var(--text-accent);
        font-style: italic;
        font-weight: 500;
        margin: 0;
    }

    .book-detail__author {
        font-size: 0.9rem;
        color: var(--text-tertiary);
        font-weight: 600;
        margin: 0;
    }

    .book-detail__tags {
        display: flex;
        gap: 0.4rem;
        flex-wrap: wrap;
    }

    .book-detail__desc {
        font-size: 0.9rem;
        color: var(--text-secondary);
        line-height: 1.6;
        margin: 0;
    }

    .book-detail__date {
        font-size: 0.8rem;
        color: var(--text-accent);
        font-weight: 600;
    }

    .book-detail__divider {
        border: none;
        border-top: 1px solid var(--border-subtle);
        margin: 0 0 3rem;
    }

    /* ── Prose (markdown body) ── */
    .book-detail__content {
        max-width: 1200px;
        margin: 0 auto;
    }

    .book-detail__content :global(h1) {
        font-size: clamp(1.75rem, 3vw, 2.5rem);
        margin-top: 3.5rem;
        margin-bottom: 1.25rem;
        padding-bottom: 0.75rem;
        border-bottom: 2px solid var(--border-accent);
    }

    .book-detail__content :global(h2) {
        font-size: clamp(1.35rem, 2.5vw, 1.85rem);
        margin-top: 3rem;
        margin-bottom: 1rem;
        padding-bottom: 0.5rem;
        border-bottom: 1px solid var(--border-subtle);
    }

    .book-detail__content :global(h3) {
        font-size: clamp(1.1rem, 2vw, 1.4rem);
        margin-top: 2rem;
        margin-bottom: 0.75rem;
    }

    .book-detail__content :global(h4) {
        font-size: 1.1rem;
        margin-top: 1.5rem;
        margin-bottom: 0.5rem;
        color: var(--text-accent);
    }

    .book-detail__content :global(p) {
        margin-bottom: 1.15rem;
        line-height: 1.8;
        font-size: 1rem;
    }

    .book-detail__content :global(ul),
    .book-detail__content :global(ol) {
        padding-left: 1.5rem;
        margin-bottom: 1.25rem;
        list-style: disc;
    }

    .book-detail__content :global(ol) {
        list-style: decimal;
    }

    .book-detail__content :global(li) {
        margin-bottom: 0.5rem;
        line-height: 1.7;
        color: var(--text-secondary);
    }

    .book-detail__content :global(li strong) {
        color: var(--text-primary);
    }

    .book-detail__content :global(code) {
        font-family: "JetBrains Mono", monospace;
        font-size: 0.85em;
        padding: 0.15rem 0.4rem;
        border-radius: 4px;
        background: var(--bg-glass);
        border: 1px solid var(--border-subtle);
        color: var(--text-accent);
    }

    .book-detail__content :global(pre) {
        padding: 1.25rem 1.5rem;
        border-radius: 12px;
        background: var(--bg-secondary);
        border: 1px solid var(--border-subtle);
        overflow-x: auto;
        margin-bottom: 1.75rem;
        line-height: 1.55;
    }

    .book-detail__content :global(pre code) {
        padding: 0;
        border: none;
        background: none;
        color: var(--text-primary);
        font-size: 0.88rem;
    }

    .book-detail__content :global(a) {
        color: var(--text-accent);
        border-bottom: 1px solid var(--border-accent);
        transition: opacity 0.2s ease;
    }

    .book-detail__content :global(a:hover) {
        opacity: 0.8;
    }

    .book-detail__content :global(blockquote) {
        border-left: 3px solid var(--text-accent);
        padding: 1rem 1.25rem;
        margin: 1.5rem 0;
        color: var(--text-secondary);
        font-style: italic;
        background: var(--bg-glass);
        border-radius: 0 8px 8px 0;
    }

    .book-detail__content :global(hr) {
        border: none;
        border-top: 1px solid var(--border-subtle);
        margin: 3rem 0;
    }

    .book-detail__content :global(table) {
        width: 100%;
        border-collapse: collapse;
        margin-bottom: 1.75rem;
        font-size: 0.9rem;
    }

    .book-detail__content :global(th) {
        text-align: left;
        padding: 0.75rem 1rem;
        border-bottom: 2px solid var(--border-glass);
        font-weight: 700;
        color: var(--text-primary);
        background: var(--bg-glass);
    }

    .book-detail__content :global(td) {
        padding: 0.65rem 1rem;
        border-bottom: 1px solid var(--border-subtle);
        color: var(--text-secondary);
    }

    .book-detail__content :global(tr:hover td) {
        background: var(--bg-glass);
    }

    .book-detail__content :global(strong) {
        color: var(--text-primary);
        font-weight: 700;
    }

    .book-detail__content :global(em) {
        color: var(--text-secondary);
    }

    /* ── Floating TOC FAB ── */
    .toc-fab {
        position: fixed;
        bottom: 5.5rem;
        right: 2rem;
        z-index: 90;
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        gap: 0.5rem;
    }

    .toc-fab__toggle {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.75rem 1.25rem;
        border-radius: 50px;
        border: 1px solid var(--border-glass);
        background: var(--bg-primary);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        color: var(--text-primary);
        font-family: inherit;
        font-size: 0.85rem;
        font-weight: 600;
        cursor: pointer;
        box-shadow: var(--shadow-lg);
        transition: all 0.2s ease;
    }

    .toc-fab__toggle:hover {
        border-color: var(--border-accent);
        box-shadow: var(--shadow-lg), var(--shadow-glow);
        transform: translateY(-1px);
    }

    .toc-fab__label {
        pointer-events: none;
    }

    .toc-fab__panel {
        display: none;
        position: absolute;
        bottom: calc(100% + 0.75rem);
        right: 0;
        width: 340px;
        max-height: 70vh;
        overflow-y: auto;
        background: var(--bg-primary);
        border: 1px solid var(--border-glass);
        border-radius: 16px;
        box-shadow: var(--shadow-lg);
        padding: 0;
        opacity: 0;
        transform: translateY(8px) scale(0.97);
        transition: opacity 0.25s ease, transform 0.25s ease;
    }

    .toc-fab__panel.open {
        display: block;
        opacity: 1;
        transform: translateY(0) scale(1);
    }

    .toc-fab__header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1rem 1.25rem 0.75rem;
        border-bottom: 1px solid var(--border-subtle);
    }

    .toc-fab__heading {
        font-size: 0.8rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--text-tertiary);
    }

    .toc-fab__close {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 28px;
        height: 28px;
        border-radius: 6px;
        border: none;
        background: transparent;
        color: var(--text-tertiary);
        cursor: pointer;
        transition: all 0.15s ease;
    }

    .toc-fab__close:hover {
        background: var(--bg-glass);
        color: var(--text-primary);
    }

    .toc-fab__list {
        padding: 0.5rem 0;
        margin: 0;
        list-style: none;
    }

    .toc-fab__item {
        margin: 0;
    }

    .toc-fab__item--l2 {
        padding-left: 0.75rem;
    }

    .toc-fab__link {
        display: block;
        padding: 0.45rem 1.25rem;
        font-size: 0.82rem;
        color: var(--text-secondary);
        line-height: 1.4;
        transition: all 0.15s ease;
        border-left: 2px solid transparent;
    }

    .toc-fab__item--l1 .toc-fab__link {
        font-weight: 600;
        color: var(--text-primary);
        font-size: 0.85rem;
    }

    .toc-fab__link:hover {
        color: var(--text-accent);
        background: var(--bg-glass);
        border-left-color: var(--text-accent);
    }

    /* ── Floating chapter progress indicator ── */
    .chapter-progress {
        position: fixed;
        bottom: 1.25rem;
        left: 50%;
        transform: translateX(-50%) translateY(20px);
        z-index: 89;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.3s ease, transform 0.3s ease;
    }

    .chapter-progress.visible {
        opacity: 1;
        transform: translateX(-50%) translateY(0);
        pointer-events: auto;
    }

    .chapter-progress__inner {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 0.6rem 1.5rem;
        border-radius: 50px;
        background: var(--bg-primary);
        border: 1px solid var(--border-glass);
        box-shadow: var(--shadow-lg);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
    }

    .chapter-progress__bar {
        width: 100px;
        height: 4px;
        border-radius: 2px;
        background: var(--bg-glass);
        overflow: hidden;
    }

    .chapter-progress__fill {
        height: 100%;
        border-radius: 2px;
        background: var(--gradient-accent);
        background-size: 200% 200%;
        animation: gradient-shift 4s ease infinite;
        width: 0%;
        transition: width 0.4s ease;
    }

    .chapter-progress__info {
        display: flex;
        align-items: center;
        gap: 0.35rem;
        font-size: 0.8rem;
        white-space: nowrap;
    }

    .chapter-progress__current {
        font-weight: 800;
        font-size: 0.95rem;
        color: var(--text-accent);
        font-family: "JetBrains Mono", monospace;
        min-width: 1.2em;
        text-align: center;
    }

    .chapter-progress__sep {
        color: var(--text-tertiary);
        font-weight: 400;
    }

    .chapter-progress__total {
        font-weight: 700;
        color: var(--text-primary);
        font-family: "JetBrains Mono", monospace;
    }

    .chapter-progress__label {
        color: var(--text-tertiary);
        font-weight: 500;
    }

    /* ── Responsive ── */
    @media (max-width: 768px) {
        .book-detail__hero {
            grid-template-columns: 1fr;
            gap: 1.5rem;
        }

        .book-detail__cover-wrap {
            max-width: 200px;
            margin: 0 auto;
        }

        .book-detail__top {
            flex-direction: column;
            gap: 1rem;
            align-items: flex-start;
        }

        .toc-fab {
            bottom: 5rem;
            right: 1rem;
        }

        .toc-fab__panel {
            width: calc(100vw - 2rem);
            max-height: 60vh;
        }

        .toc-fab__label {
            display: none;
        }

        .toc-fab__toggle {
            width: 48px;
            height: 48px;
            padding: 0;
            border-radius: 50%;
            justify-content: center;
        }

        .chapter-progress__bar {
            width: 60px;
        }
    }
</style>
