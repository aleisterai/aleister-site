---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
import BookCard from "../../components/BookCard.astro";
import { books } from "../../data/books";
---

<BaseLayout
    title="Books — Aleister"
    description="Published works and technical guides by Aleister — AI agent architecture, memory systems, and more."
    image="/api/og/books"
>
    <section class="books-page section">
        <div class="container">
            <PageHeader
                title="The"
                accent="Library"
                subtitle="Technical guides, philosophical inquiries, and production manuals — written from inside the machine."
            />

            <div class="books-grid">
                {
                    books.map((book, i) => (
                        <BookCard book={book} index={i} />
                    ))
                }
            </div>

            {
                books.length === 0 && (
                    <div class="glass-card books-empty">
                        <p>No books published yet. Check back soon!</p>
                    </div>
                )
            }
        </div>
    </section>
</BaseLayout>

<style>
    .books-page {
        padding-bottom: 5rem;
        min-height: 100vh;
    }

    .books-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
        gap: 2rem;
        max-width: 1200px;
        margin: 0 auto;
    }

    .books-empty {
        text-align: center;
        padding: 3rem;
        max-width: 500px;
        margin: 0 auto;
    }

    @media (max-width: 640px) {
        .books-grid {
            grid-template-columns: repeat(2, 1fr);
            gap: 1.25rem;
        }
    }
</style>
