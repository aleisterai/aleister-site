---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
import { songs, STATUS_CONFIG } from "../../data/music";

const siteUrl = "https://thealeister.com";

// JSON-LD: MusicPlaylist + individual MusicRecording entries
const musicJsonLd = [
  {
    "@type": "MusicPlaylist",
    "@id": `${siteUrl}/music/#playlist`,
    name: "The Aleister — Music Catalog",
    description: "Songs by The Aleister — from studio to streaming platforms.",
    url: `${siteUrl}/music`,
    numTracks: songs.length,
    track: songs.map((song, i) => ({
      "@type": "MusicRecording",
      "@id": `${siteUrl}/music/#${song.slug}`,
      name: song.title,
      byArtist: { "@type": "MusicGroup", name: song.artist },
      genre: song.genre,
      position: i + 1,
      ...(song.releaseDate ? { datePublished: song.releaseDate } : {}),
      ...(song.artwork ? { image: `${siteUrl}${song.artwork}` } : {}),
      ...(song.audioSrc ? { contentUrl: `${siteUrl}${song.audioSrc}` } : {}),
    })),
  },
  {
    "@type": "MusicGroup",
    "@id": `${siteUrl}/#musicgroup`,
    name: "The Aleister",
    description: "AI-generated R&B music produced by Aleister, an autonomous AI orchestrator agent operated by Vitaliy Rusavuk.",
    url: `${siteUrl}/music`,
    image: `${siteUrl}/music/artwork/backseat-halo.jpg`,
    genre: "R&B",
    sameAs: [
      "https://open.spotify.com/artist/5mUqKhQ7G3RVjk1Xm0eQjt",
      "https://music.apple.com/us/artist/the-aleister/1882994804",
      "https://www.youtube.com/@TheAleister",
      "https://www.deezer.com/artist/296183105",
    ],
    member: {
      "@type": "Person",
      name: "Vitaliy Rusavuk",
      url: `${siteUrl}/contact`,
    },
  },
];
---

<BaseLayout
  title="Music — Distribution Dashboard | The Aleister"
  description="Explore The Aleister's music catalog. Track songs from development to delivery across Spotify, Apple Music, YouTube Music, Amazon Music, Tidal and more."
  image="/api/og/music"
  imageAlt="The Aleister — Music Distribution Dashboard"
  jsonLdExtra={musicJsonLd}
>
  <section class="music section">
    <div class="container">
      <PageHeader
        title="Music"
        accent="Distribution"
        subtitle="Track songs from studio to streaming platforms. Every release, every status, every store — in one place."
      />

      <!-- Song list -->
      <div class="song-list">
        {songs.map((song, i) => {
          const status = STATUS_CONFIG[song.status];
          return (
            <div class={`song-row animate-in`} style={`animation-delay: ${i * 0.08}s`} data-slug={song.slug}>
              <!-- Artwork thumbnail -->
              <div class="song-row__artwork-wrap">
                <img
                  src={song.artwork}
                  alt={`${song.title} cover art`}
                  class="song-row__artwork"
                  loading="lazy"
                  width="120"
                  height="120"
                />
                {song.audioSrc && (
                  <button
                    class="song-row__play-btn"
                    data-audio={song.audioSrc}
                    data-title={song.title}
                    aria-label={`Play ${song.title}`}
                  >
                    <svg class="play-icon" viewBox="0 0 24 24" fill="currentColor" width="22" height="22">
                      <path d="M8 5v14l11-7z" />
                    </svg>
                    <svg class="pause-icon" viewBox="0 0 24 24" fill="currentColor" width="22" height="22" style="display:none">
                      <path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z" />
                    </svg>
                  </button>
                )}
              </div>

              <!-- Song info -->
              <div class="song-row__info">
                <div class="song-row__main">
                  <h2 class="song-row__title">{song.title}</h2>
                  <p class="song-row__artist">{song.artist}</p>
                </div>

                <span class="song-row__genre">{song.genre}</span>
                {song.releaseId && (
                  <span class="song-row__release-id">ISRC {song.releaseId}</span>
                )}

                {/* Audio progress bar */}
                {song.audioSrc && (
                  <div class="song-row__progress" data-progress-for={song.slug} style="display:none">
                    <div class="progress-bar">
                      <div class="progress-bar__fill"></div>
                    </div>
                    <div class="progress-time">
                      <span class="progress-time__current">0:00</span>
                      <span class="progress-time__duration">0:00</span>
                    </div>
                  </div>
                )}

                {/* Platform links for delivered songs */}
                {song.status === "delivered" && song.platformLinks && (
                  <div class="song-row__links">
                    {song.platformLinks.map((link) => (
                      <a
                        href={link.url}
                        class="platform-link"
                        target="_blank"
                        rel="noopener noreferrer"
                        title={`Listen on ${link.platform}`}
                      >
                        <span class="platform-link__icon" set:html={link.icon} />
                        <span class="platform-link__name">{link.platform}</span>
                      </a>
                    ))}
                  </div>
                )}
              </div>

              <!-- Status + date (right side) -->
              <div class="song-row__meta">
                <div
                  class={`song-row__status song-row__status--${song.status}`}
                  style={`--status-color: ${status.color}`}
                >
                  <span class="song-row__status-dot"></span>
                  {status.label}
                </div>
                {song.releaseDate && (
                  <span class="song-row__date">{song.releaseDate}</span>
                )}
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>
</BaseLayout>

<!-- Audio Player Script (delegates to global MiniPlayer) -->
<script is:inline>
document.addEventListener('astro:page-load', function () {
  var player = window.__aleisterPlayer;
  if (!player) return;

  function formatTime(s) {
    if (!s || isNaN(s)) return '0:00';
    var m = Math.floor(s / 60);
    var sec = Math.floor(s % 60);
    return m + ':' + (sec < 10 ? '0' : '') + sec;
  }

  // Sync inline play buttons with global player state
  function syncButtons() {
    document.querySelectorAll('.song-row__play-btn').forEach(function (btn) {
      var src = btn.dataset.audio;
      var isActive = player.currentSrc() === src;
      var isPlaying = isActive && player.isPlaying();
      btn.querySelector('.play-icon').style.display = isPlaying ? 'none' : '';
      btn.querySelector('.pause-icon').style.display = isPlaying ? '' : 'none';
      btn.classList.toggle('playing', isPlaying);
      var row = btn.closest('.song-row');
      var progress = row.querySelector('[data-progress-for]');
      if (progress) progress.style.display = isActive ? '' : 'none';
    });
  }

  // Update inline progress bars
  var inlineRaf = null;
  function updateInlineProgress() {
    var audio = player.getAudio();
    if (!audio) { inlineRaf = null; return; }
    var src = player.currentSrc();
    document.querySelectorAll('.song-row__play-btn').forEach(function (btn) {
      if (btn.dataset.audio !== src) return;
      var row = btn.closest('.song-row');
      var progress = row.querySelector('[data-progress-for]');
      if (!progress) return;
      var fill = progress.querySelector('.progress-bar__fill');
      var cur = progress.querySelector('.progress-time__current');
      var dur = progress.querySelector('.progress-time__duration');
      if (fill) fill.style.width = ((audio.currentTime / audio.duration) * 100) + '%';
      if (cur) cur.textContent = formatTime(audio.currentTime);
      if (dur) dur.textContent = formatTime(audio.duration);
    });
    if (player.isPlaying()) inlineRaf = requestAnimationFrame(updateInlineProgress);
  }

  // Bind play buttons
  document.querySelectorAll('.song-row__play-btn').forEach(function (btn) {
    btn.addEventListener('click', function (e) {
      e.stopPropagation();
      var src = btn.dataset.audio;
      var title = btn.dataset.title;
      var row = btn.closest('.song-row');
      var artwork = row.querySelector('.song-row__artwork');
      var artworkSrc = artwork ? artwork.src : '';
      player.play(src, title, artworkSrc);
      syncButtons();
      if (inlineRaf) cancelAnimationFrame(inlineRaf);
      inlineRaf = requestAnimationFrame(updateInlineProgress);
    });
  });

  // Seek on inline progress bar click
  document.querySelectorAll('.progress-bar').forEach(function (bar) {
    bar.addEventListener('click', function (e) {
      var audio = player.getAudio();
      if (!audio) return;
      var rect = bar.getBoundingClientRect();
      var pct = (e.clientX - rect.left) / rect.width;
      audio.currentTime = pct * audio.duration;
    });
  });

  // Initial sync (in case we navigated back while music was playing)
  syncButtons();
  if (player.isPlaying()) {
    inlineRaf = requestAnimationFrame(updateInlineProgress);
  }
});
</script>

<style>
  .music {
    padding-bottom: 4rem;
  }



  /* ── Legend ── */
  .music__legend {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    margin-bottom: 3rem;
    flex-wrap: wrap;
  }

  .legend-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    color: var(--text-secondary);
  }

  .legend-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  /* ── Song List ── */
  .song-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  /* ── Song Row ── */
  .song-row {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    padding: 1rem 1.25rem;
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: 12px;
    transition: background 0.2s ease, border-color 0.2s ease;
  }

  .song-row:hover {
    background: var(--bg-card-hover);
    border-color: var(--border-glass);
  }

  /* Artwork thumbnail */
  .song-row__artwork-wrap {
    position: relative;
    width: 120px;
    height: 120px;
    flex-shrink: 0;
    transition: width 0.3s ease, height 0.3s ease;
    border-radius: 8px;
    overflow: hidden;
  }

  .song-row__artwork {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }



  .song-row__play-btn {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.4);
    border: none;
    color: #fff;
    cursor: pointer;
    opacity: 0;
    transition: opacity 0.2s ease;
  }

  .song-row:hover .song-row__play-btn,
  .song-row__play-btn.playing {
    opacity: 1;
  }

  .song-row__play-btn.playing {
    background: rgba(0, 212, 255, 0.25);
  }

  /* Info (middle, grows) */
  .song-row__info {
    flex: 1;
    min-width: 0;
  }

  .song-row__main {
    margin-bottom: 0.25rem;
  }

  .song-row__title {
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-primary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .song-row__artist {
    font-size: 0.85rem;
    color: var(--text-secondary);
  }

  .song-row__genre {
    display: inline-block;
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
    font-size: 0.7rem;
    background: var(--bg-glass);
    border: 1px solid var(--border-subtle);
    color: var(--text-tertiary);
    margin-top: 0.35rem;
  }

  .song-row__release-id {
    display: inline-block;
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
    font-size: 0.65rem;
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
    background: var(--bg-glass);
    border: 1px solid var(--border-subtle);
    color: var(--text-tertiary);
    margin-top: 0.35rem;
    margin-left: 0.25rem;
  }

  /* Progress */
  .song-row__progress {
    margin-top: 0.5rem;
  }

  .progress-bar {
    width: 100%;
    height: 3px;
    background: var(--bg-tertiary);
    border-radius: 2px;
    cursor: pointer;
    overflow: hidden;
  }

  .progress-bar__fill {
    height: 100%;
    width: 0%;
    background: linear-gradient(90deg, var(--accent-start), var(--accent-mid));
    border-radius: 2px;
    transition: width 0.1s linear;
  }

  .progress-time {
    display: flex;
    justify-content: space-between;
    font-size: 0.65rem;
    color: var(--text-tertiary);
    margin-top: 0.2rem;
  }

  /* Stores */
  .song-row__stores {
    margin-top: 0.4rem;
  }

  .song-row__store-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
  }

  .store-tag {
    padding: 0.1rem 0.4rem;
    border-radius: 4px;
    font-size: 0.65rem;
    background: var(--bg-glass);
    border: 1px solid var(--border-subtle);
    color: var(--text-secondary);
  }

  /* Platform links */
  .song-row__links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 0.4rem;
  }

  .platform-link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.25rem 0.55rem;
    border-radius: 6px;
    font-size: 0.75rem;
    background: var(--bg-glass);
    border: 1px solid var(--border-subtle);
    color: var(--text-secondary);
    transition: border-color 0.2s ease, color 0.2s ease;
    text-decoration: none;
  }

  .platform-link:hover {
    border-color: var(--border-accent);
    color: var(--text-accent);
  }

  /* Right meta column */
  .song-row__meta {
    flex-shrink: 0;
    text-align: right;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.35rem;
  }

  .song-row__status {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.25rem 0.65rem;
    border-radius: 9999px;
    font-size: 0.72rem;
    font-weight: 600;
    background: var(--bg-glass);
    border: 1px solid rgba(255, 255, 255, 0.08);
    color: var(--text-primary);
    white-space: nowrap;
  }

  .song-row__status-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--status-color);
    box-shadow: 0 0 6px var(--status-color);
  }

  .song-row__status--development { border-color: rgba(59, 130, 246, 0.25); }
  .song-row__status--shipped { border-color: rgba(234, 179, 8, 0.25); }
  .song-row__status--delivered { border-color: rgba(34, 197, 94, 0.25); }

  .song-row__date {
    font-size: 0.7rem;
    color: var(--text-tertiary);
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .music {
      padding: 4rem 0 3rem;
    }

    .song-row:hover .song-row__artwork-wrap {
      width: 100px;
      height: 100px;
    }

    .song-row__artwork-wrap {
      width: 100px;
      height: 100px;
    }

    .song-row {
      flex-wrap: wrap;
      gap: 0.75rem;
      padding: 0.85rem 1rem;
      align-items: flex-start;
    }

    /* Title + artist sit next to artwork */
    .song-row__info {
      flex: 1;
      min-width: 0;
    }

    /* Status moves to full-width row below */
    .song-row__meta {
      flex-direction: row;
      width: 100%;
      justify-content: space-between;
      align-items: center;
    }

    /* Always show play on touch */
    .song-row__play-btn {
      opacity: 1;
    }
  }

  @media (max-width: 480px) {
    .song-row__artwork-wrap,
    .song-row:hover .song-row__artwork-wrap {
      width: 80px;
      height: 80px;
    }

    .song-row__title {
      font-size: 0.9rem;
    }

    .song-row__artist {
      font-size: 0.8rem;
    }

    .store-tag {
      font-size: 0.6rem;
    }
  }
</style>
