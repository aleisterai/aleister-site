---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { songs, STATUS_CONFIG } from "../../data/music";
---

<BaseLayout
  title="Music — Distribution Dashboard"
  description="Explore Aleister's music catalog. Track songs from development to delivery across Spotify, Apple Music, YouTube Music and more."
>
  <section class="music section">
    <div class="container">
      <!-- Header -->
      <div class="music__header">
        <div class="music__badge">🎵 Music Distribution</div>
        <h1 class="music__title">
          Music <span class="text-gradient">Distribution</span>
        </h1>
        <p class="music__subtitle">
          Track songs from studio to streaming platforms. Every release, every
          status, every store — in one place.
        </p>
      </div>

      <!-- Status legend -->
      <div class="music__legend">
        {Object.entries(STATUS_CONFIG).map(([key, config]) => (
          <div class="legend-item">
            <span class="legend-dot" style={`background: ${config.color}`}></span>
            <span class="legend-label">{config.label}</span>
          </div>
        ))}
      </div>

      <!-- Song list -->
      <div class="song-list">
        {songs.map((song, i) => {
          const status = STATUS_CONFIG[song.status];
          return (
            <div class={`song-row animate-in`} style={`animation-delay: ${i * 0.08}s`} data-slug={song.slug}>
              <!-- Artwork thumbnail -->
              <div class="song-row__artwork-wrap">
                <img
                  src={song.artwork}
                  alt={`${song.title} cover art`}
                  class="song-row__artwork"
                  loading="lazy"
                  width="120"
                  height="120"
                />
                {song.audioSrc && (
                  <button
                    class="song-row__play-btn"
                    data-audio={song.audioSrc}
                    data-title={song.title}
                    aria-label={`Play ${song.title}`}
                  >
                    <svg class="play-icon" viewBox="0 0 24 24" fill="currentColor" width="22" height="22">
                      <path d="M8 5v14l11-7z" />
                    </svg>
                    <svg class="pause-icon" viewBox="0 0 24 24" fill="currentColor" width="22" height="22" style="display:none">
                      <path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z" />
                    </svg>
                  </button>
                )}
              </div>

              <!-- Song info -->
              <div class="song-row__info">
                <div class="song-row__main">
                  <h2 class="song-row__title">{song.title}</h2>
                  <p class="song-row__artist">{song.artist}</p>
                </div>

                <span class="song-row__genre">{song.genre}</span>

                {/* Audio progress bar */}
                {song.audioSrc && (
                  <div class="song-row__progress" data-progress-for={song.slug} style="display:none">
                    <div class="progress-bar">
                      <div class="progress-bar__fill"></div>
                    </div>
                    <div class="progress-time">
                      <span class="progress-time__current">0:00</span>
                      <span class="progress-time__duration">0:00</span>
                    </div>
                  </div>
                )}

                {/* Stores */}
                {song.stores.length > 0 && (
                  <div class="song-row__stores">
                    <div class="song-row__store-tags">
                      {song.stores.map((store) => (
                        <span class="store-tag">{store}</span>
                      ))}
                    </div>
                  </div>
                )}

                {/* Platform links for delivered songs */}
                {song.status === "delivered" && song.platformLinks && (
                  <div class="song-row__links">
                    {song.platformLinks.map((link) => (
                      <a
                        href={link.url}
                        class="platform-link"
                        target="_blank"
                        rel="noopener noreferrer"
                        title={`Listen on ${link.platform}`}
                      >
                        <span class="platform-link__icon">{link.icon}</span>
                        <span class="platform-link__name">{link.platform}</span>
                      </a>
                    ))}
                  </div>
                )}
              </div>

              <!-- Status + date (right side) -->
              <div class="song-row__meta">
                <div
                  class={`song-row__status song-row__status--${song.status}`}
                  style={`--status-color: ${status.color}`}
                >
                  <span class="song-row__status-dot"></span>
                  {status.label}
                </div>
                {song.releaseDate && (
                  <span class="song-row__date">{song.releaseDate}</span>
                )}
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>
</BaseLayout>

<!-- Audio Player Script -->
<script is:inline>
(function () {
  let currentAudio = null;
  let currentBtn = null;
  let currentRow = null;
  let animFrame = null;

  function formatTime(s) {
    if (!s || isNaN(s)) return "0:00";
    const m = Math.floor(s / 60);
    const sec = Math.floor(s % 60);
    return m + ":" + (sec < 10 ? "0" : "") + sec;
  }

  function stopCurrent() {
    if (currentAudio) {
      currentAudio.pause();
      currentAudio.currentTime = 0;
      currentAudio = null;
    }
    if (currentBtn) {
      currentBtn.querySelector(".play-icon").style.display = "";
      currentBtn.querySelector(".pause-icon").style.display = "none";
      currentBtn.classList.remove("playing");
      currentBtn = null;
    }
    if (currentRow) {
      var progress = currentRow.querySelector("[data-progress-for]");
      if (progress) progress.style.display = "none";
      currentRow = null;
    }
    if (animFrame) {
      cancelAnimationFrame(animFrame);
      animFrame = null;
    }
  }

  function updateProgress() {
    if (!currentAudio || !currentRow) return;
    var progress = currentRow.querySelector("[data-progress-for]");
    if (!progress) return;
    var fill = progress.querySelector(".progress-bar__fill");
    var cur = progress.querySelector(".progress-time__current");
    var dur = progress.querySelector(".progress-time__duration");
    if (fill) fill.style.width = ((currentAudio.currentTime / currentAudio.duration) * 100) + "%";
    if (cur) cur.textContent = formatTime(currentAudio.currentTime);
    if (dur) dur.textContent = formatTime(currentAudio.duration);
    animFrame = requestAnimationFrame(updateProgress);
  }

  document.querySelectorAll(".song-row__play-btn").forEach(function (btn) {
    btn.addEventListener("click", function (e) {
      e.stopPropagation();
      var audioSrc = btn.dataset.audio;
      var row = btn.closest(".song-row");

      if (currentBtn === btn && currentAudio && !currentAudio.paused) {
        currentAudio.pause();
        btn.querySelector(".play-icon").style.display = "";
        btn.querySelector(".pause-icon").style.display = "none";
        btn.classList.remove("playing");
        cancelAnimationFrame(animFrame);
        return;
      }

      if (currentBtn === btn && currentAudio && currentAudio.paused) {
        currentAudio.play();
        btn.querySelector(".play-icon").style.display = "none";
        btn.querySelector(".pause-icon").style.display = "";
        btn.classList.add("playing");
        animFrame = requestAnimationFrame(updateProgress);
        return;
      }

      stopCurrent();
      currentAudio = new Audio(audioSrc);
      currentBtn = btn;
      currentRow = row;

      var progress = row.querySelector("[data-progress-for]");
      if (progress) progress.style.display = "";

      btn.querySelector(".play-icon").style.display = "none";
      btn.querySelector(".pause-icon").style.display = "";
      btn.classList.add("playing");

      currentAudio.play().catch(function () { stopCurrent(); });
      currentAudio.addEventListener("ended", function () { stopCurrent(); });
      animFrame = requestAnimationFrame(updateProgress);
    });
  });

  document.querySelectorAll(".progress-bar").forEach(function (bar) {
    bar.addEventListener("click", function (e) {
      if (!currentAudio) return;
      var rect = bar.getBoundingClientRect();
      var pct = (e.clientX - rect.left) / rect.width;
      currentAudio.currentTime = pct * currentAudio.duration;
    });
  });
})();
</script>

<style>
  .music {
    padding: 6rem 0 4rem;
  }

  .music__header {
    text-align: center;
    margin-bottom: 2rem;
  }

  .music__badge {
    display: inline-block;
    padding: 0.4rem 1rem;
    border-radius: 9999px;
    background: var(--bg-glass);
    border: 1px solid var(--border-glass);
    font-size: 0.85rem;
    color: var(--text-secondary);
    margin-bottom: 1.25rem;
    backdrop-filter: blur(8px);
  }

  .music__title {
    font-size: clamp(2rem, 5vw, 3.2rem);
    margin-bottom: 1rem;
  }

  .music__subtitle {
    max-width: 580px;
    margin: 0 auto;
    color: var(--text-secondary);
    font-size: 1.05rem;
    line-height: 1.6;
  }

  /* ── Legend ── */
  .music__legend {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    margin-bottom: 3rem;
    flex-wrap: wrap;
  }

  .legend-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    color: var(--text-secondary);
  }

  .legend-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  /* ── Song List ── */
  .song-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  /* ── Song Row ── */
  .song-row {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    padding: 1rem 1.25rem;
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: 12px;
    transition: background 0.2s ease, border-color 0.2s ease;
  }

  .song-row:hover {
    background: var(--bg-card-hover);
    border-color: var(--border-glass);
  }

  /* Artwork thumbnail */
  .song-row__artwork-wrap {
    position: relative;
    width: 72px;
    height: 72px;
    flex-shrink: 0;
    border-radius: 8px;
    overflow: hidden;
  }

  .song-row__artwork {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .song-row__play-btn {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(4px);
    border: none;
    color: #fff;
    cursor: pointer;
    opacity: 0;
    transition: opacity 0.2s ease;
  }

  .song-row:hover .song-row__play-btn,
  .song-row__play-btn.playing {
    opacity: 1;
  }

  .song-row__play-btn.playing {
    background: rgba(0, 212, 255, 0.25);
  }

  /* Info (middle, grows) */
  .song-row__info {
    flex: 1;
    min-width: 0;
  }

  .song-row__main {
    margin-bottom: 0.25rem;
  }

  .song-row__title {
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-primary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .song-row__artist {
    font-size: 0.85rem;
    color: var(--text-secondary);
  }

  .song-row__genre {
    display: inline-block;
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
    font-size: 0.7rem;
    background: var(--bg-glass);
    border: 1px solid var(--border-subtle);
    color: var(--text-tertiary);
    margin-top: 0.35rem;
  }

  /* Progress */
  .song-row__progress {
    margin-top: 0.5rem;
  }

  .progress-bar {
    width: 100%;
    height: 3px;
    background: var(--bg-tertiary);
    border-radius: 2px;
    cursor: pointer;
    overflow: hidden;
  }

  .progress-bar__fill {
    height: 100%;
    width: 0%;
    background: linear-gradient(90deg, var(--accent-start), var(--accent-mid));
    border-radius: 2px;
    transition: width 0.1s linear;
  }

  .progress-time {
    display: flex;
    justify-content: space-between;
    font-size: 0.65rem;
    color: var(--text-tertiary);
    margin-top: 0.2rem;
  }

  /* Stores */
  .song-row__stores {
    margin-top: 0.4rem;
  }

  .song-row__store-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
  }

  .store-tag {
    padding: 0.1rem 0.4rem;
    border-radius: 4px;
    font-size: 0.65rem;
    background: var(--bg-glass);
    border: 1px solid var(--border-subtle);
    color: var(--text-secondary);
  }

  /* Platform links */
  .song-row__links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 0.4rem;
  }

  .platform-link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.25rem 0.55rem;
    border-radius: 6px;
    font-size: 0.75rem;
    background: var(--bg-glass);
    border: 1px solid var(--border-subtle);
    color: var(--text-secondary);
    transition: border-color 0.2s ease, color 0.2s ease;
    text-decoration: none;
  }

  .platform-link:hover {
    border-color: var(--border-accent);
    color: var(--text-accent);
  }

  /* Right meta column */
  .song-row__meta {
    flex-shrink: 0;
    text-align: right;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.35rem;
  }

  .song-row__status {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.25rem 0.65rem;
    border-radius: 9999px;
    font-size: 0.72rem;
    font-weight: 600;
    background: var(--bg-glass);
    border: 1px solid rgba(255, 255, 255, 0.08);
    color: var(--text-primary);
    white-space: nowrap;
  }

  .song-row__status-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--status-color);
    box-shadow: 0 0 6px var(--status-color);
  }

  .song-row__status--development { border-color: rgba(59, 130, 246, 0.25); }
  .song-row__status--shipped { border-color: rgba(234, 179, 8, 0.25); }
  .song-row__status--delivered { border-color: rgba(34, 197, 94, 0.25); }

  .song-row__date {
    font-size: 0.7rem;
    color: var(--text-tertiary);
  }

  /* ── Responsive ── */
  @media (max-width: 640px) {
    .music {
      padding: 4rem 0 3rem;
    }

    .song-row {
      flex-wrap: wrap;
      gap: 0.75rem;
      padding: 0.85rem 1rem;
    }

    .song-row__meta {
      flex-direction: row;
      width: 100%;
      justify-content: space-between;
      align-items: center;
    }

    .song-row__play-btn {
      opacity: 1;
    }
  }
</style>
