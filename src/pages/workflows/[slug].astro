---
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
    workflows,
    getWorkflowBySlug,
    type Workflow,
    type WorkflowStep,
} from "../../data/workflows";

const { slug } = Astro.params;
const workflow = getWorkflowBySlug(slug ?? "");

if (!workflow) {
    return Astro.redirect("/workflows");
}

// JSON-LD HowTo schema
const howToJsonLd = {
    "@type": "HowTo",
    name: workflow.title,
    description: workflow.description,
    step: workflow.steps.map((s, i) => ({
        "@type": "HowToStep",
        position: i + 1,
        name: s.stepName,
        text: s.description,
    })),
};

function avatarSrc(step: WorkflowStep): string {
    if (step.agentType === "aleister") return "/avatars/hero-avatar.gif";
    if (step.agentType === "human") return "";
    return `/avatars/${step.agentName}.png`;
}
---

<BaseLayout
    title={`${workflow.title} — Aleister Workflows`}
    description={workflow.description}
    jsonLdExtra={[howToJsonLd]}
>
    <div class="pipeline-page">
        <div class="container">
            <!-- Breadcrumb -->
            <nav class="breadcrumb">
                <a href="/workflows">Workflows</a>
                <span>/</span>
                <span>{workflow.shortTitle}</span>
            </nav>

            <!-- Hero -->
            <div class="hero">
                <div class="hero__badge">{workflow.badge}</div>
                <h1 class="hero__title">{workflow.title}</h1>
                <p class="hero__desc">{workflow.description}</p>
            </div>

            <!-- Pipeline Steps -->
            <div class="pipeline glass-card">
                {
                    workflow.steps.map((step, i) => (
                        <>
                            {i > 0 && <div class="pipeline__arrow">↓</div>}
                            <div
                                class={`pipeline__step ${
                                    step.agentType === "human"
                                        ? "pipeline__step--human"
                                        : ""
                                } ${
                                    step.agentType === "aleister"
                                        ? "pipeline__step--aleister"
                                        : ""
                                }`}
                            >
                                {step.agentType === "multi" && step.avatars ? (
                                    <div class="pipeline__icon-stack">
                                        {step.avatars.map((av) => (
                                            <div class="pipeline__icon">
                                                <img
                                                    src={av}
                                                    alt=""
                                                    width="40"
                                                    height="40"
                                                />
                                            </div>
                                        ))}
                                    </div>
                                ) : step.agentType === "human" ? (
                                    <div class="pipeline__icon pipeline__icon--human">
                                        <span class="pipeline__icon-letter">
                                            F&B
                                        </span>
                                    </div>
                                ) : (
                                    <div
                                        class={`pipeline__icon pipeline__icon--${
                                            step.agentType === "aleister"
                                                ? "aleister"
                                                : "agent"
                                        }`}
                                    >
                                        <img
                                            src={avatarSrc(step)}
                                            alt={step.agentName}
                                            width="32"
                                            height="32"
                                        />
                                    </div>
                                )}
                                <div class="pipeline__body">
                                    <div class="pipeline__agent">
                                        {step.agentType === "human" ||
                                        step.agentType === "aleister" ? (
                                            <strong>{step.agentLabel}</strong>
                                        ) : (
                                            <Fragment
                                                set:html={
                                                    step.agentLabel.replace(
                                                        /^(.*?) · /,
                                                        "$1 · <strong>"
                                                    ) +
                                                    (step.agentLabel.includes(
                                                        " · "
                                                    )
                                                        ? "</strong>"
                                                        : "")
                                                }
                                            />
                                        )}
                                    </div>
                                    <h3 class="pipeline__name">
                                        {step.stepName}
                                    </h3>
                                    <p class="pipeline__desc">
                                        {step.description}
                                    </p>
                                    <div class="pipeline__outputs">
                                        {step.outputs.map((o) => (
                                            <span class="pipeline__output">
                                                {o}
                                            </span>
                                        ))}
                                    </div>
                                </div>
                            </div>
                        </>
                    ))
                }
            </div>

            <!-- Key Principles -->
            <div class="principles glass-card">
                <h2 class="principles__title">Key Principles</h2>
                <div class="principles-grid">
                    {
                        workflow.principles.map((p) => (
                            <div class="principle">
                                <span class="principle__icon">{p.icon}</span>
                                <div>
                                    <strong>{p.title}</strong>
                                    <p>{p.description}</p>
                                </div>
                            </div>
                        ))
                    }
                </div>
            </div>

            <!-- CTA -->
            <div class="cta">
                <p class="cta__text">{workflow.cta.text}</p>
                <a href={workflow.cta.href} class="cta__btn"
                    >Get the Aleister Persona →</a
                >
            </div>
        </div>
    </div>
</BaseLayout>

<style>
    .pipeline-page {
        padding: 3rem 0 6rem;
    }

    .container {
        max-width: 900px;
        margin: 0 auto;
        padding: 0 1.5rem;
    }

    /* Breadcrumb */
    .breadcrumb {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.82rem;
        color: var(--text-tertiary);
        margin-bottom: 2rem;
    }

    .breadcrumb a {
        color: var(--text-tertiary);
        text-decoration: none;
        transition: color 0.15s;
    }

    .breadcrumb a:hover {
        color: var(--text-accent);
    }

    /* Hero */
    .hero {
        margin-bottom: 2.5rem;
    }

    .hero__badge {
        display: inline-block;
        padding: 0.2rem 0.75rem;
        border-radius: 6px;
        font-size: 0.72rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.07em;
        background: color-mix(in srgb, var(--text-accent) 15%, transparent);
        color: var(--text-accent);
        border: 1px solid
            color-mix(in srgb, var(--text-accent) 30%, transparent);
        margin-bottom: 1rem;
    }

    .hero__title {
        font-size: clamp(1.75rem, 4vw, 2.75rem);
        font-weight: 800;
        margin-bottom: 0.75rem;
        line-height: 1.15;
    }

    .hero__desc {
        font-size: 1rem;
        color: var(--text-secondary);
        max-width: 640px;
        line-height: 1.7;
        margin: 0;
    }

    /* Glass card */
    .glass-card {
        background: var(--bg-glass);
        border: 1px solid var(--border-glass);
        border-radius: 16px;
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
    }

    /* Pipeline */
    .pipeline {
        padding: 2rem;
        margin-bottom: 1.5rem;
    }

    .pipeline__step {
        display: flex;
        gap: 1.25rem;
        padding: 1.5rem 1.5rem 1.5rem 0;
        border-left: 2px solid var(--border-subtle);
        margin-left: 1.5rem;
        position: relative;
    }

    .pipeline__step::before {
        content: "";
        position: absolute;
        left: -5px;
        top: 1.75rem;
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: var(--text-accent);
    }

    .pipeline__step--human {
        background: color-mix(in srgb, var(--text-accent) 4%, transparent);
        border-left-color: var(--text-accent);
        border-radius: 0 8px 8px 0;
    }

    .pipeline__step--aleister {
        background: color-mix(in srgb, #a78bfa 4%, transparent);
        border-left-color: #a78bfa;
        border-radius: 0 8px 8px 0;
    }

    .pipeline__icon {
        flex-shrink: 0;
        width: 2.5rem;
        height: 2.5rem;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.25rem;
        background: var(--bg-glass);
        border: 1px solid var(--border-glass);
        margin-left: -1.25rem;
        overflow: hidden;
    }

    .pipeline__icon img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .pipeline__icon--human {
        background: color-mix(in srgb, var(--text-accent) 15%, transparent);
        border-color: color-mix(in srgb, var(--text-accent) 40%, transparent);
    }

    .pipeline__icon--aleister {
        background: color-mix(in srgb, #a78bfa 15%, transparent);
        border-color: color-mix(in srgb, #a78bfa 40%, transparent);
    }

    .pipeline__icon--agent {
        background: var(--bg-glass);
        border-color: var(--border-glass);
    }

    .pipeline__icon-letter {
        font-size: 0.68rem;
        font-weight: 900;
        color: var(--text-accent);
        font-family: "JetBrains Mono", monospace;
        line-height: 1;
        letter-spacing: -0.04em;
        display: flex;
        align-items: center;
        justify-content: center;
        width: 100%;
        height: 100%;
    }

    .pipeline__icon-stack {
        display: flex;
        flex-direction: column;
        align-items: center;
        flex-shrink: 0;
        margin-left: -1.25rem;
        gap: 0;
        position: relative;
    }

    .pipeline__icon-stack .pipeline__icon {
        margin-left: 0;
    }

    .pipeline__icon-stack .pipeline__icon:nth-child(2) {
        margin-top: -8px;
        z-index: 2;
    }

    .pipeline__icon-stack .pipeline__icon:nth-child(1) {
        z-index: 1;
    }

    .pipeline__arrow {
        margin-left: 1.5rem;
        padding-left: 1.25rem;
        font-size: 1.1rem;
        color: var(--text-tertiary);
        line-height: 1;
        padding-top: 0.25rem;
        padding-bottom: 0.25rem;
    }

    .pipeline__body {
        flex: 1;
        min-width: 0;
    }

    .pipeline__agent {
        font-size: 0.75rem;
        color: var(--text-tertiary);
        font-family: "JetBrains Mono", monospace;
        margin-bottom: 0.25rem;
    }

    .pipeline__agent strong {
        color: var(--text-accent);
    }

    .pipeline__name {
        font-size: 1.1rem;
        font-weight: 700;
        margin: 0 0 0.4rem;
    }

    .pipeline__desc {
        font-size: 0.875rem;
        color: var(--text-secondary);
        line-height: 1.65;
        margin-bottom: 0.75rem;
    }

    .pipeline__outputs {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem;
    }

    .pipeline__output {
        display: inline-flex;
        padding: 0.15rem 0.5rem;
        border-radius: 4px;
        font-size: 0.72rem;
        font-weight: 600;
        font-family: "JetBrains Mono", monospace;
        background: var(--bg-glass);
        border: 1px solid var(--border-subtle);
        color: var(--text-secondary);
    }

    /* Principles */
    .principles {
        padding: 2rem;
        margin-bottom: 1.5rem;
    }

    .principles__title {
        font-size: 1.15rem;
        font-weight: 700;
        margin-bottom: 1.5rem;
    }

    .principles-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1.25rem;
    }

    .principle {
        display: flex;
        gap: 0.75rem;
        align-items: flex-start;
    }

    .principle__icon {
        font-size: 1.3rem;
        flex-shrink: 0;
        margin-top: 0.1rem;
    }

    .principle strong {
        display: block;
        font-size: 0.9rem;
        margin-bottom: 0.25rem;
    }

    .principle p {
        font-size: 0.8rem;
        color: var(--text-secondary);
        line-height: 1.5;
        margin: 0;
    }

    /* CTA */
    .cta {
        text-align: center;
        padding: 2.5rem 1.5rem;
        border: 1px solid var(--border-subtle);
        border-radius: 16px;
        background: color-mix(in srgb, var(--text-accent) 4%, transparent);
    }

    .cta__text {
        font-size: 1rem;
        color: var(--text-secondary);
        margin: 0 0 1.25rem;
    }

    .cta__btn {
        display: inline-flex;
        padding: 0.7rem 1.6rem;
        border-radius: 10px;
        background: var(--text-accent);
        color: #fff;
        font-weight: 700;
        font-size: 0.9rem;
        text-decoration: none;
        transition: opacity 0.15s;
    }

    .cta__btn:hover {
        opacity: 0.88;
    }

    /* Responsive */
    @media (max-width: 768px) {
        .principles-grid {
            grid-template-columns: 1fr;
        }
    }

    @media (max-width: 480px) {
        .pipeline__step {
            gap: 0.75rem;
            padding: 1rem 1rem 1rem 0;
        }
    }
</style>
