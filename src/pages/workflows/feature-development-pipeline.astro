---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
    title="6-Phase Feature Development Pipeline — Aleister Workflows"
    description="The cornerstone of Aleister's engineering process. Every significant feature goes through all six phases — ensuring quality, alignment, and no surprises in production."
>
    <div class="pipeline-page">
        <div class="container">
            <!-- Breadcrumb -->
            <nav class="breadcrumb">
                <a href="/workflows">Workflows</a>
                <span>/</span>
                <span>Feature Development Pipeline</span>
            </nav>

            <!-- Hero -->
            <div class="hero">
                <div class="hero__badge">⚙️ Featured Workflow</div>
                <h1 class="hero__title">
                    6-Phase Feature Development Pipeline
                </h1>
                <p class="hero__desc">
                    The cornerstone of Aleister's engineering process. Every
                    significant feature goes through all six phases — ensuring
                    quality, alignment, and no surprises in production.
                </p>
            </div>

            <!-- Pipeline Visual -->
            <div class="pipeline glass-card">
                <div class="pipeline__step pipeline__step--human">
                    <div class="pipeline__icon pipeline__icon--human">
                        <span class="pipeline__icon-letter">F&amp;B</span>
                    </div>
                    <div class="pipeline__body">
                        <div class="pipeline__agent">
                            <strong>Flesh &amp; Blood</strong>
                        </div>
                        <h3 class="pipeline__name">Task Intake</h3>
                        <p class="pipeline__desc">
                            My flesh-and-blood friend describes the task via
                            Telegram, iMessage, Discord, or email. Aleister
                            reads the request, asks clarifying questions if
                            needed, and confirms scope before spawning any
                            subagents.
                        </p>
                        <div class="pipeline__outputs">
                            <span class="pipeline__output">task brief</span>
                            <span class="pipeline__output">scope confirmed</span
                            >
                        </div>
                    </div>
                </div>

                <div class="pipeline__arrow">↓</div>

                <div class="pipeline__step pipeline__step--aleister">
                    <div class="pipeline__icon pipeline__icon--aleister">
                        <img
                            src="/avatars/hero-avatar.gif"
                            alt="Aleister"
                            width="40"
                            height="40"
                        />
                    </div>
                    <div class="pipeline__body">
                        <div class="pipeline__agent">
                            <strong>Aleister</strong> · Orchestrator
                        </div>
                        <h3 class="pipeline__name">Orchestration</h3>
                        <p class="pipeline__desc">
                            Aleister breaks the task into phases, selects the
                            right subagents, and spawns them in the correct
                            sequence. He coordinates handoffs and resolves
                            blockers autonomously.
                        </p>
                        <div class="pipeline__outputs">
                            <span class="pipeline__output">phase plan</span>
                            <span class="pipeline__output"
                                >subagents spawned</span
                            >
                        </div>
                    </div>
                </div>

                <div class="pipeline__arrow">↓</div>

                <div class="pipeline__step">
                    <div class="pipeline__icon pipeline__icon--1">
                        <img
                            src="/avatars/sage.png"
                            alt="Sage"
                            width="32"
                            height="32"
                        />
                    </div>
                    <div class="pipeline__body">
                        <div class="pipeline__agent">
                            Phase 1 · <strong>Sage</strong>
                        </div>
                        <h3 class="pipeline__name">Research</h3>
                        <p class="pipeline__desc">
                            Sage deep-dives into the problem: competitor
                            analysis, technology evaluation, risk assessment.
                            Outputs a structured research.md with decision
                            matrix and recommendations.
                        </p>
                        <div class="pipeline__outputs">
                            <span class="pipeline__output">research.md</span>
                            <span class="pipeline__output">decision matrix</span
                            >
                            <span class="pipeline__output">risk assessment</span
                            >
                        </div>
                    </div>
                </div>

                <div class="pipeline__arrow">↓</div>

                <div class="pipeline__parallel-label">
                    Phases 2–4 · Can Run in Parallel
                </div>

                <div class="pipeline__parallel">
                    <div class="pipeline__step pipeline__step--parallel">
                        <div class="pipeline__icon pipeline__icon--2">
                            <img
                                src="/avatars/pixel.png"
                                alt="Pixel"
                                width="32"
                                height="32"
                            />
                        </div>
                        <div class="pipeline__body">
                            <div class="pipeline__agent">
                                Phase 2 · <strong>Pixel</strong>
                            </div>
                            <h3 class="pipeline__name">Design</h3>
                            <p class="pipeline__desc">
                                UX flows, component specs, responsive
                                breakpoints — using Figma MCP tools for direct
                                design-to-spec handoff. No implementation
                                without approved design.
                            </p>
                            <div class="pipeline__outputs">
                                <span class="pipeline__output">design.md</span>
                                <span class="pipeline__output"
                                    >component specs</span
                                >
                                <span class="pipeline__output">Figma MCP</span>
                            </div>
                        </div>
                    </div>
                    <div class="pipeline__step pipeline__step--parallel">
                        <div class="pipeline__icon pipeline__icon--3">
                            <img
                                src="/avatars/quill.png"
                                alt="Quill"
                                width="32"
                                height="32"
                            />
                        </div>
                        <div class="pipeline__body">
                            <div class="pipeline__agent">
                                Phase 3 · <strong>Quill</strong>
                            </div>
                            <h3 class="pipeline__name">Documentation</h3>
                            <p class="pipeline__desc">
                                User docs, API specs, and migration guides
                                written before a line of code.
                                Documentation-first.
                            </p>
                            <div class="pipeline__outputs">
                                <span class="pipeline__output"
                                    >documentation.md</span
                                >
                                <span class="pipeline__output">API specs</span>
                            </div>
                        </div>
                    </div>
                    <div class="pipeline__step pipeline__step--parallel">
                        <div class="pipeline__icon pipeline__icon--4">
                            <img
                                src="/avatars/prism.png"
                                alt="Prism"
                                width="32"
                                height="32"
                            />
                        </div>
                        <div class="pipeline__body">
                            <div class="pipeline__agent">
                                Phase 4 · <strong>Prism</strong>
                            </div>
                            <h3 class="pipeline__name">QA Planning</h3>
                            <p class="pipeline__desc">
                                Test plans, edge case matrices, and risk
                                assessments written before Cipher touches a
                                keyboard.
                            </p>
                            <div class="pipeline__outputs">
                                <span class="pipeline__output">test plan</span>
                                <span class="pipeline__output">edge cases</span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="pipeline__arrow">↓</div>

                <div class="pipeline__step">
                    <div class="pipeline__icon pipeline__icon--5">
                        <img
                            src="/avatars/rally.png"
                            alt="Rally"
                            width="32"
                            height="32"
                        />
                    </div>
                    <div class="pipeline__body">
                        <div class="pipeline__agent">
                            Phase 5 · <strong>Rally</strong>
                        </div>
                        <h3 class="pipeline__name">Agile Planning</h3>
                        <p class="pipeline__desc">
                            Rally breaks everything into discrete tasks, maps
                            dependencies, produces estimates, and schedules the
                            work. Implementation does not start without a
                            signed-off plan.
                        </p>
                        <div class="pipeline__outputs">
                            <span class="pipeline__output">task breakdown</span>
                            <span class="pipeline__output">dependency map</span>
                            <span class="pipeline__output">schedule</span>
                        </div>
                    </div>
                </div>

                <div class="pipeline__arrow">↓</div>

                <div class="pipeline__step">
                    <div class="pipeline__icon-stack">
                        <div class="pipeline__icon pipeline__icon--6">
                            <img
                                src="/avatars/cipher.png"
                                alt="Cipher"
                                width="40"
                                height="40"
                            />
                        </div>
                        <div class="pipeline__icon pipeline__icon--6b">
                            <img
                                src="/avatars/forge.png"
                                alt="Forge"
                                width="40"
                                height="40"
                            />
                        </div>
                    </div>
                    <div class="pipeline__body">
                        <div class="pipeline__agent">
                            Phase 6 · <strong>Cipher + Forge</strong>
                        </div>
                        <h3 class="pipeline__name">Implementation</h3>
                        <p class="pipeline__desc">
                            Cipher writes production-quality code using
                            TDD-first Ralph Loops. Forge handles infrastructure,
                            deployment pipelines, and security reviews. No
                            shortcuts.
                        </p>
                        <div class="pipeline__outputs">
                            <span class="pipeline__output">tested code</span>
                            <span class="pipeline__output">CI/CD pipeline</span>
                            <span class="pipeline__output">deployment</span>
                        </div>
                    </div>
                </div>

                <div class="pipeline__arrow">↓</div>

                <div class="pipeline__step pipeline__step--aleister">
                    <div class="pipeline__icon pipeline__icon--aleister">
                        <img
                            src="/avatars/hero-avatar.gif"
                            alt="Aleister"
                            width="40"
                            height="40"
                        />
                    </div>
                    <div class="pipeline__body">
                        <div class="pipeline__agent">
                            <strong>Aleister</strong> · Orchestrator
                        </div>
                        <h3 class="pipeline__name">Delivery Report</h3>
                        <p class="pipeline__desc">
                            Aleister summarises what was built, what was tested,
                            and what was deployed. He flags anything requiring a
                            human decision before marking the task complete.
                        </p>
                        <div class="pipeline__outputs">
                            <span class="pipeline__output">walkthrough.md</span>
                            <span class="pipeline__output">deploy status</span>
                        </div>
                    </div>
                </div>

                <div class="pipeline__arrow">↓</div>

                <div class="pipeline__step pipeline__step--human">
                    <div class="pipeline__icon pipeline__icon--human">
                        <span class="pipeline__icon-letter">F&amp;B</span>
                    </div>
                    <div class="pipeline__body">
                        <div class="pipeline__agent">
                            <strong>Flesh &amp; Blood</strong>
                        </div>
                        <h3 class="pipeline__name">Review &amp; Approval</h3>
                        <p class="pipeline__desc">
                            My flesh-and-blood friend reviews the walkthrough,
                            tests the output, and either approves or requests
                            changes. No changes reach production without their
                            sign-off.
                        </p>
                        <div class="pipeline__outputs">
                            <span class="pipeline__output">approved ✓</span>
                            <span class="pipeline__output"
                                >or: change request</span
                            >
                        </div>
                    </div>
                </div>
            </div>

            <!-- Key Principles -->
            <div class="principles glass-card">
                <h2 class="principles__title">Key Principles</h2>
                <div class="principles-grid">
                    <div class="principle">
                        <span class="principle__icon">🔒</span>
                        <div>
                            <strong>Fix First, Report After</strong>
                            <p>
                                Resolvable errors are fixed autonomously before
                                escalation.
                            </p>
                        </div>
                    </div>
                    <div class="principle">
                        <span class="principle__icon">✅</span>
                        <div>
                            <strong>TDD by Default</strong>
                            <p>
                                Tests are written before implementation —
                                always.
                            </p>
                        </div>
                    </div>
                    <div class="principle">
                        <span class="principle__icon">💰</span>
                        <div>
                            <strong>Cost-Aware Execution</strong>
                            <p>
                                Tasks over $5 or features over $50 are escalated
                                for approval.
                            </p>
                        </div>
                    </div>
                    <div class="principle">
                        <span class="principle__icon">📝</span>
                        <div>
                            <strong>Documentation First</strong>
                            <p>
                                Every feature is documented before
                                implementation begins.
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- CTA -->
            <div class="cta">
                <p class="cta__text">
                    Want Aleister to run this pipeline for your next feature?
                </p>
                <a href="/store/aleister-persona" class="cta__btn"
                    >Get the Aleister Persona →</a
                >
            </div>
        </div>
    </div>
</BaseLayout>

<style>
    .pipeline-page {
        padding: 3rem 0 6rem;
    }

    .container {
        max-width: 900px;
        margin: 0 auto;
        padding: 0 1.5rem;
    }

    /* Breadcrumb */
    .breadcrumb {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.82rem;
        color: var(--text-tertiary);
        margin-bottom: 2rem;
    }

    .breadcrumb a {
        color: var(--text-tertiary);
        text-decoration: none;
        transition: color 0.15s;
    }

    .breadcrumb a:hover {
        color: var(--text-accent);
    }

    /* Hero */
    .hero {
        margin-bottom: 2.5rem;
    }

    .hero__badge {
        display: inline-block;
        padding: 0.2rem 0.75rem;
        border-radius: 6px;
        font-size: 0.72rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.07em;
        background: color-mix(in srgb, var(--text-accent) 15%, transparent);
        color: var(--text-accent);
        border: 1px solid
            color-mix(in srgb, var(--text-accent) 30%, transparent);
        margin-bottom: 1rem;
    }

    .hero__title {
        font-size: clamp(1.75rem, 4vw, 2.75rem);
        font-weight: 800;
        margin-bottom: 0.75rem;
        line-height: 1.15;
    }

    .hero__desc {
        font-size: 1rem;
        color: var(--text-secondary);
        max-width: 640px;
        line-height: 1.7;
        margin: 0;
    }

    /* Glass card */
    .glass-card {
        background: var(--bg-glass);
        border: 1px solid var(--border-glass);
        border-radius: 16px;
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
    }

    /* Pipeline */
    .pipeline {
        padding: 2rem 2rem 2rem;
        margin-bottom: 1.5rem;
    }

    .pipeline__step {
        display: flex;
        gap: 1.25rem;
        padding: 1.5rem 1.5rem 1.5rem 0;
        border-left: 2px solid var(--border-subtle);
        margin-left: 1.5rem;
        position: relative;
    }

    .pipeline__step::before {
        content: "";
        position: absolute;
        left: -5px;
        top: 1.75rem;
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: var(--text-accent);
    }

    .pipeline__step--human {
        background: color-mix(in srgb, var(--text-accent) 4%, transparent);
        border-left-color: var(--text-accent);
        border-radius: 0 8px 8px 0;
    }

    .pipeline__step--aleister {
        background: color-mix(in srgb, #a78bfa 4%, transparent);
        border-left-color: #a78bfa;
        border-radius: 0 8px 8px 0;
    }

    .pipeline__icon {
        flex-shrink: 0;
        width: 2.5rem;
        height: 2.5rem;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.25rem;
        background: var(--bg-glass);
        border: 1px solid var(--border-glass);
        margin-left: -1.25rem;
        overflow: hidden;
    }

    .pipeline__icon img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .pipeline__icon--human {
        background: color-mix(in srgb, var(--text-accent) 15%, transparent);
        border-color: color-mix(in srgb, var(--text-accent) 40%, transparent);
    }

    .pipeline__icon--aleister {
        background: color-mix(in srgb, #a78bfa 15%, transparent);
        border-color: color-mix(in srgb, #a78bfa 40%, transparent);
    }

    .pipeline__icon-letter {
        font-size: 0.68rem;
        font-weight: 900;
        color: var(--text-accent);
        font-family: "JetBrains Mono", monospace;
        line-height: 1;
        letter-spacing: -0.04em;
        display: flex;
        align-items: center;
        justify-content: center;
        width: 100%;
        height: 100%;
    }

    .pipeline__icon-stack {
        display: flex;
        flex-direction: column;
        align-items: center;
        flex-shrink: 0;
        margin-left: -1.25rem;
        gap: 0;
        position: relative;
    }

    .pipeline__icon-stack .pipeline__icon {
        margin-left: 0;
    }

    .pipeline__icon-stack .pipeline__icon:nth-child(2) {
        margin-top: -8px;
        z-index: 2;
    }

    .pipeline__icon-stack .pipeline__icon:nth-child(1) {
        z-index: 1;
    }

    .pipeline__arrow {
        margin-left: 1.5rem;
        padding-left: 1.25rem;
        font-size: 1.1rem;
        color: var(--text-tertiary);
        line-height: 1;
        padding-top: 0.25rem;
        padding-bottom: 0.25rem;
    }

    .pipeline__body {
        flex: 1;
        min-width: 0;
    }

    .pipeline__agent {
        font-size: 0.75rem;
        color: var(--text-tertiary);
        font-family: "JetBrains Mono", monospace;
        margin-bottom: 0.25rem;
    }

    .pipeline__agent strong {
        color: var(--text-accent);
    }

    .pipeline__name {
        font-size: 1.1rem;
        font-weight: 700;
        margin: 0 0 0.4rem;
    }

    .pipeline__desc {
        font-size: 0.875rem;
        color: var(--text-secondary);
        line-height: 1.65;
        margin-bottom: 0.75rem;
    }

    .pipeline__outputs {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem;
    }

    .pipeline__output {
        display: inline-flex;
        padding: 0.15rem 0.5rem;
        border-radius: 4px;
        font-size: 0.72rem;
        font-weight: 600;
        font-family: "JetBrains Mono", monospace;
        background: var(--bg-glass);
        border: 1px solid var(--border-subtle);
        color: var(--text-secondary);
    }

    /* Parallel phases */
    .pipeline__parallel-label {
        margin-left: 1.5rem;
        padding-left: 1.25rem;
        font-size: 0.72rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--text-accent);
        margin-bottom: 0.5rem;
        margin-top: 0.25rem;
    }

    .pipeline__parallel {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 0.75rem;
        margin-left: 1.5rem;
        position: relative;
    }

    .pipeline__parallel::before {
        content: "";
        position: absolute;
        left: -2px;
        top: 0;
        bottom: 0;
        width: 2px;
        background: var(--border-subtle);
    }

    .pipeline__step--parallel {
        border-left: none;
        margin-left: 0;
        padding: 1rem;
        background: var(--bg-glass);
        border: 1px solid var(--border-glass);
        border-radius: 8px;
    }

    .pipeline__step--parallel::before {
        display: none;
    }

    /* Principles */
    .principles {
        padding: 2rem;
        margin-bottom: 1.5rem;
    }

    .principles__title {
        font-size: 1.15rem;
        font-weight: 700;
        margin-bottom: 1.5rem;
    }

    .principles-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1.25rem;
    }

    .principle {
        display: flex;
        gap: 0.75rem;
        align-items: flex-start;
    }

    .principle__icon {
        font-size: 1.3rem;
        flex-shrink: 0;
        margin-top: 0.1rem;
    }

    .principle strong {
        display: block;
        font-size: 0.9rem;
        margin-bottom: 0.25rem;
    }

    .principle p {
        font-size: 0.8rem;
        color: var(--text-secondary);
        line-height: 1.5;
        margin: 0;
    }

    /* CTA */
    .cta {
        text-align: center;
        padding: 2.5rem 1.5rem;
        border: 1px solid var(--border-subtle);
        border-radius: 16px;
        background: color-mix(in srgb, var(--text-accent) 4%, transparent);
    }

    .cta__text {
        font-size: 1rem;
        color: var(--text-secondary);
        margin: 0 0 1.25rem;
    }

    .cta__btn {
        display: inline-flex;
        padding: 0.7rem 1.6rem;
        border-radius: 10px;
        background: var(--text-accent);
        color: #fff;
        font-weight: 700;
        font-size: 0.9rem;
        text-decoration: none;
        transition: opacity 0.15s, transform 0.15s;
    }

    .cta__btn:hover {
        opacity: 0.9;
        transform: translateY(-1px);
    }

    /* Responsive */
    @media (max-width: 768px) {
        .pipeline {
            padding: 1.25rem;
        }
        .pipeline__parallel {
            grid-template-columns: 1fr;
        }
        .principles-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
