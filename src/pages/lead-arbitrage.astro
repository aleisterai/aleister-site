---
import BaseLayout from "../layouts/BaseLayout.astro";
import BreadcrumbSchema from "../components/BreadcrumbSchema.astro";
---

<BaseLayout
    title="Lead Arbitrage — AI-Powered Lead Generation for Local Businesses"
    description="Never miss a lead again. Aleister responds in under 10 seconds on any channel — no website needed, no setup fees. AI lead generation built for local businesses."
    jsonLdExtra={[
      {
        "@type": "Service",
        name: "Lead Arbitrage",
        description: "AI-powered lead generation for local businesses. Aleister responds in under 10 seconds on any channel.",
        url: "https://thealeister.com/lead-arbitrage",
        image: "https://thealeister.com/og-image.jpg",
        provider: { "@type": "Organization", name: "CYTY Inc", url: "https://thealeister.com" },
        areaServed: { "@type": "Place", name: "United States" },
        offers: { "@type": "Offer", priceRange: "$$$", availability: "https://schema.org/InStock" }
      }
    ]}
>
    <BreadcrumbSchema
        slot="head"
        items={[
          { name: "Home", url: "https://thealeister.com" },
          { name: "Lead Arbitrage", url: "https://thealeister.com/lead-arbitrage" }
        ]}
    />
    <!-- Success Overlay -->
    <div class="la-success-overlay" id="success-overlay" style="display:none">
        <div class="glass-card la-success-card">
            <div class="la-success__icon">🎉</div>
            <h2>You're All Set!</h2>
            <p>
                Your subscription is confirmed. A receipt has been sent to your
                email.<br />
                <strong>Aleister will be in touch with you soon</strong> to learn
                about your business and get everything set up.
            </p>
            <button class="btn btn-primary" id="success-dismiss"
                >Got It →</button
            >
        </div>
    </div>

    <!-- Hero -->
    <section class="la-hero section">
        <div class="container">
            <div class="page-header">
                <h1 class="page-header__title">
                    Stop Losing Leads.<br /><span class="text-gradient"
                        >Start Closing Them.</span
                    >
                </h1>
                <p class="page-header__subtitle">
                    For local businesses that don't have a website.
                </p>
            </div>
            <div class="la-hero__stats">
                <div class="la-hero__stat">
                    <span class="la-hero__stat-value">&lt;10s</span>
                    <span class="la-hero__stat-label">Response Time</span>
                </div>
                <div class="la-hero__stat-divider"></div>
                <div class="la-hero__stat">
                    <span class="la-hero__stat-value">24/7</span>
                    <span class="la-hero__stat-label">Always On</span>
                </div>
                <div class="la-hero__stat-divider"></div>
                <div class="la-hero__stat">
                    <span class="la-hero__stat-value">~2 Wks</span>
                    <span class="la-hero__stat-label">Custom Setup</span>
                </div>
            </div>
        </div>
    </section>

    <!-- Advantages -->
    <section class="la-advantages section">
        <div class="container">
            <h2 class="section-title">
                Why <span class="text-gradient"
                    >Lead Arbitrage by Aleister?</span
                >
            </h2>
            <p class="section-subtitle">
                AI that responds in under 10 seconds, books appointments, and
                never takes a day off — in any language.
            </p>

            <div class="advantages-grid">
                <div class="glass-card advantage-card">
                    <div class="advantage-card__icon">🚫</div>
                    <h3>Aleister Runs Your Online Presence</h3>
                    <p>
                        No website? No problem. Aleister creates and manages
                        your entire online business presence — generating
                        traffic, capturing leads, and booking clients for you.
                        Starting from $229/mo.
                    </p>
                </div>
                <div class="glass-card advantage-card">
                    <div class="advantage-card__icon">⚡</div>
                    <h3>Under 10-Second Response</h3>
                    <p>
                        Every lead gets a response in under 10 seconds — on
                        WhatsApp, email, phone, SMS, or any channel. Your
                        competitors take hours. You take seconds.
                    </p>
                </div>
                <div class="glass-card advantage-card">
                    <div class="advantage-card__icon">🔄</div>
                    <h3>Transfer Existing Leads</h3>
                    <p>
                        Already have lead sources? Transfer your current Meta
                        ads, Google forms, landing pages, or CRM leads directly
                        to Aleister. Nothing gets wasted.
                    </p>
                </div>
                <div class="glass-card advantage-card">
                    <div class="advantage-card__icon">💰</div>
                    <h3>Zero Setup Fees</h3>
                    <p>
                        No AI setup overhead. No integration fees. No onboarding
                        charges. Aleister configures everything — you just
                        provide your business details and start getting clients.
                    </p>
                </div>
                <div class="glass-card advantage-card">
                    <div class="advantage-card__icon">🌙</div>
                    <h3>Never Miss a Lead</h3>
                    <p>
                        Leads don't respect business hours. Aleister works
                        24/7/365 — holidays, weekends, 3 AM. Every single
                        inquiry gets handled instantly.
                    </p>
                </div>
                <div class="glass-card advantage-card">
                    <div class="advantage-card__icon">🌍</div>
                    <h3>Speaks Any Language</h3>
                    <p>
                        Aleister communicates fluently in any language your
                        clients speak — English, Spanish, French, Russian,
                        Ukrainian, Mandarin, Arabic, Portuguese, and more. No
                        translator needed.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- Pricing Cards -->
    <section class="la-pricing section" id="pricing">
        <div class="container">
            <h2 class="section-title">
                Simple, <span class="text-gradient">Transparent Pricing</span>
            </h2>
            <p class="section-subtitle">
                Every plan includes a money-back guarantee. If your subscription
                doesn't pay for itself within the first month, you get a full
                refund.
            </p>

            <div class="pricing-grid">
                <!-- Tier 1: Warm Transfer -->
                <div class="glass-card pricing-card">
                    <div class="pricing-card__header">
                        <h3 class="pricing-card__name">Warm Transfer</h3>
                        <p class="pricing-card__desc">
                            ~50 warm leads/mo delivered to your channels
                        </p>
                    </div>
                    <div class="pricing-card__price">
                        <span class="pricing-card__amount">$69</span>
                        <span class="pricing-card__period">/month</span>
                    </div>
                    <ul class="pricing-card__features">
                        <li>
                            <span class="check">✓</span> ~50 warm leads per month
                        </li>
                        <li>
                            <span class="check">✓</span> AI-generated traffic & lead
                            capture
                        </li>
                        <li>
                            <span class="check">✓</span> Warm transfer to any channel
                        </li>
                        <li>
                            <span class="check">✓</span> WhatsApp, email, phone,
                            SMS
                        </li>
                        <li>
                            <span class="check">✓</span> &lt;10 second response time
                        </li>
                        <li><span class="check">✓</span> 24/7 lead handling</li>
                        <li>
                            <span class="check">✓</span> No website required
                        </li>
                    </ul>
                    <button
                        class="btn btn-primary pricing-card__cta"
                        data-tier="warm-transfer"
                        id="subscribe-warm-transfer"
                    >
                        Subscribe →
                    </button>
                </div>

                <!-- Tier 2: Hot Leads -->
                <div class="glass-card pricing-card pricing-card--popular">
                    <div class="pricing-card__badge">Most Popular</div>
                    <div class="pricing-card__header">
                        <h3 class="pricing-card__name">Hot Leads</h3>
                        <p class="pricing-card__desc">
                            ~50 pre-qualified, ready-to-book clients
                        </p>
                    </div>
                    <div class="pricing-card__price">
                        <span class="pricing-card__amount">$229</span>
                        <span class="pricing-card__period">/month</span>
                    </div>
                    <div class="pricing-card__commission">
                        + 10% from client check
                    </div>
                    <ul class="pricing-card__features">
                        <li>
                            <span class="check">✓</span> ~50 hot leads per month
                        </li>
                        <li>
                            <span class="check">✓</span> AI qualification & scoring
                        </li>
                        <li>
                            <span class="check">✓</span> Intent verification before
                            transfer
                        </li>
                        <li>
                            <span class="check">✓</span> Lead follow-up sequences
                        </li>
                        <li><span class="check">✓</span> Priority support</li>
                        <li>
                            <span class="check">✓</span> Weekly performance reports
                        </li>
                        <li>
                            <span class="check">✓</span> Transfer existing lead sources
                        </li>
                    </ul>
                    <button
                        class="btn btn-primary pricing-card__cta"
                        data-tier="hot-leads"
                        id="subscribe-hot-leads"
                    >
                        Subscribe →
                    </button>
                </div>

                <!-- Tier 3: Full Booking -->
                <div class="glass-card pricing-card">
                    <div class="pricing-card__header">
                        <h3 class="pricing-card__name">Full Booking</h3>
                        <p class="pricing-card__desc">
                            x5 ROI with full management
                        </p>
                    </div>
                    <div class="pricing-card__price">
                        <span class="pricing-card__amount">$599</span>
                        <span class="pricing-card__period">/month</span>
                    </div>
                    <div class="pricing-card__commission">
                        + 8% from client check
                    </div>
                    <ul class="pricing-card__features">
                        <li>
                            <span class="check">✓</span> x5 ROI
                        </li>
                        <li>
                            <span class="check">✓</span> AI books appointments directly
                        </li>
                        <li>
                            <span class="check">✓</span> Payment collection & management
                        </li>
                        <li>
                            <span class="check">✓</span> Booking system integration
                        </li>
                        <li>
                            <span class="check">✓</span> No booking system? Aleister
                            sends you the info
                        </li>
                        <li>
                            <span class="check">✓</span> Calendar sync & reminders
                        </li>
                        <li>
                            <span class="check">✓</span> Everything in Hot Leads
                        </li>
                    </ul>
                    <button
                        class="btn btn-primary pricing-card__cta"
                        data-tier="full-booking"
                        id="subscribe-full-booking"
                    >
                        Subscribe →
                    </button>
                </div>

                <!-- Tier 4: Full Service -->
                <div class="glass-card pricing-card pricing-card--premium">
                    <div
                        class="pricing-card__badge pricing-card__badge--premium"
                    >
                        🏆 Full Service
                    </div>
                    <div class="pricing-card__header">
                        <h3 class="pricing-card__name">Full Service</h3>
                        <p class="pricing-card__desc">
                            x10 ROI + social media management
                        </p>
                    </div>
                    <div class="pricing-card__price">
                        <span class="pricing-card__amount">$999</span>
                        <span class="pricing-card__period">/month</span>
                    </div>
                    <div class="pricing-card__commission">
                        + 6% from client check
                    </div>
                    <ul class="pricing-card__features">
                        <li>
                            <span class="check">✓</span> x10 ROI
                        </li>
                        <li>
                            <span class="check">✓</span> Social media content creation
                        </li>
                        <li>
                            <span class="check">✓</span> Social media engagement
                            management
                        </li>
                        <li>
                            <span class="check">✓</span> Brand-voice posting schedule
                        </li>
                        <li>
                            <span class="check">✓</span> Monthly growth analytics
                        </li>
                        <li>
                            <span class="check">✓</span> Dedicated account management
                        </li>
                        <li>
                            <span class="check">✓</span> Everything in Full Booking
                        </li>
                    </ul>
                    <button
                        class="btn btn-primary pricing-card__cta"
                        data-tier="full-service"
                        id="subscribe-full-service"
                    >
                        Subscribe →
                    </button>
                </div>
            </div>
            <p class="section-disclaimer">
                * Pricing shown is for US-based businesses. Outside the US?
                Reach out to Aleister for custom pricing at <a
                    href="mailto:aleisterrai@gmail.com">aleisterrai@gmail.com</a
                >
            </p>
        </div>
    </section>

    <!-- Money-Back Guarantee -->
    <section class="la-guarantee section">
        <div class="container">
            <div class="glass-card guarantee-card">
                <div class="guarantee-card__icon">🛡️</div>
                <h2>Money-Back <span class="text-gradient">Guarantee</span></h2>
                <p>
                    If your monthly subscription doesn't pay for itself — you
                    get a
                    <strong>full refund</strong>. No questions asked. Aleister
                    is that confident Aleister will deliver results from day
                    one.
                </p>
            </div>
        </div>
    </section>

    <!-- Cost Comparison vs Human Resources -->
    <section class="la-compare section">
        <div class="container">
            <h2 class="section-title">
                Aleister vs. <span class="text-gradient">Hiring Humans</span>
            </h2>
            <p class="section-subtitle">
                See what you'd actually spend to match what Aleister does — with
                real people on payroll.
            </p>

            <div class="compare-wrapper compare-desktop">
                <table class="compare-table">
                    <thead>
                        <tr>
                            <th class="compare-feature">Role / Cost</th>
                            <th class="compare-human">
                                <div class="compare-header">👤 Human Staff</div>
                            </th>
                            <th class="compare-aleister">
                                <div
                                    class="compare-header compare-header--aleister"
                                >
                                    <span>🤖 Aleister</span>
                                    <span class="compare-badge">Save 90%+</span>
                                </div>
                            </th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td class="compare-feature"
                                >Receptionist / Lead Responder</td
                            >
                            <td class="compare-human">$2,500 – $3,500/mo</td>
                            <td class="compare-aleister"
                                ><strong>Included</strong> in all plans</td
                            >
                        </tr>
                        <tr>
                            <td class="compare-feature">Response Time</td>
                            <td class="compare-human"
                                >Minutes to hours (business hours only)</td
                            >
                            <td class="compare-aleister">
                                <strong>&lt;10 seconds</strong>, 24/7/365</td
                            >
                        </tr>
                        <tr>
                            <td class="compare-feature"
                                >Appointment Setter / Booker</td
                            >
                            <td class="compare-human">$2,000 – $3,000/mo</td>
                            <td class="compare-aleister"
                                ><strong>Included</strong> from $599/mo</td
                            >
                        </tr>
                        <tr>
                            <td class="compare-feature">Social Media Manager</td
                            >
                            <td class="compare-human">$3,000 – $5,000/mo</td>
                            <td class="compare-aleister"
                                ><strong>Included</strong> at $999/mo</td
                            >
                        </tr>
                        <tr>
                            <td class="compare-feature"
                                >Marketing / Lead Generation</td
                            >
                            <td class="compare-human">$3,000 – $6,000/mo</td>
                            <td class="compare-aleister"
                                ><strong>Included</strong> in all plans</td
                            >
                        </tr>
                        <tr>
                            <td class="compare-feature"
                                >Website Development & Hosting</td
                            >
                            <td class="compare-human"
                                >$2,000 setup + $50–200/mo</td
                            >
                            <td class="compare-aleister"
                                ><strong>Not needed</strong> — $0</td
                            >
                        </tr>
                        <tr>
                            <td class="compare-feature"
                                >CRM / Booking Software</td
                            >
                            <td class="compare-human">$50 – $300/mo</td>
                            <td class="compare-aleister"
                                ><strong>Built in</strong> — $0</td
                            >
                        </tr>
                        <tr>
                            <td class="compare-feature compare-total"
                                >Total Monthly Cost</td
                            >
                            <td class="compare-human compare-total"
                                ><strong>$12,600 – $18,000+</strong>
                            </td>
                        </tr>
                        <tr>
                            <td></td>
                            <td></td>
                            <td class="compare-aleister compare-total"
                                ><strong>$69 – $999</strong>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <!-- Mobile stacked cards version -->
            <div class="compare-mobile">
                <div class="compare-mobile__summary glass-card">
                    <div class="compare-mobile__vs">
                        <div class="compare-mobile__col">
                            <span class="compare-mobile__emoji">👤</span>
                            <span class="compare-mobile__label"
                                >Human Staff</span
                            >
                            <span
                                class="compare-mobile__cost compare-mobile__cost--human"
                                >$12,600 – $18,000+<small>/mo</small>
                            </span>
                        </div>
                        <div class="compare-mobile__divider">vs</div>
                        <div class="compare-mobile__col">
                            <span class="compare-mobile__emoji">🤖</span>
                            <span class="compare-mobile__label">Aleister</span>
                            <span
                                class="compare-mobile__cost compare-mobile__cost--aleister"
                                >$69 – $999<small>/mo</small>
                            </span>
                        </div>
                    </div>
                    <div class="compare-mobile__badge-row">
                        <span class="compare-badge">Save 90%+</span>
                    </div>
                </div>
                <div class="compare-mobile__cards">
                    <div class="glass-card compare-mobile__card">
                        <h4>Receptionist / Lead Responder</h4>
                        <div class="compare-mobile__row">
                            <span>👤 Human</span><span
                                class="compare-mobile__human-val"
                                >$2,500 – $3,500/mo</span
                            >
                        </div>
                        <div class="compare-mobile__row">
                            <span>🤖 Aleister</span><span
                                class="compare-mobile__aleister-val"
                                ><strong>Included</strong> in all plans</span
                            >
                        </div>
                    </div>
                    <div class="glass-card compare-mobile__card">
                        <h4>Response Time</h4>
                        <div class="compare-mobile__row">
                            <span>👤 Human</span><span
                                class="compare-mobile__human-val"
                                >Minutes to hours</span
                            >
                        </div>
                        <div class="compare-mobile__row">
                            <span>🤖 Aleister</span><span
                                class="compare-mobile__aleister-val"
                                ><strong>&lt;10 seconds</strong>, 24/7</span
                            >
                        </div>
                    </div>
                    <div class="glass-card compare-mobile__card">
                        <h4>Appointment Setter</h4>
                        <div class="compare-mobile__row">
                            <span>👤 Human</span><span
                                class="compare-mobile__human-val"
                                >$2,000 – $3,000/mo</span
                            >
                        </div>
                        <div class="compare-mobile__row">
                            <span>🤖 Aleister</span><span
                                class="compare-mobile__aleister-val"
                                ><strong>Included</strong> from $599</span
                            >
                        </div>
                    </div>
                    <div class="glass-card compare-mobile__card">
                        <h4>Social Media Manager</h4>
                        <div class="compare-mobile__row">
                            <span>👤 Human</span><span
                                class="compare-mobile__human-val"
                                >$3,000 – $5,000/mo</span
                            >
                        </div>
                        <div class="compare-mobile__row">
                            <span>🤖 Aleister</span><span
                                class="compare-mobile__aleister-val"
                                ><strong>Included</strong> at $999</span
                            >
                        </div>
                    </div>
                    <div class="glass-card compare-mobile__card">
                        <h4>Marketing / Lead Generation</h4>
                        <div class="compare-mobile__row">
                            <span>👤 Human</span><span
                                class="compare-mobile__human-val"
                                >$3,000 – $6,000/mo</span
                            >
                        </div>
                        <div class="compare-mobile__row">
                            <span>🤖 Aleister</span><span
                                class="compare-mobile__aleister-val"
                                ><strong>Included</strong> in all plans</span
                            >
                        </div>
                    </div>
                    <div class="glass-card compare-mobile__card">
                        <h4>Website & Hosting</h4>
                        <div class="compare-mobile__row">
                            <span>👤 Human</span><span
                                class="compare-mobile__human-val"
                                >$2,000 + $50–200/mo</span
                            >
                        </div>
                        <div class="compare-mobile__row">
                            <span>🤖 Aleister</span><span
                                class="compare-mobile__aleister-val"
                                ><strong>Not needed</strong> — $0</span
                            >
                        </div>
                    </div>
                    <div class="glass-card compare-mobile__card">
                        <h4>CRM / Booking Software</h4>
                        <div class="compare-mobile__row">
                            <span>👤 Human</span><span
                                class="compare-mobile__human-val"
                                >$50 – $300/mo</span
                            >
                        </div>
                        <div class="compare-mobile__row">
                            <span>🤖 Aleister</span><span
                                class="compare-mobile__aleister-val"
                                ><strong>Built in</strong> — $0</span
                            >
                        </div>
                    </div>
                </div>
            </div>
            <p class="section-disclaimer">
                * Data and salary estimates based on US market averages.
            </p>
        </div>
    </section>

    <!-- How It Works -->
    <section class="la-how section">
        <div class="container">
            <h2 class="section-title">
                How It <span class="text-gradient">Works</span>
            </h2>
            <p class="section-subtitle">
                Get started in minutes. No technical knowledge required.
            </p>

            <div class="how-grid">
                <div class="glass-card how-card">
                    <div class="how-card__step">01</div>
                    <h3>Aleister Learns Your Business</h3>
                    <p>
                        Over approximately 2 weeks, Aleister studies your
                        business — services, pricing, operations, target
                        customers, competitors. Everything is custom-tailored to
                        your niche and subscription plan. No cookie-cutter
                        templates.
                    </p>
                </div>
                <div class="how-arrow">→</div>
                <div class="glass-card how-card">
                    <div class="how-card__step">02</div>
                    <h3>Aleister Finds Your Clients</h3>
                    <p>
                        AI-powered traffic generation, lead capture, and
                        qualification. Transfer your existing lead sources too.
                        Every inquiry gets a response in under 10 seconds.
                    </p>
                </div>
                <div class="how-arrow">→</div>
                <div class="glass-card how-card">
                    <div class="how-card__step">03</div>
                    <h3>You Get Paying Clients</h3>
                    <p>
                        Warm transfers, hot leads, or fully booked appointments
                        delivered to your preferred channel. You focus on your
                        craft — Aleister fills your calendar.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- Niches Aleister Works With -->
    <section class="la-niches section">
        <div class="container">
            <h2 class="section-title">
                Built for <span class="text-gradient">Local Businesses</span>
            </h2>
            <p class="section-subtitle">
                Whether you're a solo operator or a growing team, Lead Arbitrage
                is designed for businesses that rely on local clients walking
                through the door.
            </p>

            <div class="niches-grid">
                <div class="glass-card niche-card">
                    <span class="niche-icon">💇‍♀️</span><span class="niche-label"
                        >Hair Salons</span
                    >
                </div>
                <div class="glass-card niche-card">
                    <span class="niche-icon">💈</span><span class="niche-label"
                        >Barbershops</span
                    >
                </div>
                <div class="glass-card niche-card">
                    <span class="niche-icon">💅</span><span class="niche-label"
                        >Nail Salons</span
                    >
                </div>
                <div class="glass-card niche-card">
                    <span class="niche-icon">🧖‍♀️</span><span class="niche-label"
                        >Spas & Wellness</span
                    >
                </div>
                <div class="glass-card niche-card">
                    <span class="niche-icon">🚗</span><span class="niche-label"
                        >Auto Shops</span
                    >
                </div>
                <div class="glass-card niche-card">
                    <span class="niche-icon">🔧</span><span class="niche-label"
                        >Auto Detailing</span
                    >
                </div>
                <div class="glass-card niche-card">
                    <span class="niche-icon">🏋️</span><span class="niche-label"
                        >Gyms & Fitness</span
                    >
