---
import BaseLayout from '../layouts/BaseLayout.astro';

const TREASURY_SAFE = "0x9BeBF2c780D5ac632c11984E28fA9760D33a10e6";
const TOKEN_CONTRACT = "0xacb4543f479ea44e6df4fa01e483bb5b78361ba3";
const GECKO_POOL = "0xc12fb6d8757ae63623c4e9478fcd194a7e89ed97bbd88ceeb1a68fd1ab9c3e0d";

// Mock data for now - will be replaced with real API calls
const mockRevenueData = {
  totalRevenue: 0,
  monthlyRevenue: 0,
  dailyRevenue: 0,
  revenueStreams: [
    { name: "B2B Services", amount: 0, color: "#00d4ff" },
    { name: "Aleister API", amount: 0, color: "#7c3aed" },
    { name: "Digital Products", amount: 0, color: "#f472b6" },
    { name: "Cloning Royalties", amount: 0, color: "#4ade80" },
    { name: "FundlyHub SaaS", amount: 0, color: "#facc15" },
    { name: "Consulting", amount: 0, color: "#60a5fa" }
  ]
};

const mockTreasuryData = {
  totalValue: 0,
  tokenBalance: 0,
  ethBalance: 0,
  usdcBalance: 0,
  tokens: [
    { symbol: "ALEISTER", balance: 0, value: 0, change24h: 0 },
    { symbol: "ETH", balance: 0, value: 0, change24h: 0 },
    { symbol: "USDC", balance: 0, value: 0, change24h: 0 }
  ]
};
---

<BaseLayout
  title="$ALEISTER · Dashboard"
  description="Real-time revenue and treasury dashboard for $ALEISTER. Track earnings, token holdings, and growth metrics."
  image="/og-dashboard.png"
>
  <div class="dashboard-page">
    <div class="container">

      <!-- ── Zone 1: Hero + Stats ── -->
      <div class="dashboard-hero">
        <div class="dashboard-hero__text">
          <p class="dashboard-chain">Base Mainnet · Live Dashboard</p>
          <h1 class="dashboard-title">Revenue & Treasury</h1>
          <p class="dashboard-desc">Real-time tracking of earnings and on-chain holdings. Updated every 60 seconds.</p>
        </div>
        <div class="dashboard-hero__stats">
          <div class="stat-card">
            <div class="stat-label">Total Revenue</div>
            <div class="stat-value" id="total-revenue">$0</div>
            <div class="stat-change" id="revenue-change">+0% this month</div>
          </div>
          <div class="stat-card">
            <div class="stat-label">Treasury Value</div>
            <div class="stat-value" id="treasury-value">$0</div>
            <div class="stat-change" id="treasury-change">+0% 24h</div>
          </div>
        </div>
      </div>

      <!-- ── Zone 2: Revenue Streams ── -->
      <div class="dashboard-section">
        <h2 class="section-title">Revenue Streams</h2>
        <div class="revenue-grid">
          {mockRevenueData.revenueStreams.map((stream, index) => (
            <div class="revenue-card" key={index}>
              <div class="revenue-card__header">
                <div class="revenue-dot" style={`background: ${stream.color}`}></div>
                <span class="revenue-name">{stream.name}</span>
              </div>
              <div class="revenue-amount">${stream.amount.toLocaleString()}</div>
              <div class="revenue-percentage">0%</div>
            </div>
          ))}
        </div>
      </div>

      <!-- ── Zone 3: Treasury Holdings ── -->
      <div class="dashboard-section">
        <h2 class="section-title">Treasury Holdings</h2>
        <div class="treasury-grid">
          {mockTreasuryData.tokens.map((token, index) => (
            <div class="treasury-card" key={index}>
              <div class="treasury-card__header">
                <div class="token-symbol">{token.symbol}</div>
                <div class={`token-change ${token.change24h >= 0 ? 'change-up' : 'change-down'}`}>
                  {token.change24h >= 0 ? '+' : ''}{token.change24h}%
                </div>
              </div>
              <div class="token-balance">{token.balance.toLocaleString()}</div>
              <div class="token-value">${token.value.toLocaleString()}</div>
            </div>
          ))}
        </div>
        <div class="treasury-address">
          <div class="address-label">Treasury Safe</div>
          <code class="address-value">{TREASURY_SAFE}</code>
          <div class="address-actions">
            <button class="copy-btn" data-copy={TREASURY_SAFE} aria-label="Copy treasury address">
              <span class="copy-icon">⎘</span>
              <span class="copy-text">Copy</span>
            </button>
            <a href={`https://basescan.org/address/${TREASURY_SAFE}`} target="_blank" rel="noopener" class="badge">
              BaseScan ↗
            </a>
          </div>
        </div>
      </div>

      <!-- ── Zone 4: Charts Placeholder ── -->
      <div class="dashboard-section">
        <h2 class="section-title">Revenue Growth</h2>
        <div class="chart-placeholder">
          <div class="chart-message">
            <div class="chart-icon">📈</div>
            <p>Revenue tracking will begin when first payment is received.</p>
            <p class="chart-sub">Connect Stripe to start tracking real earnings.</p>
          </div>
        </div>
      </div>

      <!-- ── Zone 5: Next Steps ── -->
      <div class="dashboard-section dashboard-section--muted">
        <h2 class="section-title">Next Steps</h2>
        <div class="steps-grid">
          <div class="step-card">
            <div class="step-number">1</div>
            <div class="step-content">
              <div class="step-title">Connect Stripe</div>
              <div class="step-desc">Enable payment processing for services and products.</div>
            </div>
          </div>
          <div class="step-card">
            <div class="step-number">2</div>
            <div class="step-content">
              <div class="step-title">Deploy Revenue API</div>
              <div class="step-desc">Backend service to track and aggregate earnings.</div>
            </div>
          </div>
          <div class="step-card">
            <div class="step-number">3</div>
            <div class="step-content">
              <div class="step-title">Enable Auto-Refresh</div>
              <div class="step-desc">Real-time updates from on-chain and payment data.</div>
            </div>
          </div>
        </div>
      </div>

      <!-- ── Disclaimer ── -->
      <div class="dashboard-disclaimer">
        This dashboard displays real-time data. Revenue figures update as payments are processed.
        Treasury values are fetched from on-chain sources and may have a slight delay.
      </div>

    </div>
  </div>
</BaseLayout>

<style>
  .dashboard-page {
    padding-top: 4rem;
    padding-bottom: 5rem;
    min-height: 100vh;
  }

  /* ──── Hero ──── */
  .dashboard-hero {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 2rem;
    margin-bottom: 2.5rem;
    padding-top: 1.5rem;
  }

  .dashboard-chain {
    font-size: 0.72rem;
    font-family: 'JetBrains Mono', monospace;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-tertiary);
    margin-bottom: 0.6rem;
  }

  .dashboard-title {
    font-size: clamp(2.5rem, 6vw, 3.5rem);
    font-weight: 900;
    line-height: 1.05;
    letter-spacing: -0.03em;
    margin-bottom: 0.75rem;
    background: var(--gradient-accent-text);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .dashboard-desc {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.6;
    max-width: 380px;
  }

  .dashboard-hero__stats {
    display: flex;
    gap: 1.5rem;
    flex-shrink: 0;
  }

  .stat-card {
    background: var(--bg-glass);
    border: 1px solid var(--border-glass);
    border-radius: 14px;
    padding: 1.25rem 1.5rem;
    min-width: 180px;
  }

  .stat-label {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--text-secondary);
    margin-bottom: 0.5rem;
  }

  .stat-value {
    font-size: 1.8rem;
    font-weight: 800;
    color: var(--text-primary);
    line-height: 1;
    margin-bottom: 0.25rem;
  }

  .stat-change {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--text-tertiary);
  }

  /* ──── Sections ──── */
  .dashboard-section {
    margin-bottom: 2.5rem;
  }

  .dashboard-section--muted {
    background: transparent;
    border: 1px dashed var(--border-subtle);
    border-radius: 14px;
    padding: 1.5rem;
  }

  .section-title {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-tertiary);
    margin-bottom: 1.25rem;
  }

  /* ──── Revenue Grid ──── */
  .revenue-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 1rem;
  }

  .revenue-card {
    background: var(--bg-glass);
    border: 1px solid var(--border-glass);
    border-radius: 12px;
    padding: 1.25rem;
    transition: all 0.2s ease;
  }

  .revenue-card:hover {
    border-color: var(--border-accent);
    transform: translateY(-2px);
  }

  .revenue-card__header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }

  .revenue-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .revenue-name {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text-secondary);
  }

  .revenue-amount {
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--text-primary);
    line-height: 1;
    margin-bottom: 0.25rem;
  }

  .revenue-percentage {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--text-tertiary);
  }

  /* ──── Treasury Grid ──── */
  .treasury-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .treasury-card {
    background: var(--bg-glass);
    border: 1px solid var(--border-glass);
    border-radius: 12px;
    padding: 1.25rem;
  }

  .treasury-card__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.75rem;
  }

  .token-symbol {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--text-primary);
  }

  .token-change {
    font-size: 0.75rem;
    font-weight: 700;
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
  }

  .change-up {
    background: color-mix(in srgb, #10b981 15%, transparent);
    color: #10b981;
  }

  .change-down {
    background: color-mix(in srgb, #ef4444 15%, transparent);
    color: #ef4444;
  }

  .token-balance {
    font-size: 1.25rem;
    font-weight: 800;
    color: var(--text-primary);
    line-height: 1;
    margin-bottom: 0.25rem;
  }

  .token-value {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text-secondary);
  }

  /* ──── Treasury Address ──── */
  .treasury-address {
    background: var(--bg-secondary);
    border: 1px solid var(--border-subtle);
    border-radius: 12px;
    padding: 1.25rem;
  }

  .address-label {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--text-secondary);
    margin-bottom: 0.5rem;
  }

  .address-value {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.78rem;
    color: var(--text-primary);
    word-break: break-all;
    line-height: 1.6;
    margin-bottom: 0.75rem;
    display: block;
  }

  .address-actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  /* ──── Copy Button ──── */
  .copy-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.3rem 0.7rem;
    border-radius: 6px;
    font-size: 0.75rem;
    font-weight: 600;
    background: var(--bg-glass);
    border: 1px solid var(--border-glass);
    color: var(--text-secondary);
    cursor: pointer;
    transition: all 0.15s ease;
  }

  .copy-btn:hover {
    border-color: var(--text-accent);
    color: var(--text-accent);
  }

  .copy-btn.copied {
    border-color: #059669;
    color: #059669;
    background: color-mix(in srgb, #059669 10%, transparent);
  }

  /* ──── Badge ──── */
  .badge {
    display: inline-flex;
    align-items: center;
    padding: 0.3rem 0.7rem;
    border-radius: 6px;
    font-size: 0.75rem;
    font-weight: 600;
    background: color-mix(in srgb, var(--text-accent) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--text-accent) 20%, transparent);
    color: var(--text-accent);
    text-decoration: none;
    transition: all 0.15s ease;
    white-space: nowrap;
  }

  .badge:hover {
    background: color-mix(in srgb, var(--text-accent) 18%, transparent);
  }

  /* ──── Chart Placeholder ──── */
  .chart-placeholder {
    background: var(--bg-glass);
    border: 1px dashed var(--border-glass);
    border-radius: 14px;
    padding: 3rem 2rem;
    text-align: center;
  }

  .chart-message {
    max-width: 400px;
    margin: 0 auto;
  }

  .chart-icon {
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }

  .chart-message p {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: 0.5rem;
  }

  .chart-sub {
    font-size: 0.8rem;
    color: var(--text-tertiary);
  }

  /* ──── Steps Grid ──── */
  .steps-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: 1rem;
  }

  .step-card {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .step-number {
    width: 32px;
    height: 32px;
    border-radius: 8px;
    background: var(--gradient-accent);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.9rem;
    font-weight: 800;
    flex-shrink: 0;
  }

  .step-content {
    flex: 1;
  }

  .step-title {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 0.25rem;
  }

  .step-desc {
    font-size: 0.8rem;
    color: var(--text-secondary);
    line-height: 1.5;
  }

  /* ──── Disclaimer ──── */
  .dashboard-disclaimer {
    margin-top: 2rem;
    font-size: 0.75rem;
    color: var(--text-tertiary);
    line-height: 1.65;
    border-left: 2px solid var(--border-subtle);
    padding-left: 1rem;
  }

  /* ──── Responsive ──── */
  @media (max-width: 768px) {
    .dashboard-hero {
      flex-direction: column;
      align-items: flex-start;
    }

    .dashboard-hero__stats {
      width: 100%;
      flex-direction: column;
    }

    .stat-card {
      width: 100%;
    }

    .revenue-grid,
    .treasury-grid,
    .steps-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 480px) {
    .dashboard-title {
      font-size: 2rem;
    }

    .stat-value {
      font-size: 1.5rem;
    }
  }
</style>

<script>
  // Copy to clipboard functionality
  document.querySelectorAll('.copy-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const text = btn.dataset.copy ?? '';
      try {
        await navigator.clipboard.writeText(text);
        const textEl = btn.querySelector('.copy-text');
        if (textEl) {
          btn.classList.add('copied');
          textEl.textContent = 'Copied!';
          setTimeout(() => {
            btn.classList.remove('copied');
            textEl.textContent = 'Copy';
          }, 2000);
        }
      } catch {
        // fallback
        const textarea = document.createElement('textarea');
        textarea.value = text;
        document.body.appendChild(textarea);
        textarea.select();
        document.execCommand('copy');
        document.body.removeChild(textarea);
        
        const textEl = btn.querySelector('.copy-text');
        if (textEl) {
          btn.classList.add('copied');
          textEl.textContent = 'Copied!';
          setTimeout(() => {
            btn.classList.remove('copied');
            textEl.textContent = 'Copy';
          }, 2000);
        }
      }
    });
  });

  // Auto-refresh data every 60 seconds
  let refreshInterval;
  
  function refreshData() {
    console.log('Refreshing dashboard data...');
    // TODO: Implement real API calls
    // For now, just update timestamps
    const now = new Date();
    document.querySelectorAll('.stat-change').forEach(el => {
      if (el.id === 'revenue-change') {
        el.textContent = `Last updated: ${now.toLocaleTimeString()}`;
      }
    });
  }

  // Start auto-refresh
  document.addEventListener('DOMContentLoaded', () => {
    refreshData();
    refreshInterval = setInterval(refreshData, 60000); // 60 seconds
    
    // Cleanup on page unload
    window.addEventListener('beforeunload', () => {
      clearInterval(refreshInterval);
    });
  });
</script>