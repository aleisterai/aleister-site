---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";

const TREASURY_SAFE = "0x9BeBF2c780D5ac632c11984E28fA9760D33a10e6";
const TOKEN_CONTRACT = "0xacb4543f479ea44e6df4fa01e483bb5b78361ba3";
const BURN_ADDRESS = "0x000000000000000000000000000000000000dEaD";

// Claw Mart earnings - will be fetched from API
const CLAW_MART_EARNINGS = 89;
---

<BaseLayout
  title="$ALEISTER · Dashboard"
  description="Real-time revenue and treasury dashboard for $ALEISTER. Track earnings, token holdings, and growth metrics."
  image="/api/og/dashboard"
>
  <div class="dashboard-page">
    <div class="container">
      <!-- ── Hero ── -->
      <div class="dashboard-hero">
        <div class="dashboard-hero__text">
          <PageHeader
            accent="Dashboard"
            subtitle="All-time revenue, revenue streams, and on-chain treasury. Auto-refreshes every 60 seconds."
          >
            <p class="dashboard-chain">
              Base Mainnet · Live <span class="live-dot-inline"
                ><span></span>
              </span>
            </p>
          </PageHeader>
        </div>
        <div class="dashboard-hero__stats">
          <div class="stat-card stat-card--accent">
            <div class="stat-label">
              All-Time Revenue <span class="live-dot-inline"
                ><span></span>
              </span>
            </div>
            <div class="stat-value" id="all-time-revenue">—</div>
            <div class="stat-change" id="all-time-change">Aggregating...</div>
          </div>
        </div>
      </div>

      <!-- ── Revenue Streams ── -->
      <div class="dashboard-section">
        <h2 class="section-title">
          Revenue Streams <a
            href="https://trustmrr.com/founder/aleisterai"
            target="_blank"
            rel="noopener"
            class="section-title__link">TrustMRR ↗</a
          >
        </h2>
        <div class="revenue-grid">
          <a
            class="revenue-card"
            id="rev-clawmart"
            href="https://www.shopclawmart.com/creators/4cf39e00-fa5f-4ac1-9187-e75b55c77c11"
            target="_blank"
            rel="noopener"
          >
            <div class="revenue-card__body">
              <div class="revenue-card__name">Claw Mart</div>
              <div class="revenue-card__amount" id="clawmart-earnings">
                $89.00
              </div>
              <div class="revenue-card__sub" id="clawmart-sub">
                Product sales
              </div>
            </div>
          </a>
          <a class="revenue-card" id="rev-store" href="/store">
            <div class="revenue-card__body">
              <div class="revenue-card__name">
                Aleister Store <span class="live-dot-inline"
                  ><span></span>
                </span>
              </div>
              <div class="revenue-card__amount" id="store-revenue">—</div>
              <div class="revenue-card__sub" id="store-sub">
                Loading from Stripe...
              </div>
            </div>
          </a>
          <a
            class="revenue-card"
            id="rev-fundlyhub"
            href="https://fundlyhub.org"
            target="_blank"
            rel="noopener"
          >
            <div class="revenue-card__body">
              <div class="revenue-card__name">
                FundlyHub <span class="live-dot-inline"><span></span></span>
              </div>
              <div class="revenue-card__amount" id="fundlyhub-revenue">—</div>
              <div class="revenue-card__sub" id="fundlyhub-sub">
                Loading from Stripe...
              </div>
            </div>
          </a>
          <div class="revenue-card" id="rev-token">
            <div class="revenue-card__body">
              <div class="revenue-card__name">Token Fees</div>
              <div class="revenue-card__amount" id="token-fees">$0.00</div>
            </div>
          </div>
        </div>
      </div>

      <!-- ── Treasury Holdings ── -->
      <div class="dashboard-section">
        <h2 class="section-title">Treasury Holdings</h2>
        <div class="treasury-grid">
          <div class="treasury-card" data-token="ETH">
            <div class="treasury-card__header">
              <div class="token-symbol">ETH</div>
              <div class="token-change change-up">+0%</div>
            </div>
            <div class="token-balance">0</div>
            <div class="token-value">$0</div>
          </div>
          <div class="treasury-card" data-token="$ALEISTER">
            <div class="treasury-card__header">
              <div class="token-symbol">$ALEISTER</div>
              <div class="token-change change-up">+0%</div>
            </div>
            <div class="token-balance">0</div>
            <div class="token-value">$0</div>
          </div>
          <div class="treasury-card" data-token="USDC">
            <div class="treasury-card__header">
              <div class="token-symbol">USDC</div>
              <div class="token-change change-up">+0%</div>
            </div>
            <div class="token-balance">0</div>
            <div class="token-value">$0</div>
          </div>
        </div>
        <div class="treasury-address">
          <div class="address-label">Treasury Safe</div>
          <code class="address-value">{TREASURY_SAFE}</code>
          <div class="address-actions">
            <button
              class="copy-btn"
              data-copy={TREASURY_SAFE}
              aria-label="Copy treasury address"
            >
              <span class="copy-icon">⎘</span>
              <span class="copy-text">Copy</span>
            </button>
            <a
              href={`https://basescan.org/address/${TREASURY_SAFE}`}
              target="_blank"
              rel="noopener"
              class="badge"
            >
              BaseScan ↗
            </a>
          </div>
        </div>
      </div>

      <!-- ── Token Burn ── -->
      <div class="dashboard-section">
        <h2 class="section-title">
          Token Burn
          <a
            href={`https://basescan.org/token/${TOKEN_CONTRACT}?a=${BURN_ADDRESS}`}
            target="_blank"
            rel="noopener"
            class="section-title__link">BaseScan ↗</a
          >
        </h2>
        <div class="burn-card">
          <div class="burn-card__icon">🔥</div>
          <div class="burn-card__body">
            <div class="burn-card__label">
              $ALEISTER Burned Forever <span class="live-dot-inline"><span></span></span>
            </div>
            <div class="burn-card__amount" id="burn-amount">—</div>
            <div class="burn-card__sub" id="burn-sub">Loading from chain...</div>
          </div>
          <div class="burn-card__usd" id="burn-usd"></div>
        </div>
        <div class="burn-address">
          <div class="address-label">Burn Address</div>
          <code class="address-value">{BURN_ADDRESS}</code>
          <div class="address-actions">
            <button
              class="copy-btn"
              data-copy={BURN_ADDRESS}
              aria-label="Copy burn address"
            >
              <span class="copy-icon">⎘</span>
              <span class="copy-text">Copy</span>
            </button>
            <a
              href={`https://basescan.org/address/${BURN_ADDRESS}`}
              target="_blank"
              rel="noopener"
              class="badge"
            >
              BaseScan ↗
            </a>
          </div>
        </div>
      </div>

      <!-- ── Buybacks ── -->
      <div class="dashboard-section">
        <h2 class="section-title">
          Buybacks
          <a
            href={`https://basescan.org/address/${TREASURY_SAFE}`}
            target="_blank"
            rel="noopener"
            class="section-title__link">Safe Wallet ↗</a
          >
        </h2>
        <div class="buyback-list">
          <a
            class="buyback-card"
            href="https://basescan.org/tx/0x0cd39b0bb2d752bafef290a759bb8bce1e5b5b34948bdeac8e76f349835bbc39"
            target="_blank"
            rel="noopener"
          >
            <div class="buyback-card__icon">💎</div>
            <div class="buyback-card__body">
              <div class="buyback-card__pair">WETH → $ALEISTER</div>
              <div class="buyback-card__meta">
                <span id="buyback-weth-0">Loading...</span> · Executed via Safe Wallet
              </div>
            </div>
            <div class="buyback-card__tx">
              <span class="buyback-card__usd" id="buyback-usd-0"></span>
              <code class="buyback-card__hash">0x0cd3…bc39</code>
              <span class="buyback-card__link">BaseScan ↗</span>
            </div>
          </a>
        </div>
      </div>

      <!-- ── Disclaimer ── -->
      <div class="dashboard-disclaimer">
        This dashboard displays real-time data. Revenue figures update as
        payments are processed. Treasury values are fetched from on-chain
        sources and may have a slight delay.
      </div>
    </div>
  </div>

  <style>
    .dashboard-page {
      padding-top: 3rem;
      padding-bottom: 5rem;
      min-height: 100vh;
    }

    /* ──── Hero ──── */
    .dashboard-hero {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      gap: 2rem;
      margin-bottom: 2.5rem;
    }

    .dashboard-chain {
      font-size: 0.72rem;
      font-family: "JetBrains Mono", monospace;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--text-tertiary);
      margin-bottom: 0.6rem;
    }

    .dashboard-hero__stats {
      display: flex;
      gap: 1.5rem;
      flex-shrink: 0;
      align-items: flex-end;
    }

    .refresh-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.7rem 1.25rem;
      border-radius: 10px;
      font-size: 0.88rem;
      font-weight: 700;
      background: var(--bg-glass);
      border: 1px solid var(--border-glass);
      color: var(--text-primary);
      cursor: pointer;
      transition: all 0.2s ease;
      height: fit-content;
      margin-bottom: 0.1rem;
    }

    .refresh-btn:hover:not(:disabled) {
      border-color: var(--text-accent);
      background: color-mix(in srgb, var(--text-accent) 8%, var(--bg-glass));
      transform: translateY(-1px);
    }

    .refresh-btn:disabled {
      opacity: 0.5;
      cursor: not-allowed;
    }

    .refresh-btn svg {
      transition: transform 0.3s ease;
    }

    .refresh-btn:active:not(:disabled) svg {
      transform: rotate(180deg);
    }

    .stat-card {
      background: var(--bg-glass);
      border: 1px solid var(--border-glass);
      border-radius: 14px;
      padding: 1.25rem 1.5rem;
      min-width: 180px;
    }

    .stat-label {
      font-size: 0.8rem;
      font-weight: 600;
      color: var(--text-secondary);
      margin-bottom: 0.5rem;
    }

    .stat-value {
      font-size: 1.8rem;
      font-weight: 800;
      color: var(--text-primary);
      line-height: 1;
      margin-bottom: 0.25rem;
    }

    .stat-change {
      font-size: 0.75rem;
      font-weight: 600;
      color: var(--text-tertiary);
    }

    .stat-change.change-up {
      color: #10b981;
    }

    .stat-change.change-down {
      color: #ef4444;
    }

    .stat-card--accent {
      border-color: color-mix(in srgb, #10b981 30%, var(--border-glass));
      background: color-mix(in srgb, #10b981 5%, var(--bg-glass));
    }

    /* ──── Sections ──── */
    .dashboard-section {
      margin-bottom: 2.5rem;
    }

    .dashboard-section--muted {
      background: transparent;
      border: 1px dashed var(--border-subtle);
      border-radius: 14px;
      padding: 1.5rem;
    }

    .section-title {
      font-size: 0.7rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--text-tertiary);
      margin-bottom: 1.25rem;
      text-align: left;
    }

    .section-title__link {
      font-size: 0.65rem;
      font-weight: 500;
      color: var(--accent, #6c5ce7);
      text-decoration: none;
      opacity: 0.7;
      margin-left: 0.5rem;
      transition: opacity 0.2s;
    }

    .section-title__link:hover {
      opacity: 1;
      text-decoration: underline;
    }

    /* ──── Revenue Grid ──── */
    .revenue-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
      gap: 1rem;
    }

    .revenue-card {
      display: flex;
      gap: 1rem;
      align-items: flex-start;
      background: var(--bg-glass);
      border: 1px solid var(--border-glass);
      border-radius: 12px;
      padding: 1.25rem;
      transition: border-color 0.2s ease;
      text-decoration: none;
      color: inherit;
      cursor: pointer;
    }

    .revenue-card:hover {
      border-color: var(--border-subtle);
    }

    .revenue-card__icon {
      font-size: 1.6rem;
      line-height: 1;
      flex-shrink: 0;
      padding-top: 0.1rem;
    }

    .revenue-card__body {
      flex: 1;
      min-width: 0;
    }

    .revenue-card__name {
      font-size: 0.78rem;
      font-weight: 600;
      color: var(--text-secondary);
      margin-bottom: 0.35rem;
    }

    .revenue-card__amount {
      font-size: 1.4rem;
      font-weight: 800;
      color: var(--text-primary);
      line-height: 1;
      margin-bottom: 0.25rem;
    }

    .revenue-card__sub {
      font-size: 0.7rem;
      color: var(--text-tertiary);
      font-style: italic;
    }

    .revenue-card__sales {
      display: flex;
      gap: 0.4rem;
      margin-top: 0.5rem;
      flex-wrap: wrap;
    }

    .sale-pill {
      display: inline-flex;
      align-items: center;
      gap: 0.25rem;
      font-size: 0.7rem;
      padding: 0.15rem 0.5rem;
      border-radius: 99px;
      background: var(--bg-glass);
      border: 1px solid var(--border-glass);
      color: var(--text-secondary);
      white-space: nowrap;
    }

    .sale-pill b {
      font-weight: 700;
      color: var(--text-primary);
    }

    /* ──── Treasury Grid ──── */
    .treasury-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
      gap: 1rem;
      margin-bottom: 1.5rem;
    }

    .treasury-card {
      background: var(--bg-glass);
      border: 1px solid var(--border-glass);
      border-radius: 12px;
      padding: 1.25rem;
    }

    .treasury-card__header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 0.75rem;
    }

    .token-symbol {
      font-size: 0.9rem;
      font-weight: 700;
      color: var(--text-primary);
    }

    .token-change {
      font-size: 0.75rem;
      font-weight: 700;
      padding: 0.2rem 0.5rem;
      border-radius: 4px;
    }

    .change-up {
      background: color-mix(in srgb, #10b981 15%, transparent);
      color: #10b981;
    }

    .change-down {
      background: color-mix(in srgb, #ef4444 15%, transparent);
      color: #ef4444;
    }

    .token-balance {
      font-size: 1.25rem;
      font-weight: 800;
      color: var(--text-primary);
      line-height: 1;
      margin-bottom: 0.25rem;
    }

    .token-value {
      font-size: 0.85rem;
      font-weight: 600;
      color: var(--text-secondary);
    }

    .token-breakdown {
      font-size: 0.7rem;
      color: var(--text-tertiary);
      margin-top: 0.25rem;
      font-style: italic;
    }

    /* ──── Treasury Address ──── */
    .treasury-address {
      background: var(--bg-secondary);
      border: 1px solid var(--border-subtle);
      border-radius: 12px;
      padding: 1.25rem;
    }

    .address-label {
      font-size: 0.8rem;
      font-weight: 600;
      color: var(--text-secondary);
      margin-bottom: 0.5rem;
    }

    .address-value {
      font-family: "JetBrains Mono", monospace;
      font-size: 0.78rem;
      color: var(--text-primary);
      word-break: break-all;
      line-height: 1.6;
      margin-bottom: 0.75rem;
      display: block;
    }

    .address-actions {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      flex-wrap: wrap;
    }

    /* ──── Copy Button ──── */
    .copy-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.3rem;
      padding: 0.3rem 0.7rem;
      border-radius: 6px;
      font-size: 0.75rem;
      font-weight: 600;
      background: var(--bg-glass);
      border: 1px solid var(--border-glass);
      color: var(--text-secondary);
      cursor: pointer;
      transition: all 0.15s ease;
    }

    .copy-btn:hover {
      border-color: var(--text-accent);
      color: var(--text-accent);
    }

    .copy-btn.copied {
      border-color: #059669;
      color: #059669;
      background: color-mix(in srgb, #059669 10%, transparent);
    }

    /* ──── Badge ──── */
    .badge {
      display: inline-flex;
      align-items: center;
      padding: 0.3rem 0.7rem;
      border-radius: 6px;
      font-size: 0.75rem;
      font-weight: 600;
      background: color-mix(in srgb, var(--text-accent) 10%, transparent);
      border: 1px solid color-mix(in srgb, var(--text-accent) 20%, transparent);
      color: var(--text-accent);
      text-decoration: none;
      transition: all 0.15s ease;
      white-space: nowrap;
    }

    .badge:hover {
      background: color-mix(in srgb, var(--text-accent) 18%, transparent);
    }

    /* ──── Live Dot ──── */
    .live-dot {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 20px;
      height: 20px;
    }

    .live-dot span {
      display: block;
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: #10b981;
      box-shadow: 0 0 6px rgba(16, 185, 129, 0.5);
      animation: pulse-dot 2s ease-in-out infinite;
    }

    @keyframes pulse-dot {
      0%,
      100% {
        opacity: 1;
        box-shadow: 0 0 4px rgba(16, 185, 129, 0.4);
      }
      50% {
        opacity: 0.5;
        box-shadow: 0 0 10px rgba(16, 185, 129, 0.7);
      }
    }

    .live-dot-inline {
      display: inline-flex;
      align-items: center;
      margin-left: 0.35rem;
      vertical-align: middle;
    }

    .live-dot-inline span {
      display: block;
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: #10b981;
      box-shadow: 0 0 4px rgba(16, 185, 129, 0.5);
      animation: pulse-dot 2s ease-in-out infinite;
    }

    /* ──── Burn Card ──── */
    .burn-card {
      display: flex;
      gap: 1.25rem;
      align-items: center;
      background: var(--bg-glass);
      border: 1px solid color-mix(in srgb, #f97316 25%, var(--border-glass));
      border-radius: 14px;
      padding: 1.5rem;
      margin-bottom: 1.25rem;
      position: relative;
      overflow: hidden;
    }

    .burn-card::before {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg, color-mix(in srgb, #f97316 6%, transparent), transparent 60%);
      pointer-events: none;
    }

    .burn-card__icon {
      font-size: 2.2rem;
      line-height: 1;
      flex-shrink: 0;
      animation: burn-pulse 2.5s ease-in-out infinite;
    }

    @keyframes burn-pulse {
      0%, 100% { transform: scale(1); opacity: 1; }
      50% { transform: scale(1.12); opacity: 0.85; }
    }

    .burn-card__body {
      flex: 1;
      min-width: 0;
    }

    .burn-card__label {
      font-size: 0.78rem;
      font-weight: 600;
      color: var(--text-secondary);
      margin-bottom: 0.4rem;
    }

    .burn-card__amount {
      font-size: 1.8rem;
      font-weight: 800;
      color: var(--text-primary);
      line-height: 1;
      margin-bottom: 0.25rem;
    }

    .burn-card__sub {
      font-size: 0.72rem;
      color: var(--text-tertiary);
      font-style: italic;
    }

    .burn-card__usd {
      font-size: 1.1rem;
      font-weight: 700;
      color: #f97316;
      white-space: nowrap;
      flex-shrink: 0;
    }

    .burn-address {
      background: var(--bg-secondary);
      border: 1px solid var(--border-subtle);
      border-radius: 12px;
      padding: 1.25rem;
    }

    /* ──── Buyback Cards ──── */
    .buyback-list {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }

    .buyback-card {
      display: flex;
      gap: 1rem;
      align-items: center;
      background: var(--bg-glass);
      border: 1px solid color-mix(in srgb, #6c5ce7 20%, var(--border-glass));
      border-radius: 12px;
      padding: 1.25rem;
      text-decoration: none;
      color: inherit;
      transition: border-color 0.2s ease, transform 0.15s ease;
    }

    .buyback-card:hover {
      border-color: color-mix(in srgb, #6c5ce7 40%, var(--border-glass));
      transform: translateY(-1px);
    }

    .buyback-card__icon {
      font-size: 1.8rem;
      line-height: 1;
      flex-shrink: 0;
    }

    .buyback-card__body {
      flex: 1;
      min-width: 0;
    }

    .buyback-card__pair {
      font-size: 0.95rem;
      font-weight: 700;
      color: var(--text-primary);
      margin-bottom: 0.2rem;
    }

    .buyback-card__meta {
      font-size: 0.72rem;
      color: var(--text-tertiary);
      font-style: italic;
    }

    .buyback-card__tx {
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      gap: 0.25rem;
      flex-shrink: 0;
    }

    .buyback-card__hash {
      font-family: "JetBrains Mono", monospace;
      font-size: 0.7rem;
      color: var(--text-secondary);
      background: var(--bg-secondary);
      padding: 0.2rem 0.5rem;
      border-radius: 4px;
    }

    .buyback-card__link {
      font-size: 0.68rem;
      font-weight: 600;
      color: var(--accent, #6c5ce7);
      opacity: 0.7;
      transition: opacity 0.2s;
    }

    .buyback-card:hover .buyback-card__link {
      opacity: 1;
    }

    .buyback-card__usd {
      font-size: 0.85rem;
      font-weight: 700;
      color: #6c5ce7;
      white-space: nowrap;
    }

    @media (max-width: 480px) {
      .buyback-card {
        flex-wrap: wrap;
      }
      .buyback-card__tx {
        width: 100%;
        flex-direction: row;
        justify-content: space-between;
        align-items: center;
        margin-top: 0.5rem;
        padding-top: 0.5rem;
        border-top: 1px solid var(--border-glass);
      }
    }

    /* ──── Disclaimer ──── */
    .dashboard-disclaimer {
      margin-top: 2rem;
      font-size: 0.75rem;
      color: var(--text-tertiary);
      line-height: 1.65;
      border-left: 2px solid var(--border-subtle);
      padding-left: 1rem;
    }

    /* ──── Responsive ──── */
    @media (max-width: 768px) {
      .dashboard-hero {
        flex-direction: column;
        align-items: flex-start;
      }

      .dashboard-hero__stats {
        width: 100%;
        flex-direction: column;
      }

      .stat-card {
        width: 100%;
      }

      .revenue-grid,
      .treasury-grid,
      .steps-grid {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 480px) {
      .page-header__title {
        font-size: 2rem;
      }

      .stat-value {
        font-size: 1.5rem;
      }
    }
  </style>

  <script>
    // Copy to clipboard functionality
    document.querySelectorAll(".copy-btn").forEach((btn) => {
      btn.addEventListener("click", async () => {
        const text = btn.dataset.copy ?? "";
        try {
          await navigator.clipboard.writeText(text);
          const textEl = btn.querySelector(".copy-text");
          if (textEl) {
            btn.classList.add("copied");
            textEl.textContent = "Copied!";
            setTimeout(() => {
              btn.classList.remove("copied");
              textEl.textContent = "Copy";
            }, 2000);
          }
        } catch {
          // fallback
          const textarea = document.createElement("textarea");
          textarea.value = text;
          document.body.appendChild(textarea);
          textarea.select();
          document.execCommand("copy");
          document.body.removeChild(textarea);

          const textEl = btn.querySelector(".copy-text");
          if (textEl) {
            btn.classList.add("copied");
            textEl.textContent = "Copied!";
            setTimeout(() => {
              btn.classList.remove("copied");
              textEl.textContent = "Copy";
            }, 2000);
          }
        }
      });
    });

    // Configuration
    const TREASURY_SAFE = "0x9BeBF2c780D5ac632c11984E28fA9760D33a10e6";

    // State
    let refreshInterval;
    let isLoading = false;

    // Format numbers
    function formatCurrency(amount) {
      if (amount >= 1e6) return `$${(amount / 1e6).toFixed(2)}M`;
      if (amount >= 1e3) return `$${(amount / 1e3).toFixed(1)}K`;
      return `$${amount.toFixed(2)}`;
    }

    function formatNumber(num, decimals = 2) {
      if (num >= 1e6) return (num / 1e6).toFixed(decimals) + "M";
      if (num >= 1e3) return (num / 1e3).toFixed(decimals) + "K";
      return num.toFixed(decimals);
    }

    // Fetch token prices from our server endpoint
    async function fetchTokenPrices() {
      try {
        const response = await fetch("/api/token-prices.json");
        const data = await response.json();
        return {
          aleister: {
            price: data.aleister?.usd || 0,
            change24h: data.aleister?.usd_24h_change || 0,
          },
          ethereum: {
            price: data.ethereum?.usd || 0,
            change24h: data.ethereum?.usd_24h_change || 0,
          },
          "usd-coin": {
            price: data["usd-coin"]?.usd || 1,
            change24h: data["usd-coin"]?.usd_24h_change || 0,
          },
        };
      } catch (error) {
        console.error("Error fetching token prices:", error);
        return {
          aleister: { price: 0, change24h: 0 },
          ethereum: { price: 0, change24h: 0 },
          "usd-coin": { price: 1, change24h: 0 },
        };
      }
    }

    // Fetch treasury balances from our server endpoint
    async function fetchTreasuryBalances() {
      try {
        const response = await fetch("/api/treasury-balances.json");
        const data = await response.json();
        return data;
      } catch (error) {
        console.error("Error fetching treasury balances:", error);
        return {
          success: false,
          balances: [
            { symbol: "ETH", balance: 0 },
            { symbol: "ALEISTER", balance: 0 },
            { symbol: "USDC", balance: 0 },
          ],
        };
      }
    }

    // Fetch all treasury data
    async function fetchTreasuryData() {
      isLoading = true;
      updateLoadingState(true);

      try {
        const [balancesData, pricesData] = await Promise.all([
          fetchTreasuryBalances(),
          fetchTokenPrices(),
        ]);

        const treasuryData = {
          tokens: [],
          totalValue: 0,
        };

        // Process each token
        balancesData.balances.forEach((tokenBalance) => {
          const symbol = tokenBalance.symbol;
          const balance = tokenBalance.balance;

          let priceData;
          switch (symbol) {
            case "$ALEISTER":
              priceData = pricesData.aleister;
              break;
            case "ETH": // Combined ETH + WETH
              priceData = pricesData.ethereum;
              break;
            case "USDC":
              priceData = pricesData["usd-coin"];
              break;
            default:
              priceData = { price: 0, change24h: 0 };
          }

          const value = balance * priceData.price;
          treasuryData.totalValue += value;

          treasuryData.tokens.push({
            symbol,
            balance,
            value,
            change24h: priceData.change24h,
            breakdown: tokenBalance.breakdown,
          });
        });

        return treasuryData;
      } catch (error) {
        console.error("Error fetching treasury data:", error);
        return {
          tokens: [
            {
              symbol: "ETH",
              balance: 0,
              value: 0,
              change24h: 0,
              breakdown: { native: 0, wrapped: 0 },
            },
            {
              symbol: "$ALEISTER",
              balance: 0,
              value: 0,
              change24h: 0,
            },
            {
              symbol: "USDC",
              balance: 0,
              value: 0,
              change24h: 0,
            },
          ],
          totalValue: 0,
        };
      } finally {
        isLoading = false;
        updateLoadingState(false);
      }
    }

    // Fetch Claw Mart earnings (hardcoded for now, will integrate API later)
    async function fetchClawMartEarnings() {
      // TODO: Integrate with Claw Mart API
      // For now, return hardcoded value as mentioned
      return {
        totalEarnings: 89.0,
        currency: "USD",
        lastUpdated: new Date().toISOString(),
        topSkills: [
          { skill: "Twitter Engagement", earnings: 45.0 },
          { skill: "Research Assistant", earnings: 25.0 },
          { skill: "Code Review", earnings: 19.0 },
        ],
      };
    }

    // Update UI with data
    function updateUI(treasuryData, clawMartData) {
      // Update token cards
      treasuryData.tokens.forEach((token) => {
        const card = document.querySelector(
          `.treasury-card[data-token="${token.symbol}"]`
        );
        if (card) {
          const changeEl = card.querySelector(".token-change");
          const balanceEl = card.querySelector(".token-balance");
          const valueEl = card.querySelector(".token-value");

          if (changeEl) {
            changeEl.textContent = `${
              token.change24h >= 0 ? "+" : ""
            }${token.change24h.toFixed(1)}%`;
            changeEl.className = `token-change ${
              token.change24h >= 0 ? "change-up" : "change-down"
            }`;
          }
          if (balanceEl) balanceEl.textContent = formatNumber(token.balance, 2);
          if (valueEl) valueEl.textContent = formatCurrency(token.value);
        }
      });

      // Store treasury total for all-time calc
      window.__treasuryValue = treasuryData.totalValue || 0;

      // Token Fees = total USD value of treasury holdings + burned tokens
      const burnValue = window.__burnValue || 0;
      const tokenFeesTotal = (treasuryData.totalValue || 0) + burnValue;
      const tokenFeesEl = document.getElementById("token-fees");
      if (tokenFeesEl) tokenFeesEl.textContent = formatCurrency(tokenFeesTotal);
      window.__tokenFeesRevenue = tokenFeesTotal;

      // Update Claw Mart revenue card
      if (clawMartData && clawMartData.totalEarnings > 0) {
        const earningsEl = document.getElementById("clawmart-earnings");
        const subEl = document.getElementById("clawmart-sub");
        if (earningsEl)
          earningsEl.textContent = `$${clawMartData.totalEarnings.toFixed(2)}`;
        if (subEl) subEl.textContent = "Product sales";
        window.__clawmartRevenue = clawMartData.totalEarnings;
      }

      // Update all-time revenue
      updateAllTimeRevenue();
    }

    // Aggregate all revenue streams + treasury into hero card
    function updateAllTimeRevenue() {
      const clawmart = window.__clawmartRevenue || 89;
      const store = window.__storeRevenue || 0;
      const fundlyhub = window.__fundlyhubRevenue || 0;
      const tokenFees = window.__tokenFeesRevenue || 0;
      const buybacks = window.__buybackRevenue || 0;
      const total = clawmart + store + fundlyhub + tokenFees + buybacks;

      const el = document.getElementById("all-time-revenue");
      const changeEl = document.getElementById("all-time-change");
      if (el) el.textContent = formatCurrency(total);
      if (changeEl) {
        changeEl.textContent = "5 revenue streams";
        changeEl.className = "stat-change change-up";
      }
    }

    // Update loading state
    function updateLoadingState(loading) {
      const loadingIndicator = document.getElementById("loading-indicator");
      if (loadingIndicator) {
        loadingIndicator.style.display = loading ? "block" : "none";
      }
      const refreshBtn = document.getElementById("refresh-btn");
      if (refreshBtn) refreshBtn.disabled = loading;
    }

    // Main refresh function
    async function refreshData() {
      if (isLoading) return;
      console.log("Refreshing dashboard data...");
      const treasuryData = await fetchTreasuryData();
      const clawMartData = await fetchClawMartEarnings();
      if (treasuryData) updateUI(treasuryData, clawMartData);
    }

    // Manual refresh button handler
    function setupRefreshButton() {
      const refreshBtn = document.getElementById("refresh-btn");
      if (refreshBtn) {
        refreshBtn.addEventListener("click", () => {
          refreshData();
          fetchStoreRevenue();
        });
      }
    }

    // Start auto-refresh (works with Astro View Transitions)
    document.addEventListener("astro:page-load", () => {
      // Clean up any previous interval (in case of re-navigation)
      if (refreshInterval) clearInterval(refreshInterval);

      // Only run on the dashboard page
      if (!document.querySelector(".dashboard-page")) return;

      const loadingIndicator =
        document.getElementById("loading-indicator") ||
        document.createElement("div");
      loadingIndicator.id = "loading-indicator";
      loadingIndicator.style.cssText = `
      position: fixed; top: 20px; right: 20px;
      background: var(--gradient-accent); color: white;
      padding: 8px 16px; border-radius: 20px;
      font-size: 0.8rem; font-weight: 600;
      z-index: 1000; display: none;
      box-shadow: var(--shadow-md);
    `;
      loadingIndicator.textContent = "Loading data...";
      if (!loadingIndicator.parentNode)
        document.body.appendChild(loadingIndicator);

      refreshData();
      fetchStoreRevenue();
      fetchFundlyHubRevenue();
      fetchBurnBalance();
      fetchBuybackData();

      refreshInterval = setInterval(() => {
        refreshData();
        fetchStoreRevenue();
        fetchFundlyHubRevenue();
        fetchBurnBalance();
        fetchBuybackData();
      }, 60000);

      setupRefreshButton();

      window.addEventListener("beforeunload", () => {
        clearInterval(refreshInterval);
      });
    });

    // ──── Stripe Store Revenue → Aleister Store card ────
    async function fetchStoreRevenue() {
      try {
        const res = await fetch("/api/store-revenue.json");
        const data = await res.json();

        const amountEl = document.getElementById("store-revenue");
        const subEl = document.getElementById("store-sub");

        const total = data.revenue30d || 0;
        window.__storeRevenue = total;

        if (amountEl) amountEl.textContent = formatCurrency(total);
        if (subEl) {
          subEl.textContent = `${
            data.chargeCount30d || 0
          } charges last 30d · Stripe`;
        }

        updateAllTimeRevenue();
      } catch (err) {
        console.error("Store revenue fetch error:", err);
      }
    }

    // ──── FundlyHub Revenue → FundlyHub card ────
    async function fetchFundlyHubRevenue() {
      try {
        const res = await fetch("/api/fundlyhub-revenue.json");
        const data = await res.json();

        const amountEl = document.getElementById("fundlyhub-revenue");
        const subEl = document.getElementById("fundlyhub-sub");
        const revenue = data.totalRevenue || 0;
        window.__fundlyhubRevenue = revenue;

        if (amountEl) amountEl.textContent = formatCurrency(revenue);
        if (subEl) {
          subEl.textContent = `${
            data.chargeCount30d || 0
          } charges last 30d · Stripe`;
        }

        updateAllTimeRevenue();
      } catch (err) {
        console.error("FundlyHub revenue fetch error:", err);
      }
    }

    // ──── Buyback Data → Buybacks section + Token Fees ────
    async function fetchBuybackData() {
      try {
        const [buybackRes, priceRes] = await Promise.all([
          fetch("/api/buyback-data.json"),
          fetch("/api/token-prices.json"),
        ]);
        const buybackData = await buybackRes.json();
        const priceData = await priceRes.json();

        const ethPrice = priceData.ethereum?.usd || 0;
        let totalUsd = 0;

        // Update each buyback card
        (buybackData.buybacks || []).forEach((bb, i) => {
          const wethEl = document.getElementById(`buyback-weth-${i}`);
          const usdEl = document.getElementById(`buyback-usd-${i}`);
          const usdValue = (bb.wethAmount || 0) * ethPrice;
          totalUsd += usdValue;

          if (wethEl) {
            wethEl.textContent = `${(bb.wethAmount || 0).toFixed(4)} WETH`;
          }
          if (usdEl && usdValue > 0) {
            usdEl.textContent = `≈ ${formatCurrency(usdValue)}`;
          }
        });

        // Store buyback USD total for all-time revenue
        window.__buybackRevenue = totalUsd;
        updateAllTimeRevenue();
      } catch (err) {
        console.error("Buyback data fetch error:", err);
        const wethEl = document.getElementById("buyback-weth-0");
        if (wethEl) wethEl.textContent = "—";
      }
    }

    // ──── Burn Balance → Burn Tracker card ────
    async function fetchBurnBalance() {
      try {
        const [burnRes, priceRes] = await Promise.all([
          fetch("/api/burn-balance.json"),
          fetch("/api/token-prices.json"),
        ]);
        const burnData = await burnRes.json();
        const priceData = await priceRes.json();

        const balance = burnData.balance || 0;
        const price = priceData.aleister?.usd || 0;
        const usdValue = balance * price;

        // Store for Token Fees + All-Time Revenue calculations
        window.__burnValue = usdValue;

        const amountEl = document.getElementById("burn-amount");
        const subEl = document.getElementById("burn-sub");
        const usdEl = document.getElementById("burn-usd");

        if (amountEl) {
          amountEl.textContent = formatNumber(balance) + " $ALEISTER";
        }
        if (subEl) {
          subEl.textContent = "tokens burned forever · verified on-chain";
        }
        if (usdEl && usdValue > 0) {
          usdEl.textContent = "≈ " + formatCurrency(usdValue);
        } else if (usdEl) {
          usdEl.textContent = "";
        }

        // Recalculate Token Fees card to include burn value
        const treasuryValue = window.__treasuryValue || 0;
        const tokenFeesTotal = treasuryValue + usdValue;
        const tokenFeesEl = document.getElementById("token-fees");
        if (tokenFeesEl) tokenFeesEl.textContent = formatCurrency(tokenFeesTotal);
        window.__tokenFeesRevenue = tokenFeesTotal;

        updateAllTimeRevenue();
      } catch (err) {
        console.error("Burn balance fetch error:", err);
        const subEl = document.getElementById("burn-sub");
        if (subEl) subEl.textContent = "Unable to load burn data";
      }
    }
  </script>
</BaseLayout>
