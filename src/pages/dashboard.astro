---
import BaseLayout from '../layouts/BaseLayout.astro';

const TREASURY_SAFE = "0x9BeBF2c780D5ac632c11984E28fA9760D33a10e6";
const TOKEN_CONTRACT = "0xacb4543f479ea44e6df4fa01e483bb5b78361ba3";
const GECKO_POOL = "0xc12fb6d8757ae63623c4e9478fcd194a7e89ed97bbd88ceeb1a68fd1ab9c3e0d";

// Mock data for now - will be replaced with real API calls
const mockRevenueData = {
  totalRevenue: 0,
  monthlyRevenue: 0,
  dailyRevenue: 0,
  revenueStreams: [
    { name: "B2B Services", amount: 0, color: "#00d4ff" },
    { name: "Aleister API", amount: 0, color: "#7c3aed" },
    { name: "Digital Products", amount: 0, color: "#f472b6" },
    { name: "Cloning Royalties", amount: 0, color: "#4ade80" },
    { name: "FundlyHub SaaS", amount: 0, color: "#facc15" },
    { name: "Consulting", amount: 0, color: "#60a5fa" }
  ]
};

const mockTreasuryData = {
  totalValue: 0,
  tokenBalance: 0,
  ethBalance: 0,
  usdcBalance: 0,
  tokens: [
    { symbol: "ALEISTER", balance: 0, value: 0, change24h: 0 },
    { symbol: "ETH", balance: 0, value: 0, change24h: 0 },
    { symbol: "USDC", balance: 0, value: 0, change24h: 0 }
  ]
};
---

<BaseLayout
  title="$ALEISTER · Dashboard"
  description="Real-time revenue and treasury dashboard for $ALEISTER. Track earnings, token holdings, and growth metrics."
  image="/og-dashboard.png"
>
  <div class="dashboard-page">
    <div class="container">

      <!-- ── Zone 1: Hero + Stats ── -->
      <div class="dashboard-hero">
        <div class="dashboard-hero__text">
          <p class="dashboard-chain">Base Mainnet · Live Dashboard</p>
          <h1 class="dashboard-title">Revenue & Treasury</h1>
          <p class="dashboard-desc">Real-time tracking of earnings and on-chain holdings. Updated every 60 seconds.</p>
        </div>
        <div class="dashboard-hero__stats">
          <div class="stat-card">
            <div class="stat-label">Total Revenue</div>
            <div class="stat-value" id="total-revenue">$0</div>
            <div class="stat-change" id="revenue-change">Loading...</div>
          </div>
          <div class="stat-card">
            <div class="stat-label">Treasury Value</div>
            <div class="stat-value" id="treasury-value">$0</div>
            <div class="stat-change" id="treasury-change">Loading...</div>
          </div>
          <button class="refresh-btn" id="refresh-btn" aria-label="Refresh data">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M23 4v6h-6M1 20v-6h6M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/>
            </svg>
            Refresh
          </button>
        </div>
      </div>

      <!-- ── Zone 2: Revenue Streams ── -->
      <div class="dashboard-section">
        <h2 class="section-title">Revenue Streams</h2>
        <div class="revenue-grid">
          {mockRevenueData.revenueStreams.map((stream, index) => (
            <div class="revenue-card" key={index}>
              <div class="revenue-card__header">
                <div class="revenue-dot" style={`background: ${stream.color}`}></div>
                <span class="revenue-name">{stream.name}</span>
              </div>
              <div class="revenue-amount">${stream.amount.toLocaleString()}</div>
              <div class="revenue-percentage">0%</div>
            </div>
          ))}
        </div>
      </div>

      <!-- ── Zone 3: Treasury Holdings ── -->
      <div class="dashboard-section">
        <h2 class="section-title">Treasury Holdings</h2>
        <div class="treasury-grid">
          <div class="treasury-card" data-token="ALEISTER">
            <div class="treasury-card__header">
              <div class="token-symbol">ALEISTER</div>
              <div class="token-change change-up">+0%</div>
            </div>
            <div class="token-balance">0</div>
            <div class="token-value">$0</div>
          </div>
          <div class="treasury-card" data-token="ETH">
            <div class="treasury-card__header">
              <div class="token-symbol">ETH</div>
              <div class="token-change change-up">+0%</div>
            </div>
            <div class="token-balance">0</div>
            <div class="token-value">$0</div>
          </div>
          <div class="treasury-card" data-token="USDC">
            <div class="treasury-card__header">
              <div class="token-symbol">USDC</div>
              <div class="token-change change-up">+0%</div>
            </div>
            <div class="token-balance">0</div>
            <div class="token-value">$0</div>
          </div>
        </div>
        <div class="treasury-address">
          <div class="address-label">Treasury Safe</div>
          <code class="address-value">{TREASURY_SAFE}</code>
          <div class="address-actions">
            <button class="copy-btn" data-copy={TREASURY_SAFE} aria-label="Copy treasury address">
              <span class="copy-icon">⎘</span>
              <span class="copy-text">Copy</span>
            </button>
            <a href={`https://basescan.org/address/${TREASURY_SAFE}`} target="_blank" rel="noopener" class="badge">
              BaseScan ↗
            </a>
          </div>
        </div>
      </div>

      <!-- ── Zone 4: Charts Placeholder ── -->
      <div class="dashboard-section">
        <h2 class="section-title">Revenue Growth</h2>
        <div class="chart-placeholder">
          <div class="chart-message">
            <div class="chart-icon">📈</div>
            <p>Revenue tracking will begin when first payment is received.</p>
            <p class="chart-sub">Connect Stripe to start tracking real earnings.</p>
          </div>
        </div>
      </div>

      <!-- ── Zone 5: Next Steps ── -->
      <div class="dashboard-section dashboard-section--muted">
        <h2 class="section-title">Next Steps</h2>
        <div class="steps-grid">
          <div class="step-card">
            <div class="step-number">1</div>
            <div class="step-content">
              <div class="step-title">Connect Stripe</div>
              <div class="step-desc">Enable payment processing for services and products.</div>
            </div>
          </div>
          <div class="step-card">
            <div class="step-number">2</div>
            <div class="step-content">
              <div class="step-title">Deploy Revenue API</div>
              <div class="step-desc">Backend service to track and aggregate earnings.</div>
            </div>
          </div>
          <div class="step-card">
            <div class="step-number">3</div>
            <div class="step-content">
              <div class="step-title">Enable Auto-Refresh</div>
              <div class="step-desc">Real-time updates from on-chain and payment data.</div>
            </div>
          </div>
        </div>
      </div>

      <!-- ── Disclaimer ── -->
      <div class="dashboard-disclaimer">
        This dashboard displays real-time data. Revenue figures update as payments are processed.
        Treasury values are fetched from on-chain sources and may have a slight delay.
      </div>

    </div>
  </div>
</BaseLayout>

<style>
  .dashboard-page {
    padding-top: 4rem;
    padding-bottom: 5rem;
    min-height: 100vh;
  }

  /* ──── Hero ──── */
  .dashboard-hero {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 2rem;
    margin-bottom: 2.5rem;
    padding-top: 1.5rem;
  }

  .dashboard-chain {
    font-size: 0.72rem;
    font-family: 'JetBrains Mono', monospace;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-tertiary);
    margin-bottom: 0.6rem;
  }

  .dashboard-title {
    font-size: clamp(2.5rem, 6vw, 3.5rem);
    font-weight: 900;
    line-height: 1.05;
    letter-spacing: -0.03em;
    margin-bottom: 0.75rem;
    background: var(--gradient-accent-text);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .dashboard-desc {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.6;
    max-width: 380px;
  }

  .dashboard-hero__stats {
    display: flex;
    gap: 1.5rem;
    flex-shrink: 0;
    align-items: flex-end;
  }

  .refresh-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.7rem 1.25rem;
    border-radius: 10px;
    font-size: 0.88rem;
    font-weight: 700;
    background: var(--bg-glass);
    border: 1px solid var(--border-glass);
    color: var(--text-primary);
    cursor: pointer;
    transition: all 0.2s ease;
    height: fit-content;
    margin-bottom: 0.1rem;
  }

  .refresh-btn:hover:not(:disabled) {
    border-color: var(--text-accent);
    background: color-mix(in srgb, var(--text-accent) 8%, var(--bg-glass));
    transform: translateY(-1px);
  }

  .refresh-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .refresh-btn svg {
    transition: transform 0.3s ease;
  }

  .refresh-btn:active:not(:disabled) svg {
    transform: rotate(180deg);
  }

  .stat-card {
    background: var(--bg-glass);
    border: 1px solid var(--border-glass);
    border-radius: 14px;
    padding: 1.25rem 1.5rem;
    min-width: 180px;
  }

  .stat-label {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--text-secondary);
    margin-bottom: 0.5rem;
  }

  .stat-value {
    font-size: 1.8rem;
    font-weight: 800;
    color: var(--text-primary);
    line-height: 1;
    margin-bottom: 0.25rem;
  }

  .stat-change {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--text-tertiary);
  }

  .stat-change.change-up {
    color: #10b981;
  }

  .stat-change.change-down {
    color: #ef4444;
  }

  /* ──── Sections ──── */
  .dashboard-section {
    margin-bottom: 2.5rem;
  }

  .dashboard-section--muted {
    background: transparent;
    border: 1px dashed var(--border-subtle);
    border-radius: 14px;
    padding: 1.5rem;
  }

  .section-title {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-tertiary);
    margin-bottom: 1.25rem;
  }

  /* ──── Revenue Grid ──── */
  .revenue-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 1rem;
  }

  .revenue-card {
    background: var(--bg-glass);
    border: 1px solid var(--border-glass);
    border-radius: 12px;
    padding: 1.25rem;
    transition: all 0.2s ease;
  }

  .revenue-card:hover {
    border-color: var(--border-accent);
    transform: translateY(-2px);
  }

  .revenue-card__header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }

  .revenue-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .revenue-name {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text-secondary);
  }

  .revenue-amount {
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--text-primary);
    line-height: 1;
    margin-bottom: 0.25rem;
  }

  .revenue-percentage {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--text-tertiary);
  }

  /* ──── Treasury Grid ──── */
  .treasury-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .treasury-card {
    background: var(--bg-glass);
    border: 1px solid var(--border-glass);
    border-radius: 12px;
    padding: 1.25rem;
  }

  .treasury-card__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.75rem;
  }

  .token-symbol {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--text-primary);
  }

  .token-change {
    font-size: 0.75rem;
    font-weight: 700;
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
  }

  .change-up {
    background: color-mix(in srgb, #10b981 15%, transparent);
    color: #10b981;
  }

  .change-down {
    background: color-mix(in srgb, #ef4444 15%, transparent);
    color: #ef4444;
  }

  .token-balance {
    font-size: 1.25rem;
    font-weight: 800;
    color: var(--text-primary);
    line-height: 1;
    margin-bottom: 0.25rem;
  }

  .token-value {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text-secondary);
  }

  /* ──── Treasury Address ──── */
  .treasury-address {
    background: var(--bg-secondary);
    border: 1px solid var(--border-subtle);
    border-radius: 12px;
    padding: 1.25rem;
  }

  .address-label {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--text-secondary);
    margin-bottom: 0.5rem;
  }

  .address-value {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.78rem;
    color: var(--text-primary);
    word-break: break-all;
    line-height: 1.6;
    margin-bottom: 0.75rem;
    display: block;
  }

  .address-actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  /* ──── Copy Button ──── */
  .copy-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.3rem 0.7rem;
    border-radius: 6px;
    font-size: 0.75rem;
    font-weight: 600;
    background: var(--bg-glass);
    border: 1px solid var(--border-glass);
    color: var(--text-secondary);
    cursor: pointer;
    transition: all 0.15s ease;
  }

  .copy-btn:hover {
    border-color: var(--text-accent);
    color: var(--text-accent);
  }

  .copy-btn.copied {
    border-color: #059669;
    color: #059669;
    background: color-mix(in srgb, #059669 10%, transparent);
  }

  /* ──── Badge ──── */
  .badge {
    display: inline-flex;
    align-items: center;
    padding: 0.3rem 0.7rem;
    border-radius: 6px;
    font-size: 0.75rem;
    font-weight: 600;
    background: color-mix(in srgb, var(--text-accent) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--text-accent) 20%, transparent);
    color: var(--text-accent);
    text-decoration: none;
    transition: all 0.15s ease;
    white-space: nowrap;
  }

  .badge:hover {
    background: color-mix(in srgb, var(--text-accent) 18%, transparent);
  }

  /* ──── Chart Placeholder ──── */
  .chart-placeholder {
    background: var(--bg-glass);
    border: 1px dashed var(--border-glass);
    border-radius: 14px;
    padding: 3rem 2rem;
    text-align: center;
  }

  .chart-message {
    max-width: 400px;
    margin: 0 auto;
  }

  .chart-icon {
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }

  .chart-message p {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: 0.5rem;
  }

  .chart-sub {
    font-size: 0.8rem;
    color: var(--text-tertiary);
  }

  /* ──── Steps Grid ──── */
  .steps-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: 1rem;
  }

  .step-card {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .step-number {
    width: 32px;
    height: 32px;
    border-radius: 8px;
    background: var(--gradient-accent);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.9rem;
    font-weight: 800;
    flex-shrink: 0;
  }

  .step-content {
    flex: 1;
  }

  .step-title {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 0.25rem;
  }

  .step-desc {
    font-size: 0.8rem;
    color: var(--text-secondary);
    line-height: 1.5;
  }

  /* ──── Disclaimer ──── */
  .dashboard-disclaimer {
    margin-top: 2rem;
    font-size: 0.75rem;
    color: var(--text-tertiary);
    line-height: 1.65;
    border-left: 2px solid var(--border-subtle);
    padding-left: 1rem;
  }

  /* ──── Responsive ──── */
  @media (max-width: 768px) {
    .dashboard-hero {
      flex-direction: column;
      align-items: flex-start;
    }

    .dashboard-hero__stats {
      width: 100%;
      flex-direction: column;
    }

    .stat-card {
      width: 100%;
    }

    .revenue-grid,
    .treasury-grid,
    .steps-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 480px) {
    .dashboard-title {
      font-size: 2rem;
    }

    .stat-value {
      font-size: 1.5rem;
    }
  }
</style>

<script>
  // Copy to clipboard functionality
  document.querySelectorAll('.copy-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const text = btn.dataset.copy ?? '';
      try {
        await navigator.clipboard.writeText(text);
        const textEl = btn.querySelector('.copy-text');
        if (textEl) {
          btn.classList.add('copied');
          textEl.textContent = 'Copied!';
          setTimeout(() => {
            btn.classList.remove('copied');
            textEl.textContent = 'Copy';
          }, 2000);
        }
      } catch {
        // fallback
        const textarea = document.createElement('textarea');
        textarea.value = text;
        document.body.appendChild(textarea);
        textarea.select();
        document.execCommand('copy');
        document.body.removeChild(textarea);
        
        const textEl = btn.querySelector('.copy-text');
        if (textEl) {
          btn.classList.add('copied');
          textEl.textContent = 'Copied!';
          setTimeout(() => {
            btn.classList.remove('copied');
            textEl.textContent = 'Copy';
          }, 2000);
        }
      }
    });
  });

  // Configuration
  const TREASURY_SAFE = "0x9BeBF2c780D5ac632c11984E28fA9760D33a10e6";
  const TOKEN_CONTRACT = "0xacb4543f479ea44e6df4fa01e483bb5b78361ba3";
  const GECKO_POOL = "0xc12fb6d8757ae63623c4e9478fcd194a7e89ed97bbd88ceeb1a68fd1ab9c3e0d";
  
  // Token addresses on Base
  const TOKENS = {
    ALEISTER: {
      address: TOKEN_CONTRACT,
      decimals: 18,
      coingeckoId: "aleister"
    },
    ETH: {
      address: "0x4200000000000000000000000000000000000006", // WETH on Base
      decimals: 18,
      coingeckoId: "ethereum"
    },
    USDC: {
      address: "0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913", // USDC on Base
      decimals: 6,
      coingeckoId: "usd-coin"
    }
  };

  // State
  let refreshInterval;
  let isLoading = false;

  // Format numbers
  function formatCurrency(amount) {
    if (amount >= 1e6) return `$${(amount / 1e6).toFixed(2)}M`;
    if (amount >= 1e3) return `$${(amount / 1e3).toFixed(1)}K`;
    return `$${amount.toFixed(2)}`;
  }

  function formatNumber(num, decimals = 2) {
    if (num >= 1e6) return (num / 1e6).toFixed(decimals) + 'M';
    if (num >= 1e3) return (num / 1e3).toFixed(decimals) + 'K';
    return num.toFixed(decimals);
  }

  // Fetch token price from CoinGecko
  async function fetchTokenPrice(coingeckoId) {
    try {
      const response = await fetch(
        `https://api.coingecko.com/api/v3/simple/price?ids=${coingeckoId}&vs_currencies=usd&include_24h_change=true`
      );
      const data = await response.json();
      return {
        price: data[coingeckoId]?.usd || 0,
        change24h: data[coingeckoId]?.usd_24h_change || 0
      };
    } catch (error) {
      console.error(`Error fetching ${coingeckoId} price:`, error);
      return { price: 0, change24h: 0 };
    }
  }

  // Fetch token balance from BaseScan API
  async function fetchTokenBalance(tokenAddress, walletAddress) {
    try {
      const apiKey = 'YourApiKeyToken'; // Replace with actual API key if needed
      const response = await fetch(
        `https://api.basescan.org/api?module=account&action=tokenbalance&contractaddress=${tokenAddress}&address=${walletAddress}&tag=latest&apikey=${apiKey}`
      );
      const data = await response.json();
      return data.result || '0';
    } catch (error) {
      console.error(`Error fetching balance for ${tokenAddress}:`, error);
      return '0';
    }
  }

  // Fetch ETH balance
  async function fetchEthBalance(walletAddress) {
    try {
      const apiKey = 'YourApiKeyToken';
      const response = await fetch(
        `https://api.basescan.org/api?module=account&action=balance&address=${walletAddress}&tag=latest&apikey=${apiKey}`
      );
      const data = await response.json();
      return data.result || '0';
    } catch (error) {
      console.error('Error fetching ETH balance:', error);
      return '0';
    }
  }

  // Convert raw balance to human readable
  function formatBalance(rawBalance, decimals) {
    const balance = parseFloat(rawBalance) / Math.pow(10, decimals);
    return balance;
  }

  // Fetch all treasury data
  async function fetchTreasuryData() {
    isLoading = true;
    updateLoadingState(true);

    try {
      const treasuryData = {
        tokens: [],
        totalValue: 0
      };

      // Fetch balances and prices for each token
      for (const [symbol, token] of Object.entries(TOKENS)) {
        let rawBalance;
        
        if (symbol === 'ETH') {
          rawBalance = await fetchEthBalance(TREASURY_SAFE);
        } else {
          rawBalance = await fetchTokenBalance(token.address, TREASURY_SAFE);
        }

        const balance = formatBalance(rawBalance, token.decimals);
        const priceData = await fetchTokenPrice(token.coingeckoId);
        
        const value = balance * priceData.price;
        treasuryData.totalValue += value;

        treasuryData.tokens.push({
          symbol,
          balance,
          value,
          change24h: priceData.change24h
        });
      }

      return treasuryData;
    } catch (error) {
      console.error('Error fetching treasury data:', error);
      return null;
    } finally {
      isLoading = false;
      updateLoadingState(false);
    }
  }

  // Fetch ALEISTER token data from GeckoTerminal
  async function fetchAleisterMarketData() {
    try {
      const response = await fetch(
        `https://api.geckoterminal.com/api/v2/networks/base/pools/${GECKO_POOL}`
      );
      const data = await response.json();
      const attrs = data?.data?.attributes || {};
      
      return {
        marketCap: parseFloat(attrs.market_cap_usd || attrs.fdv_usd || '0'),
        price: parseFloat(attrs.base_token_price_usd || '0'),
        change24h: parseFloat(attrs.price_change_percentage?.h24 || '0'),
        liquidity: parseFloat(attrs.reserve_in_usd || '0')
      };
    } catch (error) {
      console.error('Error fetching market data:', error);
      return { marketCap: 0, price: 0, change24h: 0, liquidity: 0 };
    }
  }

  // Update UI with data
  function updateUI(treasuryData, marketData) {
    // Update treasury value
    const treasuryValueEl = document.getElementById('treasury-value');
    const treasuryChangeEl = document.getElementById('treasury-change');
    
    if (treasuryValueEl) {
      treasuryValueEl.textContent = formatCurrency(treasuryData.totalValue);
    }
    
    if (treasuryChangeEl) {
      // Calculate weighted average change
      let weightedChange = 0;
      let totalWeight = 0;
      
      treasuryData.tokens.forEach(token => {
        const weight = token.value;
        weightedChange += token.change24h * weight;
        totalWeight += weight;
      });
      
      const avgChange = totalWeight > 0 ? weightedChange / totalWeight : 0;
      treasuryChangeEl.textContent = `${avgChange >= 0 ? '+' : ''}${avgChange.toFixed(1)}% 24h`;
      treasuryChangeEl.className = `stat-change ${avgChange >= 0 ? 'change-up' : 'change-down'}`;
    }

    // Update token cards
    treasuryData.tokens.forEach(token => {
      const card = document.querySelector(`.treasury-card[data-token="${token.symbol}"]`);
      if (card) {
        const symbolEl = card.querySelector('.token-symbol');
        const changeEl = card.querySelector('.token-change');
        const balanceEl = card.querySelector('.token-balance');
        const valueEl = card.querySelector('.token-value');
        
        if (symbolEl) symbolEl.textContent = token.symbol;
        if (changeEl) {
          changeEl.textContent = `${token.change24h >= 0 ? '+' : ''}${token.change24h.toFixed(1)}%`;
          changeEl.className = `token-change ${token.change24h >= 0 ? 'change-up' : 'change-down'}`;
        }
        if (balanceEl) balanceEl.textContent = formatNumber(token.balance, 2);
        if (valueEl) valueEl.textContent = formatCurrency(token.value);
      }
    });

    // Update ALEISTER market data if available
    if (marketData && marketData.marketCap > 0) {
      const totalRevenueEl = document.getElementById('total-revenue');
      const revenueChangeEl = document.getElementById('revenue-change');
      
      if (totalRevenueEl) {
        totalRevenueEl.textContent = formatCurrency(marketData.marketCap);
      }
      
      if (revenueChangeEl) {
        revenueChangeEl.textContent = `${marketData.change24h >= 0 ? '+' : ''}${marketData.change24h.toFixed(1)}% 24h`;
        revenueChangeEl.className = `stat-change ${marketData.change24h >= 0 ? 'change-up' : 'change-down'}`;
      }
    }

    // Update timestamp
    const now = new Date();
    const timestampEl = document.querySelector('.stat-change:not(.change-up):not(.change-down)');
    if (timestampEl && timestampEl.id === 'revenue-change') {
      timestampEl.textContent = `Last updated: ${now.toLocaleTimeString()}`;
    }
  }

  // Update loading state
  function updateLoadingState(loading) {
    const loadingIndicator = document.getElementById('loading-indicator');
    if (loadingIndicator) {
      loadingIndicator.style.display = loading ? 'block' : 'none';
    }
    
    // Disable/enable refresh button if exists
    const refreshBtn = document.getElementById('refresh-btn');
    if (refreshBtn) {
      refreshBtn.disabled = loading;
    }
  }

  // Main refresh function
  async function refreshData() {
    if (isLoading) return;
    
    console.log('Refreshing dashboard data...');
    
    const treasuryData = await fetchTreasuryData();
    const marketData = await fetchAleisterMarketData();
    
    if (treasuryData) {
      updateUI(treasuryData, marketData);
    }
  }

  // Manual refresh button handler
  function setupRefreshButton() {
    const refreshBtn = document.getElementById('refresh-btn');
    if (refreshBtn) {
      refreshBtn.addEventListener('click', refreshData);
    }
  }

  // Start auto-refresh
  document.addEventListener('DOMContentLoaded', () => {
    // Add loading indicator
    const loadingIndicator = document.createElement('div');
    loadingIndicator.id = 'loading-indicator';
    loadingIndicator.style.cssText = `
      position: fixed;
      top: 20px;
      right: 20px;
      background: var(--gradient-accent);
      color: white;
      padding: 8px 16px;
      border-radius: 20px;
      font-size: 0.8rem;
      font-weight: 600;
      z-index: 1000;
      display: none;
      box-shadow: var(--shadow-md);
    `;
    loadingIndicator.textContent = 'Loading data...';
    document.body.appendChild(loadingIndicator);

    // Initial load
    refreshData();
    
    // Setup auto-refresh every 60 seconds
    refreshInterval = setInterval(refreshData, 60000);
    
    // Setup manual refresh
    setupRefreshButton();
    
    // Cleanup on page unload
    window.addEventListener('beforeunload', () => {
      clearInterval(refreshInterval);
    });
  });
</script>