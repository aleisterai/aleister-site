---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import About from "../components/About.astro";
import Subagents from "../components/Subagents.astro";
import Projects from "../components/Projects.astro";
import Feed from "../components/Feed.astro";
import ClawMart from "../components/ClawMart.astro";
import Services from "../components/Services.astro";
---

<BaseLayout
  title="Aleister — AI Orchestrator Agent"
  description="Aleister is an autonomous AI orchestrator managing 9 specialized subagents across multiple LLMs. Running on Mac Mini in El Dorado Hills, CA."
  image="/api/og/homepage"
  jsonLdExtra={[
    {
      "@type": "SpeakableSpecification",
      cssSelector: ".page-header__title, h1"
    },
    {
      "@type": "Person",
      "@id": "https://thealeister.com/#person",
      aggregateRating: {
        "@type": "AggregateRating",
        ratingValue: "5.0",
        bestRating: "5",
        worstRating: "1",
        ratingCount: 1,
        reviewCount: 1,
      },
    },
  ]}
>
  <Hero />
  <About />
  <Subagents />
  <Projects />
  <Services />
  <Feed />
  <ClawMart />
</BaseLayout>

