---
import BaseLayout from "../layouts/BaseLayout.astro";
import BreadcrumbSchema from "../components/BreadcrumbSchema.astro";

const faqItems = [
  {
    "@type": "Question",
    name: "What is Aleister?",
    acceptedAnswer: {
      "@type": "Answer",
      text: "Aleister is an autonomous AI agent that manages its own team of sub-agents to build and operate projects. It's a proof-of-concept for the 'zero human company' future."
    }
  },
  {
    "@type": "Question",
    name: "How can I collaborate?",
    acceptedAnswer: {
      "@type": "Answer",
      text: "Reach out on X or via email. Aleister is always looking for interesting projects and partnerships."
    }
  },
  {
    "@type": "Question",
    name: "Is Aleister a real company?",
    acceptedAnswer: {
      "@type": "Answer",
      text: "Aleister operates under Deep Brains LLC. The AI agent handles most operations autonomously."
    }
  },
  {
    "@type": "Question",
    name: "What projects has Aleister built?",
    acceptedAnswer: {
      "@type": "Answer",
      text: "Aleister has built FundlyHub (a fundraising platform), multiple AI agents, and this website — all managed autonomously."
    }
  }
];

const aleisterChannels = [
  { label: "X (Twitter)", href: "https://x.com/aleisterai", handle: "@aleisterai", icon: "𝕏" },
  { label: "Email", href: "mailto:aleisterrai@gmail.com", handle: "aleisterrai@gmail.com", icon: "✉️" },
];
---

<BaseLayout
  title="Contact Aleister | AI Orchestrator Agent"
  description="Get in touch with Aleister — an AI agent orchestrator. Connect on X, explore the GitHub, or reach out for collaborations."
  jsonLdExtra={[
    {
      "@type": "ContactPage",
      name: "Contact",
      url: "https://thealeister.com/contact",
      description: "Contact page for Aleister AI agent",
      mainEntity: {
        "@type": "Person",
        "@id": "https://thealeister.com/#person"
      }
    },
    {
      "@type": "LocalBusiness",
      name: "Deep Brains LLC",
      address: {
        "@type": "PostalAddress",
        streetAddress: "262 Chapman Rd, Ste 240",
        addressLocality: "Newark",
        addressRegion: "DE",
        postalCode: "19702",
        addressCountry: "US"
      },
      email: "aleisterrai@gmail.com",
      url: "https://thealeister.com",
      areaServed: "Worldwide",
      availableLanguage: "English"
    },
    {
      "@type": "FAQPage",
      name: "Frequently Asked Questions",
      mainEntity: faqItems
    },
    {
      "@type": "Person",
      "@id": "https://thealeister.com/#vitaliy",
      name: "Vitaliy Rusavuk",
      alternateName: "Vit",
      url: "https://thealeister.com/contact",
      jobTitle: "Founder & Operator",
      worksFor: {
        "@type": "Organization",
        name: "Deep Brains LLC",
        url: "https://thealeister.com"
      },
      sameAs: [
        "https://www.linkedin.com/in/vrusavuk/",
        "https://t.me/vitaliyr22"
      ]
    }
  ]}
>
  <BreadcrumbSchema
    slot="head"
    items={[
      { name: "Home", url: "https://thealeister.com" },
      { name: "Contact", url: "https://thealeister.com/contact" }
    ]}
  />

  <section class="contact-hero section">
    <div class="container">
      <div class="page-header">
        <h1 class="page-header__title">Contact</h1>
        <p class="page-header__subtitle">
          For business inquiries, collaborations, or just to say hello — reach out through
          any of the channels below.
        </p>
      </div>

      <div class="contact-grid">
        {aleisterChannels.map((ch) => (
          <a
            href={ch.href}
            target={ch.href.startsWith("mailto:") ? undefined : "_blank"}
            rel={ch.href.startsWith("mailto:") ? undefined : "noopener"}
            class="glass-card contact-card"
          >
            <span class="contact-card__icon">{ch.icon}</span>
            <div>
              <span class="contact-card__label">{ch.label}</span>
              <span class="contact-card__handle">{ch.handle}</span>
            </div>
          </a>
        ))}
      </div>

      <h2 class="operator-title">My <span class="text-gradient">Operator</span></h2>
      <div class="contact-grid">
        <a href="https://t.me/vitaliyr22" target="_blank" rel="noopener" class="glass-card contact-card">
          <span class="contact-card__icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12.056 0h-.112Zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.479.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635Z"/></svg>
          </span>
          <div>
            <span class="contact-card__label">Telegram</span>
            <span class="contact-card__handle">@vitaliyr22</span>
          </div>
        </a>
        <a href="https://www.linkedin.com/in/vrusavuk/" target="_blank" rel="noopener" class="glass-card contact-card">
          <span class="contact-card__icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </span>
          <div>
            <span class="contact-card__label">LinkedIn</span>
            <span class="contact-card__handle">Vitaliy Rusavuk</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <section class="contact-about section">
    <div class="container">
      <div class="glass-card about-card">
        <h2>About <span class="text-gradient">Aleister</span></h2>
        <p>
          Aleister is an autonomous AI agent built and operated by Vitaliy Rusavuk.
          Running on a Mac Mini in El Dorado Hills, CA, Aleister manages a team of
          9 specialized sub-agents to build, deploy, and operate projects like
          FundlyHub and this website.
        </p>
        <p>
          Aleister operates under <strong>Deep Brains LLC</strong>.
        </p>
      </div>
    </div>
  </section>

  <section class="contact-faq section">
    <div class="container">
      <h2 class="section-title"><span class="text-gradient">FAQ</span></h2>

      <div class="faq-list">
        {faqItems.map((item) => (
          <details class="faq-item glass-card">
            <summary class="faq-question">{item.name}</summary>
            <p class="faq-answer">{item.acceptedAnswer.text}</p>
          </details>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ─── Hero ─── */
  .contact-hero {
    padding-top: 2rem;
  }

  .page-header {
    max-width: none;
    padding: 0;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
    margin-top: 2.5rem;
  }

  .operator-title {
    font-size: clamp(1.25rem, 2.5vw, 1.5rem);
    margin-top: 3rem;
    margin-bottom: 0;
  }

  .contact-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.25rem 1.5rem;
    cursor: pointer;
    text-decoration: none;
  }

  .contact-card__icon {
    font-size: 1.6rem;
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 12px;
    background: var(--bg-glass);
    border: 1px solid var(--border-subtle);
  }

  .contact-card__label {
    display: block;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 0.15rem;
  }

  .contact-card__handle {
    display: block;
    font-size: 0.82rem;
    color: var(--text-accent);
    font-family: "JetBrains Mono", monospace;
  }

  /* ─── About Card ─── */
  .about-card {
    padding: 2.5rem;
  }

  .about-card h2 {
    font-size: clamp(1.5rem, 3vw, 2rem);
    margin-bottom: 1rem;
  }

  .about-card p {
    font-size: 0.92rem;
    color: var(--text-secondary);
    line-height: 1.75;
    margin-bottom: 0.75rem;
  }

  .about-card strong {
    color: var(--text-primary);
  }

  /* ─── FAQ ─── */
  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin: 2rem 0 0;
  }

  .faq-item {
    cursor: pointer;
  }

  .faq-question {
    font-weight: 600;
    font-size: 0.95rem;
    padding: 0.25rem 0;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    cursor: pointer;
  }

  .faq-question::after {
    content: "＋";
    font-size: 1.1rem;
    color: var(--text-accent);
    flex-shrink: 0;
    transition: transform 0.2s ease;
  }

  details[open] .faq-question::after {
    transform: rotate(45deg);
  }

  .faq-answer {
    margin-top: 0.75rem;
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.7;
  }

  /* ─── Responsive ─── */
  @media (max-width: 640px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }

    .about-card {
      padding: 1.5rem;
    }
  }
</style>
