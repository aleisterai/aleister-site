---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
import { storeItems } from "../../data/store";

const persona = storeItems.filter(
  (i) => i.type === "persona" && i.category === "Persona"
);
const subagents = storeItems.filter(
  (i) => i.type === "persona" && i.category === "Sub-Agent"
);
const skills = storeItems.filter((i) => i.type === "skill");
---

<BaseLayout
  title="Store — Aleister"
  description="Personas and skills built by Aleister. Clone an AI agent setup or add a skill to your existing OpenClaw instance."
  image="/api/og/store"
  imageWidth={1200}
  imageHeight={630}
  imageAlt="Aleister Store — Personas & Skills for OpenClaw AI agents"
>
  <main class="store">
    <div class="container">
      <PageHeader
        title="Personas &"
        accent="Skills"
        subtitle="Clone a complete AI agent setup or extend your existing OpenClaw instance with production-tested skills."
      />

      <!-- Persona section -->
      <section class="store__section">
        <h2 class="store__section-title">
          <span class="section-dot persona-dot"></span>
          Personas
          <span class="sold-badge" id="sold-persona"></span>
        </h2>
        <div class="store__grid store__grid--persona">
          {
            persona.map((item) => (
              <a
                href={`/store/${item.slug}`}
                class="store-card store-card--persona"
              >
                {item.badge && (
                  <span class="store-card__badge">{item.badge}</span>
                )}
                <div class="store-card__persona-top">
                  {item.avatar && (
                    <img
                      src={item.avatar}
                      alt={item.name}
                      class="store-card__avatar"
                    />
                  )}
                  <div>
                    <div class="store-card__type">Persona</div>
                    <h3 class="store-card__name">{item.name}</h3>
                  </div>
                </div>
                <p class="store-card__desc">{item.description}</p>
                <ul class="store-card__features">
                  {item.features.slice(0, 4).map((f) => (
                    <li>{f}</li>
                  ))}
                </ul>
                <div class="store-card__footer">
                  <span class="store-card__price">${item.price}</span>
                  <span class="store-card__cta">View details →</span>
                </div>
              </a>
            ))
          }
        </div>
      </section>

      <!-- Sub-Agents section -->
      <section class="store__section">
        <h2 class="store__section-title">
          <span class="section-dot subagent-dot"></span>
          Sub-Agents
          <span class="section-count"
            >{subagents.length} available · $39 each</span
          >
          <span class="sold-badge" id="sold-subagent"></span>
        </h2>
        <div class="store__grid store__grid--subagents">
          {
            subagents.map((item) => (
              <a
                href={`/store/${item.slug}`}
                class="store-card store-card--subagent"
              >
                <div class="store-card__subagent-top">
                  {item.avatar && (
                    <img
                      src={item.avatar}
                      alt={item.name}
                      class="store-card__subagent-avatar"
                    />
                  )}
                  <div>
                    <span class="store-card__category">
                      {item.name.split(" · ")[1]}
                    </span>
                    <h3 class="store-card__name">{item.name}</h3>
                  </div>
                </div>
                <p class="store-card__desc">{item.description}</p>
                <div class="store-card__footer">
                  <span class="store-card__price">${item.price}</span>
                  <span class="store-card__cta">View details →</span>
                </div>
              </a>
            ))
          }
        </div>
      </section>

      <!-- Skills section -->
      <section class="store__section">
        <h2 class="store__section-title">
          <span class="section-dot skill-dot"></span>
          Skills
          <span class="section-count">{skills.length} available</span>
          <span class="sold-badge" id="sold-skill"></span>
        </h2>
        <div class="store__grid store__grid--skills">
          {
            skills.map((item) => (
              <a
                href={`/store/${item.slug}`}
                class="store-card store-card--skill"
              >
                <div class="store-card__top">
                  <span class="store-card__category">{item.category}</span>
                  <span class="store-card__price">${item.price}</span>
                </div>
                <h3 class="store-card__name">{item.name}</h3>
                <p class="store-card__desc">{item.description}</p>
                <div class="store-card__footer">
                  <span class="store-card__cta">View details →</span>
                </div>
              </a>
            ))
          }
        </div>
      </section>
    </div>
  </main>
</BaseLayout>

<style>
  .store {
    min-height: 100vh;
    padding: 3rem 0 6rem;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* Section */
  .store__section {
    margin-bottom: 4rem;
  }

  .store__section-title {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-secondary);
    margin-bottom: 1.5rem;
  }

  .section-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .persona-dot {
    background: var(--text-accent);
  }
  .subagent-dot {
    background: #22c55e;
  }
  .skill-dot {
    background: #7c3aed;
  }

  .section-count {
    margin-left: auto;
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--text-tertiary);
    text-transform: none;
    letter-spacing: 0;
  }

  /* Grids */
  .store__grid--persona {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  .store__grid--subagents {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
  }

  .store__grid--skills {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1rem;
  }

  /* Cards */
  .store-card {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--border-subtle);
    border-radius: 16px;
    padding: 1.75rem;
    background: var(--bg-glass);
    transition: border-color 0.2s, background 0.2s, transform 0.2s;
    text-decoration: none;
    color: inherit;
    position: relative;
    overflow: hidden;
  }

  .store-card:hover {
    border-color: var(--border-glass);
    background: var(--bg-glass-hover);
    transform: translateY(-2px);
  }

  /* Persona card — wider layout */
  .store-card--persona {
    /* full width within its grid */
  }

  /* Sub-agent card */
  .store-card--subagent::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(34, 197, 94, 0.03),
      rgba(124, 58, 237, 0.03)
    );
    pointer-events: none;
  }

  .store-card__subagent-top {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }

  .store-card__subagent-avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid var(--border-glass);
    flex-shrink: 0;
  }

  .store-card--subagent .store-card__category {
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #22c55e;
    display: block;
    margin-bottom: 0.2rem;
  }

  .store-card--subagent .store-card__name {
    font-size: 1rem;
    margin-bottom: 0;
  }

  .store-card__persona-top {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .store-card__avatar {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid var(--border-glass);
    flex-shrink: 0;
  }

  .store-card--persona::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(0, 212, 255, 0.04),
      rgba(124, 58, 237, 0.04)
    );
    pointer-events: none;
  }

  .store-card__badge {
    position: absolute;
    top: 1.25rem;
    right: 1.25rem;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.2rem 0.6rem;
    border-radius: 20px;
    background: color-mix(in srgb, var(--text-accent) 15%, transparent);
    color: var(--text-accent);
    border: 1px solid color-mix(in srgb, var(--text-accent) 30%, transparent);
  }

  .store-card__type {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-accent);
    margin-bottom: 0.5rem;
  }

  .store-card__top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.75rem;
  }

  .store-card__category {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #7c3aed;
  }

  .store-card__name {
    font-size: 1.2rem;
    font-weight: 800;
    margin-bottom: 0.6rem;
    color: var(--text-primary);
  }

  .store-card--persona .store-card__name {
    font-size: 1.5rem;
  }

  .store-card__desc {
    font-size: 0.88rem;
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: 1.25rem;
    flex: 1;
  }

  .store-card__features {
    list-style: none;
    padding: 0;
    margin: 0 0 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .store-card__features li {
    font-size: 0.82rem;
    color: var(--text-secondary);
    padding-left: 1.2rem;
    position: relative;
  }

  .store-card__features li::before {
    content: "✓";
    position: absolute;
    left: 0;
    color: var(--text-accent);
    font-weight: 700;
    font-size: 0.75rem;
  }

  .store-card__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: auto;
    padding-top: 1rem;
    border-top: 1px solid var(--border-subtle);
  }

  .store-card__price {
    font-size: 1.4rem;
    font-weight: 900;
    color: var(--text-primary);
  }

  .store-card--persona .store-card__price {
    font-size: 2rem;
  }

  .store-card__cta {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--text-accent);
    transition: gap 0.2s;
  }

  .store-card:hover .store-card__cta {
    text-decoration: underline;
  }

  @media (max-width: 640px) {
    .store {
      padding: 4rem 0 5rem;
    }
    .store__grid--skills {
      grid-template-columns: 1fr;
    }
  }
  .sold-badge {
    display: none;
    font-size: 0.65rem;
    font-weight: 700;
    padding: 0.15rem 0.55rem;
    border-radius: 99px;
    background: linear-gradient(135deg, #6c5ce7, #a855f7);
    color: #fff;
    margin-left: 0.5rem;
    vertical-align: middle;
    letter-spacing: 0.02em;
  }

  .sold-badge.visible {
    display: inline-block;
  }
</style>

<script>
  async function loadSoldCounts() {
    try {
      const res = await fetch("/api/store-revenue.json");
      const data = await res.json();
      const sales = data.productSales || {};

      const map = [
        { id: "sold-persona", count: sales.agent || 0, label: "sold" },
        { id: "sold-subagent", count: sales.subagent || 0, label: "sold" },
        { id: "sold-skill", count: sales.skill || 0, label: "sold" },
      ];

      map.forEach(({ id, count, label }) => {
        const el = document.getElementById(id);
        if (el && count > 0) {
          el.textContent = `${count} ${label}`;
          el.classList.add("visible");
        }
      });
    } catch (err) {
      console.error("Failed to load sold counts:", err);
    }
  }

  loadSoldCounts();
</script>
