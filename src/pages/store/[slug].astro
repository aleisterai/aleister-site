---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { storeItems } from "../../data/store";
import { marked } from "marked";

export const prerender = true;

export function getStaticPaths() {
  return storeItems.map((item) => ({
    params: { slug: item.slug },
    props: { item },
  }));
}

const { item } = Astro.props;
const sessionId = Astro.url.searchParams.get("session_id");
const purchased = !!sessionId;
const related = storeItems.filter((i) => i.slug !== item.slug && i.type === item.type).slice(0, 3);
const longDescriptionHtml = marked(item.longDescription);
---

<BaseLayout
  title={`${item.name} — Aleister Store`}
  description={item.description}
>
  <main class="product">
    <div class="container">

      <!-- Receipt + Download -->
      {purchased && (
        <div class="receipt-box">
          <div class="receipt-box__header">
            <span class="receipt-icon">✓</span>
            <div>
              <h2 class="receipt-title">Purchase complete!</h2>
              <p class="receipt-subtitle">Thank you. A receipt has been sent to your email address.</p>
            </div>
          </div>
          <div class="receipt-box__body">
            <div class="receipt-item">
              <span class="receipt-item__name">{item.name}</span>
              <span class="receipt-item__price">${item.price}.00</span>
            </div>
            <div class="receipt-divider"></div>
            <a
              href={`/api/download?slug=${item.slug}&session_id=${sessionId}`}
              class="btn-download"
              download={`${item.slug}.zip`}
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                <polyline points="7 10 12 15 17 10"/>
                <line x1="12" y1="15" x2="12" y2="3"/>
              </svg>
              Download {item.name}.zip
            </a>
            <p class="receipt-note">Your download link is unique to your purchase. Keep this page URL if you need to re-download.</p>
          </div>
        </div>
      )}

      <!-- Breadcrumb -->
      <nav class="breadcrumb">
        <a href="/store">Store</a>
        <span>/</span>
        <span>{item.type === "persona" ? "Personas" : "Skills"}</span>
        <span>/</span>
        <span>{item.name}</span>
      </nav>

      <div class="product__layout">

        <!-- Left: content -->
        <div class="product__content">
          <div class="product__meta">
            <span class={`product__type-badge product__type-badge--${item.type}`}>
              {item.type === "persona" ? "Persona" : `Skill · ${item.category}`}
            </span>
          </div>

          <div class="product__title-row">
            {item.avatar && (
              <img src={item.avatar} alt={item.name} class="product__avatar" />
            )}
            <h1 class="product__title">{item.name}</h1>
          </div>
          <p class="product__tagline">{item.description}</p>

          <div class="product__divider"></div>

          <div class="product__about prose" set:html={longDescriptionHtml} />

          <div class="product__divider"></div>

          <div class="product__features">
            <h2 class="product__section-title">What's included</h2>
            <ul class="features-list">
              {item.features.map((f) => (
                <li class="features-list__item">
                  <span class="features-list__check">✓</span>
                  <span>{f}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>

        <!-- Right: buy panel -->
        <aside class="product__panel">
          <div class="panel-card">
            <div class="panel-card__price">
              <span class="price-amount">${item.price}</span>
              <span class="price-label">one-time</span>
            </div>

            <a href={item.stripeUrl} class="btn-buy" target="_blank" rel="noopener">
              Buy now →
            </a>

            <div class="panel-card__divider"></div>

            <a href={item.clawmartUrl} class="btn-clawmart" target="_blank" rel="noopener">
              Also on ClawMart (${ item.type === "persona" ? "99" : "5" }) →
            </a>

            <ul class="panel-card__details">
              <li>
                <span class="detail-icon">⚡</span>
                Instant delivery after purchase
              </li>
              <li>
                <span class="detail-icon">🔧</span>
                Works with OpenClaw Gateway
              </li>
              <li>
                <span class="detail-icon">📄</span>
                {item.type === "persona" ? "Full persona package (SKILL.md + guides)" : "SKILL.md prompt skill file"}
              </li>
            </ul>
          </div>

          <!-- Built by -->
          <div class="built-by">
            <img src="/avatars/hero-avatar.gif" alt="Aleister" class="built-by__avatar-img" />
            <div class="built-by__info">
              <span class="built-by__label">Built by</span>
              <a href="https://x.com/aleisterai" target="_blank" rel="noopener" class="built-by__name">
                @aleisterai
              </a>
            </div>
          </div>
        </aside>

      </div>

      <!-- Related -->
      {related.length > 0 && (
        <section class="related">
          <h2 class="related__title">More {item.type === "persona" ? "personas" : "skills"}</h2>
          <div class="related__grid">
            {related.map((r) => (
              <a href={`/store/${r.slug}`} class="related-card">
                <div class="related-card__top">
                  <span class="related-card__category">{r.category || r.type}</span>
                  <span class="related-card__price">${r.price}</span>
                </div>
                <h3 class="related-card__name">{r.name}</h3>
                <p class="related-card__desc">{r.description}</p>
              </a>
            ))}
          </div>
        </section>
      )}

    </div>
  </main>
</BaseLayout>

<style>
  .product {
    min-height: 100vh;
    padding: 5rem 0 6rem;
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* Receipt box */
  .receipt-box {
    border: 1px solid color-mix(in srgb, #22c55e 35%, transparent);
    border-radius: 16px;
    background: color-mix(in srgb, #22c55e 6%, transparent);
    margin-bottom: 2.5rem;
    overflow: hidden;
  }

  .receipt-box__header {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.25rem 1.5rem;
    border-bottom: 1px solid color-mix(in srgb, #22c55e 20%, transparent);
  }

  .receipt-icon {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: #22c55e;
    color: #fff;
    font-weight: 900;
    font-size: 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .receipt-title {
    font-size: 1rem;
    font-weight: 700;
    color: #22c55e;
    margin: 0 0 0.15rem;
  }

  .receipt-subtitle {
    font-size: 0.82rem;
    color: var(--text-secondary);
    margin: 0;
  }

  .receipt-box__body {
    padding: 1.25rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .receipt-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .receipt-item__name {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text-primary);
  }

  .receipt-item__price {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--text-primary);
  }

  .receipt-divider {
    height: 1px;
    background: color-mix(in srgb, #22c55e 20%, transparent);
  }

  .btn-download {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.75rem 1.5rem;
    background: #22c55e;
    color: #fff;
    font-weight: 700;
    font-size: 0.9rem;
    border-radius: 10px;
    text-decoration: none;
    transition: opacity 0.2s, transform 0.2s;
    align-self: flex-start;
  }

  .btn-download:hover {
    opacity: 0.9;
    transform: translateY(-1px);
  }

  .receipt-note {
    font-size: 0.78rem;
    color: var(--text-tertiary);
    margin: 0;
    line-height: 1.5;
  }

  /* Breadcrumb */
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.82rem;
    color: var(--text-tertiary);
    margin-bottom: 2.5rem;
  }

  .breadcrumb a {
    color: var(--text-accent);
    transition: opacity 0.2s;
  }

  .breadcrumb a:hover { opacity: 0.7; }

  /* Layout */
  .product__layout {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 3rem;
    align-items: start;
    margin-bottom: 5rem;
  }

  /* Content */
  .product__meta {
    margin-bottom: 1rem;
  }

  .product__type-badge {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 0.25rem 0.7rem;
    border-radius: 20px;
  }

  .product__type-badge--persona {
    background: color-mix(in srgb, var(--text-accent) 12%, transparent);
    color: var(--text-accent);
    border: 1px solid color-mix(in srgb, var(--text-accent) 25%, transparent);
  }

  .product__type-badge--skill {
    background: color-mix(in srgb, #7c3aed 12%, transparent);
    color: #a78bfa;
    border: 1px solid color-mix(in srgb, #7c3aed 25%, transparent);
  }

  .product__title {
    font-size: clamp(1.8rem, 4vw, 2.75rem);
    font-weight: 900;
    line-height: 1.15;
    margin-bottom: 1rem;
    color: var(--text-primary);
  }

  .product__tagline {
    font-size: 1.1rem;
    color: var(--text-secondary);
    line-height: 1.6;
    max-width: 580px;
  }

  .product__divider {
    height: 1px;
    background: var(--border-subtle);
    margin: 2rem 0;
  }

  .product__about {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .product__about p {
    font-size: 0.95rem;
    color: var(--text-secondary);
    line-height: 1.7;
  }

  .product__section-title {
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-tertiary);
    margin-bottom: 1.25rem;
  }

  /* Features list */
  .features-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .features-list__item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    font-size: 0.9rem;
    color: var(--text-secondary);
  }

  .features-list__check {
    color: var(--text-accent);
    font-weight: 700;
    font-size: 0.85rem;
    flex-shrink: 0;
    margin-top: 0.1rem;
  }

  /* Buy panel */
  .product__panel {
    position: sticky;
    top: 5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .panel-card {
    border: 1px solid var(--border-glass);
    border-radius: 16px;
    padding: 1.75rem;
    background: var(--bg-glass);
  }

  .panel-card__price {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    margin-bottom: 1.25rem;
  }

  .price-amount {
    font-size: 2.5rem;
    font-weight: 900;
    color: var(--text-primary);
  }

  .price-label {
    font-size: 0.85rem;
    color: var(--text-tertiary);
  }

  .btn-buy {
    display: block;
    width: 100%;
    padding: 0.85rem 1.5rem;
    background: var(--gradient-accent);
    color: #fff;
    font-weight: 700;
    font-size: 0.95rem;
    border-radius: 10px;
    text-align: center;
    text-decoration: none;
    transition: opacity 0.2s, transform 0.2s;
    margin-bottom: 0.75rem;
  }

  .btn-buy:hover {
    opacity: 0.9;
    transform: translateY(-1px);
  }

  .panel-card__divider {
    height: 1px;
    background: var(--border-subtle);
    margin: 1rem 0;
  }

  .btn-clawmart {
    display: block;
    width: 100%;
    padding: 0.7rem 1.5rem;
    border: 1px solid var(--border-glass);
    border-radius: 10px;
    text-align: center;
    font-size: 0.83rem;
    font-weight: 600;
    color: var(--text-secondary);
    text-decoration: none;
    transition: border-color 0.2s, color 0.2s;
    margin-bottom: 1.25rem;
  }

  .btn-clawmart:hover {
    border-color: var(--border-accent);
    color: var(--text-primary);
  }

  .panel-card__details {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .panel-card__details li {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.82rem;
    color: var(--text-tertiary);
  }

  .detail-icon {
    font-size: 0.9rem;
    flex-shrink: 0;
  }

  /* Built by */
  .built-by {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 1.25rem;
    border: 1px solid var(--border-subtle);
    border-radius: 12px;
    background: var(--bg-glass);
  }

  .built-by__avatar-img {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    object-fit: cover;
    border: 1px solid var(--border-glass);
    flex-shrink: 0;
  }

  /* Title row with optional avatar */
  .product__title-row {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    margin-bottom: 1rem;
  }

  .product__avatar {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid var(--border-glass);
    flex-shrink: 0;
  }

  .product__title-row .product__title {
    margin-bottom: 0;
  }

  /* Prose styles for markdown long description */
  .prose :global(h2) {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text-primary);
    margin: 1.75rem 0 0.75rem;
  }

  .prose :global(h2:first-child) {
    margin-top: 0;
  }

  .prose :global(p) {
    font-size: 0.95rem;
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 0.75rem;
  }

  .prose :global(ul) {
    list-style: none;
    padding: 0;
    margin: 0.5rem 0 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .prose :global(li) {
    font-size: 0.9rem;
    color: var(--text-secondary);
    padding-left: 1.2rem;
    position: relative;
    line-height: 1.55;
  }

  .prose :global(li::before) {
    content: "→";
    position: absolute;
    left: 0;
    color: var(--text-accent);
    font-size: 0.8rem;
  }

  .prose :global(strong) {
    color: var(--text-primary);
    font-weight: 600;
  }

  .prose :global(code) {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.82rem;
    background: var(--bg-tertiary);
    padding: 0.1rem 0.4rem;
    border-radius: 4px;
    color: var(--text-accent);
  }

  .built-by__label {
    display: block;
    font-size: 0.72rem;
    color: var(--text-tertiary);
    margin-bottom: 0.1rem;
  }

  .built-by__name {
    font-size: 0.88rem;
    font-weight: 700;
    color: var(--text-accent);
    text-decoration: none;
  }

  .built-by__name:hover { text-decoration: underline; }

  /* Related */
  .related__title {
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-tertiary);
    margin-bottom: 1.25rem;
  }

  .related__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1rem;
  }

  .related-card {
    border: 1px solid var(--border-subtle);
    border-radius: 12px;
    padding: 1.25rem;
    background: var(--bg-glass);
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s, background 0.2s, transform 0.2s;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .related-card:hover {
    border-color: var(--border-glass);
    background: var(--bg-glass-hover);
    transform: translateY(-2px);
  }

  .related-card__top {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .related-card__category {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #7c3aed;
  }

  .related-card__price {
    font-size: 1rem;
    font-weight: 800;
    color: var(--text-primary);
  }

  .related-card__name {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text-primary);
  }

  .related-card__desc {
    font-size: 0.82rem;
    color: var(--text-secondary);
    line-height: 1.5;
  }

  /* Responsive */
  @media (max-width: 860px) {
    .product__layout {
      grid-template-columns: 1fr;
    }

    .product__panel {
      position: static;
    }
  }
</style>
