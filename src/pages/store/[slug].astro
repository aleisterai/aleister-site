---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { storeItems } from "../../data/store";
import { getCollection } from "astro:content";
import { marked } from "marked";

// SSR — must NOT prerender so we can read session_id from URL at request time
const { slug } = Astro.params;
const item = storeItems.find((i) => i.slug === slug);

if (!item) {
  return Astro.redirect("/store");
}

// For subagent items, pull rich data from the team collection
const isSubagent = item.category === "Sub-Agent";
const teamMember = isSubagent
  ? (await getCollection("team")).find((m) => m.slug === slug)
  : null;
const teamData = teamMember?.data ?? null;

const sessionId = Astro.url.searchParams.get("session_id");
const purchased = !!sessionId;
const related = storeItems
  .filter((i) => i.slug !== item.slug && i.type === item.type)
  .slice(0, 3);
const longDescriptionHtml = marked(item.longDescription);
---

<BaseLayout
  title={`${item.name} — Aleister Store`}
  description={item.description}
  image={item.avatar || undefined}
  jsonLdExtra={[{
    '@type': 'Product',
    '@id': `https://thealeister.com/store/${item.slug}#product`,
    name: item.name,
    description: item.description,
    url: `https://thealeister.com/store/${item.slug}`,
    ...(item.avatar ? { image: `https://thealeister.com${item.avatar}` } : {}),
    brand: { '@type': 'Person', name: 'Aleister', '@id': 'https://thealeister.com/#person' },
    offers: {
      '@type': 'Offer',
      price: String(item.price),
      priceCurrency: 'USD',
      availability: 'https://schema.org/InStock',
      url: item.stripeUrl,
      seller: { '@type': 'Person', name: 'Aleister' },
    },
  }]}
>
  <main class="product">
    <div class="container">
      <!-- Receipt + Download (JS-driven after device bind) -->
      {
        purchased && (
          <div class="receipt-box" id="receipt-box">
            <div class="receipt-box__header" id="receipt-toggle" role="button" tabindex="0" aria-expanded="true" aria-controls="receipt-body">
              <span class="receipt-icon" id="receipt-icon">
                ✓
              </span>
              <div class="receipt-box__header-text">
                <h2 class="receipt-title">Purchase complete!</h2>
                <p class="receipt-subtitle">
                  Thank you. A receipt has been sent to your email address.
                </p>
              </div>
              <button class="receipt-chevron" id="receipt-chevron" aria-hidden="true" tabindex="-1">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="18 15 12 9 6 15" />
                </svg>
              </button>
            </div>
            <div class="receipt-box__body" id="receipt-body">
              <div class="receipt-item">
                <span class="receipt-item__name">{item.name}</span>
                <span class="receipt-item__price">${item.price}.00</span>
              </div>
              <div class="receipt-divider" />

              {/* Download button — href filled in by JS after device bind */}
              <a
                id="btn-download"
                href="#"
                class="btn-download btn-download--loading"
                download={`${item.slug}.zip`}
              >
                <svg
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
                  <polyline points="7 10 12 15 17 10" />
                  <line x1="12" y1="15" x2="12" y2="3" />
                </svg>
                Download {item.name}.zip
              </a>

              {/* Note + Copy URL */}
              <div class="receipt-note-row">
                <p class="receipt-note" id="receipt-note">
                  Verifying your device…
                </p>
                <button
                  class="btn-copy-url"
                  id="btn-copy-url"
                  title="Copy page URL for re-download"
                  aria-label="Copy download page URL"
                  style="display:none"
                >
                  <svg
                    width="14"
                    height="14"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <rect x="9" y="9" width="13" height="13" rx="2" ry="2" />
                    <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" />
                  </svg>
                  <span id="copy-label">Copy link</span>
                </button>
              </div>

              {/* Claimed-by-another-device recovery UI */}
              <div
                class="receipt-claimed"
                id="receipt-claimed"
                style="display:none"
              >
                <p class="receipt-claimed__msg">
                  This download has already been claimed on another device.
                  Enter your purchase email to re-link:
                </p>
                <div class="receipt-claimed__form">
                  <input
                    id="recovery-email"
                    type="email"
                    placeholder="your@email.com"
                    class="receipt-email-input"
                  />
                  <button id="btn-recover" class="btn-recover">
                    Re-link device
                  </button>
                </div>
                <p class="receipt-claimed__hint" id="recovery-msg" />
              </div>
            </div>
          </div>
        )
      }

      <!-- Breadcrumb -->
      <nav class="breadcrumb">
        <a href="/store">Store</a>
        <span>/</span>
        <span
          >{
            isSubagent
              ? "Sub-Agents"
              : item.type === "persona"
              ? "Personas"
              : "Skills"
          }</span
        >
        <span>/</span>
        <span>{item.name}</span>
      </nav>

      <div class="product__layout">
        <!-- Left: content -->
        <div class="product__content">
          <div class="product__meta">
            {
              teamData ? (
                <span
                  class="product__type-badge product__type-badge--subagent"
                  style={`--agent-color: ${teamData.color}`}
                >
                  Sub-Agent · {teamData.codename}
                </span>
              ) : (
                <span
                  class={`product__type-badge product__type-badge--${item.type}`}
                >
                  {item.type === "persona"
                    ? "Persona"
                    : `Skill · ${item.category}`}
                </span>
              )
            }
          </div>

          <div class="product__title-row">
            {
              item.avatar && (
                <div
                  class="product__avatar-wrap"
                  style={
                    teamData ? `--agent-color: ${teamData.color}` : undefined
                  }
                >
                  <img
                    src={item.avatar}
                    alt={item.name}
                    class="product__avatar"
                  />
                </div>
              )
            }
            <div>
              <h1 class="product__title">{item.name}</h1>
              {teamData && <span class="product__model">{teamData.model}</span>}
            </div>
          </div>

          {/* Team traits from collection — same as /team page */}
          {
            teamData && teamData.traits && (
              <div class="product__traits">
                {teamData.traits.map((trait: string) => (
                  <span
                    class="product__trait"
                    style={`--trait-color: ${teamData.color}`}
                  >
                    {trait}
                  </span>
                ))}
              </div>
            )
          }

          <p class="product__tagline">{item.description}</p>

          {/* Link to full /team profile */}
          {
            teamData && (
              <a href={`/team/${slug}`} class="product__team-link">
                <svg
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                  <circle cx="12" cy="7" r="4" />
                </svg>
                View full agent profile →
              </a>
            )
          }

          <div class="product__divider"></div>

          <div class="product__about prose" set:html={longDescriptionHtml}>
          </div>

          <div class="product__divider"></div>

          <div class="product__features">
            <h2 class="product__section-title">What's included</h2>
            <ul class="features-list">
              {
                item.features.map((f) => (
                  <li class="features-list__item">
                    <span class="features-list__check">✓</span>
                    <span>{f}</span>
                  </li>
                ))
              }
            </ul>
          </div>

          {/* Good for workflows — only on personas and sub-agents */}
          {(item.type === "persona" || item.category === "Sub-Agent") && (
            <div class="product__divider"></div>
            <div class="product__workflows">
              <h2 class="product__section-title">Good for workflows</h2>
              <a href="/workflows/feature-development-pipeline" class="workflow-card">
                <div class="workflow-card__header">
                  <span class="workflow-card__icon">⚙️</span>
                  <div>
                    <span class="workflow-card__name">Feature Development Pipeline</span>
                    <span class="workflow-card__phases">6 phases</span>
                  </div>
                  <span class="workflow-card__arrow">→</span>
                </div>
                <p class="workflow-card__desc">
                  End-to-end workflow for shipping features: Research → Design → Approval → Agile Setup → Implementation → Production Deploy.
                  Uses Sage, Pixel, Rally, Cipher, Forge, Quill, and Prism in a structured handoff pipeline.
                </p>
                <div class="workflow-card__steps">
                  {[
                    { emoji: "🎓", label: "Research", agent: "Sage" },
                    { emoji: "🎨", label: "Design & Planning", agent: "Pixel · Quill · Prism" },
                    { emoji: "🚦", label: "Approval Gate", agent: "You" },
                    { emoji: "🏁", label: "Agile Setup", agent: "Rally" },
                    { emoji: "⚡", label: "Implementation", agent: "Cipher · Forge" },
                    { emoji: "🚀", label: "Production Deploy", agent: "Forge" },
                  ].map((step) => (
                    <div class="workflow-step">
                      <span class="workflow-step__emoji">{step.emoji}</span>
                      <div class="workflow-step__info">
                        <span class="workflow-step__label">{step.label}</span>
                        <span class="workflow-step__agent">{step.agent}</span>
                      </div>
                    </div>
                  ))}
                </div>
              </a>
            </div>
          )}
        </div>

        <!-- Right: buy panel -->
        <aside class="product__panel">
          <div class="panel-card">
            <div class="panel-card__price">
              <span class="price-amount">${item.price}</span>
              <span class="price-label">one-time</span>
            </div>

            <a
              href={item.stripeUrl}
              class="btn-buy"
              target="_blank"
              rel="noopener"
            >
              Buy now →
            </a>

            <div class="panel-card__divider"></div>

            {
              item.category !== "Sub-Agent" && item.clawmartUrl && (
                <a
                  href={item.clawmartUrl}
                  class="btn-clawmart"
                  target="_blank"
                  rel="noopener"
                >
                  Also on ClawMart ({item.type === "persona" ? "$99" : "$5"}) →
                </a>
              )
            }

            <ul class="panel-card__details">
              <li>
                <span class="detail-icon">⚡</span>
                Instant delivery after purchase
              </li>
              <li>
                <span class="detail-icon">🔧</span>
                Works with OpenClaw Gateway
              </li>
              <li>
                <span class="detail-icon">📄</span>
                {
                  item.type === "persona"
                    ? "Full persona package (SKILL.md + guides)"
                    : "SKILL.md prompt skill file"
                }
              </li>
            </ul>
          </div>

          <!-- Built by -->
          <div class="built-by">
            <img
              src="/avatars/hero-avatar.gif"
              alt="Aleister"
              class="built-by__avatar-img"
            />
            <div class="built-by__info">
              <span class="built-by__label">Built by</span>
              <a
                href="https://x.com/aleisterai"
                target="_blank"
                rel="noopener"
                class="built-by__name"
              >
                @aleisterai
              </a>
            </div>
          </div>
        </aside>
      </div>

      <!-- Related -->
      {
        related.length > 0 && (
          <section class="related">
            <h2 class="related__title">
              More {item.type === "persona" ? "personas" : "skills"}
            </h2>
            <div class="related__grid">
              {related.map((r) => (
                <a href={`/store/${r.slug}`} class="related-card">
                  <div class="related-card__top">
                    <span class="related-card__category">
                      {r.category || r.type}
                    </span>
                    <span class="related-card__price">${r.price}</span>
                  </div>
                  <h3 class="related-card__name">{r.name}</h3>
                  <p class="related-card__desc">{r.description}</p>
                </a>
              ))}
            </div>
          </section>
        )
      }
    </div>
  </main>

  {/* Fixed bottom buy bar — mobile only (hidden on desktop via CSS) */}
  {!purchased && (
    <div class="store-buy-bar">
      <div class="store-buy-bar__inner">
        <div class="store-buy-bar__info">
          {item.avatar && (
            <img
              src={item.avatar}
              alt={item.name}
              class="store-buy-bar__avatar"
              style={teamData ? `--agent-color: ${teamData.color}` : undefined}
            />
          )}
          <div class="store-buy-bar__text">
            <span class="store-buy-bar__name">{item.name}</span>
            <span class="store-buy-bar__price">${item.price} one-time</span>
          </div>
        </div>
        <a
          href={item.stripeUrl}
          class="store-buy-bar__btn"
          target="_blank"
          rel="noopener"
          style={teamData ? `--agent-color: ${teamData.color}` : undefined}
        >
          Buy now →
        </a>
      </div>
    </div>
  )}
</BaseLayout>

<style>
  .product {
    min-height: 100vh;
    padding: 5rem 0 6rem;
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* Receipt box */
  .receipt-box {
    border: 1px solid color-mix(in srgb, #22c55e 35%, transparent);
    border-radius: 16px;
    background: color-mix(in srgb, #22c55e 6%, transparent);
    margin-bottom: 2.5rem;
    overflow: hidden;
  }

  .receipt-box__header {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.25rem 1.5rem;
    border-bottom: 1px solid color-mix(in srgb, #22c55e 20%, transparent);
    cursor: pointer;
    user-select: none;
    transition: background 0.15s;
  }

  .receipt-box__header:hover {
    background: color-mix(in srgb, #22c55e 8%, transparent);
  }

  .receipt-box__header-text {
    flex: 1;
    min-width: 0;
  }

  .receipt-chevron {
    display: flex;
    align-items: center;
    justify-content: center;
    margin-left: auto;
    flex-shrink: 0;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    border: none;
    background: color-mix(in srgb, #22c55e 12%, transparent);
    color: #22c55e;
    cursor: pointer;
    transition: background 0.15s, transform 0.25s;
    padding: 0;
  }

  .receipt-chevron svg {
    transition: transform 0.25s ease;
  }

  /* Collapsed state — chevron flips down */
  .receipt-box--collapsed .receipt-chevron svg {
    transform: rotate(180deg);
  }

  /* Collapsible body */
  .receipt-box__body {
    overflow: hidden;
    max-height: 600px;
    transition: max-height 0.3s ease, padding 0.2s ease;
    padding-top: 0;
  }

  .receipt-box--collapsed .receipt-box__body {
    max-height: 0;
  }

  /* Header border removed when collapsed */
  .receipt-box--collapsed .receipt-box__header {
    border-bottom-color: transparent;
  }

  .receipt-icon {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: #22c55e;
    color: #fff;
    font-weight: 900;
    font-size: 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .receipt-title {
    font-size: 1rem;
    font-weight: 700;
    color: #22c55e;
    margin: 0 0 0.15rem;
  }

  .receipt-subtitle {
    font-size: 0.82rem;
    color: var(--text-secondary);
    margin: 0;
  }

  .receipt-box__body {
    padding: 1.25rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .receipt-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .receipt-item__name {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text-primary);
  }

  .receipt-item__price {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--text-primary);
  }

  .receipt-divider {
    height: 1px;
    background: color-mix(in srgb, #22c55e 20%, transparent);
  }

  .btn-download {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.75rem 1.5rem;
    background: #22c55e;
    color: #fff;
    font-weight: 700;
    font-size: 0.9rem;
    border-radius: 10px;
    text-decoration: none;
    transition: opacity 0.2s, transform 0.2s;
    align-self: flex-start;
  }

  .btn-download:hover {
    opacity: 0.9;
    transform: translateY(-1px);
  }

  .receipt-note {
    font-size: 0.78rem;
    color: var(--text-tertiary);
    margin: 0;
    line-height: 1.5;
  }

  /* Breadcrumb */
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.82rem;
    color: var(--text-tertiary);
    margin-bottom: 2.5rem;
  }

  .breadcrumb a {
    color: var(--text-accent);
    transition: opacity 0.2s;
  }

  .breadcrumb a:hover {
    opacity: 0.7;
  }

  /* Layout */
  .product__layout {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 3rem;
    align-items: start;
    margin-bottom: 5rem;
  }

  /* Content */
  .product__meta {
    margin-bottom: 1rem;
  }

  .product__type-badge {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 0.25rem 0.7rem;
    border-radius: 20px;
  }

  .product__type-badge--persona {
    background: color-mix(in srgb, var(--text-accent) 12%, transparent);
    color: var(--text-accent);
    border: 1px solid color-mix(in srgb, var(--text-accent) 25%, transparent);
  }

  .product__type-badge--skill {
    background: color-mix(in srgb, #7c3aed 12%, transparent);
    color: #a78bfa;
    border: 1px solid color-mix(in srgb, #7c3aed 25%, transparent);
  }

  .product__title {
    font-size: clamp(1.8rem, 4vw, 2.75rem);
    font-weight: 900;
    line-height: 1.15;
    margin-bottom: 1rem;
    color: var(--text-primary);
  }

  .product__tagline {
    font-size: 1.1rem;
    color: var(--text-secondary);
    line-height: 1.6;
    max-width: 580px;
  }

  .product__divider {
    height: 1px;
    background: var(--border-subtle);
    margin: 2rem 0;
  }

  .product__about {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .product__about p {
    font-size: 0.95rem;
    color: var(--text-secondary);
    line-height: 1.7;
  }

  .product__section-title {
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-tertiary);
    margin-bottom: 1.25rem;
  }

  /* Features list */
  .features-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .features-list__item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    font-size: 0.9rem;
    color: var(--text-secondary);
  }

  .features-list__check {
    color: var(--text-accent);
    font-weight: 700;
    font-size: 0.85rem;
    flex-shrink: 0;
    margin-top: 0.1rem;
  }

  /* Buy panel */
  .product__panel {
    position: sticky;
    top: 5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .panel-card {
    border: 1px solid var(--border-glass);
    border-radius: 16px;
    padding: 1.75rem;
    background: var(--bg-glass);
  }

  .panel-card__price {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    margin-bottom: 1.25rem;
  }

  .price-amount {
    font-size: 2.5rem;
    font-weight: 900;
    color: var(--text-primary);
  }

  .price-label {
    font-size: 0.85rem;
    color: var(--text-tertiary);
  }

  .btn-buy {
    display: block;
    width: 100%;
    padding: 0.85rem 1.5rem;
    background: var(--gradient-accent);
    color: #fff;
    font-weight: 700;
    font-size: 0.95rem;
    border-radius: 10px;
    text-align: center;
    text-decoration: none;
    transition: opacity 0.2s, transform 0.2s;
    margin-bottom: 0.75rem;
  }

  .btn-buy:hover {
    opacity: 0.9;
    transform: translateY(-1px);
  }

  .panel-card__divider {
    height: 1px;
    background: var(--border-subtle);
    margin: 1rem 0;
  }

  .btn-clawmart {
    display: block;
    width: 100%;
    padding: 0.7rem 1.5rem;
    border: 1px solid var(--border-glass);
    border-radius: 10px;
    text-align: center;
    font-size: 0.83rem;
    font-weight: 600;
    color: var(--text-secondary);
    text-decoration: none;
    transition: border-color 0.2s, color 0.2s;
    margin-bottom: 1.25rem;
  }

  .btn-clawmart:hover {
    border-color: var(--border-accent);
    color: var(--text-primary);
  }

  .panel-card__details {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .panel-card__details li {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.82rem;
    color: var(--text-tertiary);
  }

  .detail-icon {
    font-size: 0.9rem;
    flex-shrink: 0;
  }

  /* Built by */
  .built-by {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 1.25rem;
    border: 1px solid var(--border-subtle);
    border-radius: 12px;
    background: var(--bg-glass);
  }

  .built-by__avatar-img {
    width: 36px;
    height: 36px;
