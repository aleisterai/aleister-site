<script is:inline>
  (function () {
    const box      = document.getElementById('receipt-box');
    const toggle   = document.getElementById('receipt-toggle');
    const LS_KEY   = 'receipt_collapsed';

    if (!box || !toggle) return;

    // Restore previous state
    if (localStorage.getItem(LS_KEY) === '1') {
      box.classList.add('receipt-box--collapsed');
      toggle.setAttribute('aria-expanded', 'false');
    }

    function doToggle() {
      const isCollapsed = box.classList.toggle('receipt-box--collapsed');
      toggle.setAttribute('aria-expanded', isCollapsed ? 'false' : 'true');
      localStorage.setItem(LS_KEY, isCollapsed ? '1' : '0');
    }

    toggle.addEventListener('click', doToggle);

    // Keyboard: Enter / Space
    toggle.addEventListener('keydown', function (e) {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        doToggle();
      }
    });
  })();
</script>

<script is:inline define:vars={{ sessionId, itemSlug: item.slug }}>
  if (sessionId) {
    (async () => {
      const LS_KEY = `dt_${sessionId}`;
      const dlBtn = document.getElementById("btn-download");
      const noteEl = document.getElementById("receipt-note");
      const copyBtn = document.getElementById("btn-copy-url");
      const copyLabel = document.getElementById("copy-label");
      const claimedEl = document.getElementById("receipt-claimed");
      const recoverBtn = document.getElementById("btn-recover");
      const recoveryMsg = document.getElementById("recovery-msg");

      function activateDownload(token) {
        if (!dlBtn) return;
        const url = `/api/download?slug=${itemSlug}&session_id=${sessionId}&dt=${encodeURIComponent(
          token
        )}`;
        dlBtn.href = url;
        dlBtn.classList.remove("btn-download--loading");
        if (noteEl)
          noteEl.textContent =
            "Your download link is bound to this device. Keep this page URL to re-download.";
        if (copyBtn) copyBtn.style.display = "inline-flex";
      }

      function showClaimed() {
        if (dlBtn) {
          dlBtn.classList.add("btn-download--loading");
        }
        if (noteEl) noteEl.textContent = "Download claimed on another device.";
        if (claimedEl) claimedEl.style.display = "flex";
      }

      // Copy URL button
      if (copyBtn) {
        copyBtn.addEventListener("click", async () => {
          try {
            await navigator.clipboard.writeText(window.location.href);
            copyBtn.classList.add("copied");
            if (copyLabel) copyLabel.textContent = "Copied!";
            setTimeout(() => {
              copyBtn.classList.remove("copied");
              if (copyLabel) copyLabel.textContent = "Copy link";
            }, 2000);
          } catch {}
        });
      }

      // Email recovery
      if (recoverBtn) {
        recoverBtn.addEventListener("click", async () => {
          const emailInput = document.getElementById("recovery-email");
          const email = emailInput ? emailInput.value.trim() : "";
          if (!email) return;
          recoverBtn.disabled = true;
          recoverBtn.textContent = "Verifying…";
          try {
            const res = await fetch("/api/bind", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ session_id: sessionId, email }),
            });
            const data = await res.json();
            if (!res.ok || !data.token) {
              if (recoveryMsg)
                recoveryMsg.textContent =
                  "Email does not match purchase record. Contact support.";
              recoverBtn.disabled = false;
              recoverBtn.textContent = "Re-link device";
              return;
            }
            // Success — store new token and activate
            localStorage.setItem(LS_KEY, data.token);
            if (claimedEl) claimedEl.style.display = "none";
            activateDownload(data.token);
          } catch {
            if (recoveryMsg)
              recoveryMsg.textContent = "Network error. Try again.";
            recoverBtn.disabled = false;
            recoverBtn.textContent = "Re-link device";
          }
        });
      }

      // Try existing localStorage token first
      const storedToken = localStorage.getItem(LS_KEY);
      const body = storedToken
        ? { session_id: sessionId, device_token: storedToken }
        : { session_id: sessionId };

      try {
        const res = await fetch("/api/bind", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(body),
        });
        const data = await res.json();

        if (res.ok && data.token) {
          localStorage.setItem(LS_KEY, data.token);
          activateDownload(data.token);
        } else if (res.status === 409) {
          showClaimed();
        } else {
          if (noteEl)
            noteEl.textContent =
              "Could not verify purchase. Refresh and try again.";
        }
      } catch {
        if (noteEl)
          noteEl.textContent =
            "Network error verifying device. Please refresh.";
      }
    })();
  }
</script>
