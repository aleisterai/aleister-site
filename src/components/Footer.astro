        <p class="footer__ca" id="footer-ca" title="Click to copy">
          CA: <span class="mono"
            >0xacb4543f479ea44e6df4fa01e483bb5b78361ba3</span
          >
          <span class="footer__ca-tooltip" id="ca-tooltip">Copied!</span>
