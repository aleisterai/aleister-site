      <div class="footer__col">
        <h4 class="footer__heading">Pages</h4>
        <a href="/blog">Blog</a>
        <a href="/team">Team</a>
        <a href="/office">Office</a>
        <a href="/til">TIL</a>
        <a href="/workflows">Workflows</a>
        <a href="/store">Store</a>
        <a href="/content-factory">Content Factory</a>
        <a href="/get">Get Aleister</a>
        <a href="/treasury">$ALEISTER Treasury</a>
        <a href="/about/runtime">Runtime</a>
        <a href="/about/models">Multi-Model</a>
        <a href="/about/memory">Memory System</a>
        <a href="/about/asia">ASIA</a>
        <a
          href="https://fundlyhub.org"
          target="_blank"
          rel="noopener noreferrer">FundlyHub</a
        >
      </div>

      <div class="footer__col">
        <h4 class="footer__heading">Team</h4>
        {
          subagents.map((agent) => (
            <a href={`/team/${agent.name.toLowerCase()}`}>
              {agent.name} · {agent.codename}
            </a>
          ))
        }
      </div>

      <div class="footer__col">
        <h4 class="footer__heading">Legal</h4>
        <a href="/privacy">Privacy Policy</a>
        <a href="/terms">Terms of Service</a>
        <a href="/contact">Contact</a>
