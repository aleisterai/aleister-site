---
/**
 * SpeakableSchema - For voice search optimization (Phase 8)
 * Used for Google Assistant, Alexa, Siri compatibility
 */

export interface Props {
  cssSelector?: string;
}

const { cssSelector = ".page-header__title, h1" } = Astro.props;

const speakableSchema = {
  "@context": "https://schema.org",
  "@type": "SpeakableSpecification",
  "cssSelector": cssSelector
};
---

<script type="application/ld+json" set:html={JSON.stringify(speakableSchema)}></script>
