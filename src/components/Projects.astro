---
import { projects } from '../data/projects';
---
<section class="projects section" id="projects">
  <div class="container">
    <h2 class="section-title">Active <span class="text-gradient">Projects</span></h2>
    <p class="section-subtitle">
      Ventures and production systems Aleister builds, runs, and leads.
    </p>

    <div class="projects__grid">
      {projects.map((project) => (
        <a href={`/projects/${project.slug}`} class="glass-card project-card">
          <div class="project-card__header">
            {project.logo ? (
              <img
                src={project.logo}
                alt={`${project.name} logo`}
                class="project-card__logo"
                width="40"
                height="40"
                loading="lazy"
              />
            ) : (
              <span
                class="project-card__monogram"
                style={`--monogram-color: ${project.color}`}
                aria-hidden="true"
              >
                {project.name.charAt(0)}
              </span>
            )}
            <h3 class="project-card__name">{project.name}</h3>
            <span class="project-card__arrow">→</span>
          </div>
          <span class="project-card__role">{project.role}</span>
          <p class="project-card__desc">{project.description}</p>
          <div class="project-card__tags">
            {project.tags.map((tag) => (
              <span class="chip">{tag}</span>
            ))}
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .projects__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .project-card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    cursor: pointer;
  }

  .project-card__header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .project-card__logo {
    width: 40px;
    height: 40px;
    object-fit: contain;
    border-radius: 8px;
    flex-shrink: 0;
  }

  .project-card__monogram {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 8px;
    flex-shrink: 0;
    font-size: var(--text-xl);
    font-weight: 800;
    color: var(--monogram-color, var(--text-accent));
    background: color-mix(in srgb, var(--monogram-color, var(--text-accent)) 14%, transparent);
    border: 1px solid color-mix(in srgb, var(--monogram-color, var(--text-accent)) 35%, transparent);
  }

  .project-card__name {
    font-size: var(--text-xl);
    font-weight: 800;
    flex: 1;
  }

  .project-card__arrow {
    font-size: var(--text-xl);
    color: var(--text-tertiary);
    transition: all 0.3s ease;
  }

  .project-card:hover .project-card__arrow {
    color: var(--text-accent);
    transform: translate(3px, -3px);
  }

  .project-card__role {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--text-accent);
  }

  .project-card__desc {
    font-size: var(--text-sm);
    line-height: 1.6;
  }

  .project-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: auto;
  }

  @media (max-width: 640px) {
    .projects__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
