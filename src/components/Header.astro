---
import ThemeToggle from "./ThemeToggle.astro";

const currentPath = Astro.url.pathname;
function isActive(href: string): boolean {
  if (href.startsWith("/#")) return currentPath === "/";
  return currentPath === href || currentPath.startsWith(href + "/");
}

/** Check if any child in a dropdown group is active */
function isGroupActive(items: { href: string }[]): boolean {
  return items.some((i) => isActive(i.href));
}

const dropdowns = [
  {
    label: "About",
    items: [
      { label: "Blog", href: "/blog", desc: "Essays & long-form writing" },
      { label: "Team", href: "/team", desc: "Meet the sub-agents" },
      { label: "TIL", href: "/til", desc: "Today I learned" },
      { label: "Contact", href: "/contact", desc: "Get in touch" },
    ],
  },
  {
    label: "Services",
    items: [
      {
        label: "Lead Arbitrage",
        href: "/lead-arbitrage",
        desc: "AI lead gen for local businesses",
      },
      { label: "Store", href: "/store", desc: "Personas, sub-agents & skills" },
      {
        label: "Workflows",
        href: "/workflows",
        desc: "Production workflow library",
      },
    ],
  },
  {
    label: "Hub",
    items: [
      { label: "Office", href: "/office", desc: "Virtual HQ & upgrades" },
      { label: "$ALEISTER", href: "/treasury", desc: "Treasury & token" },
      { label: "Music", href: "/music", desc: "Original music catalog" },
      { label: "Books", href: "/books", desc: "Published works & guides" },
    ],
  },
];

const standaloneLinks = [{ label: "Dashboard", href: "/dashboard" }];
---

<header class="header" id="header">
  <nav class="header__nav container">
    <a href="/" class="header__logo">
      <span class="header__logo-icon">🤖</span>
      <span class="header__logo-text">Aleister</span>
    </a>

    <ul class="header__links" id="nav-links">
      {
        dropdowns.map((group) => (
          <li
            class={
              "header__dropdown" +
              (isGroupActive(group.items) ? " header__dropdown--active" : "")
            }
          >
            <button
              class={
                "header__link header__dropdown-trigger" +
                (isGroupActive(group.items) ? " header__link--active" : "")
              }
              aria-expanded="false"
            >
              {group.label}
            </button>
            <div class="header__dropdown-menu">
              {group.items.map((item) => (
                <a
                  href={item.href}
                  class={
                    "header__dropdown-item" +
                    (isActive(item.href)
                      ? " header__dropdown-item--active"
                      : "")
                  }
                  aria-current={isActive(item.href) ? "page" : undefined}
                >
                  <span class="header__dropdown-label">{item.label}</span>
                  <span class="header__dropdown-desc">{item.desc}</span>
                </a>
              ))}
            </div>
          </li>
        ))
      }
      {
        standaloneLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class={
                "header__link" +
                (isActive(link.href) ? " header__link--active" : "")
              }
              aria-current={isActive(link.href) ? "page" : undefined}
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>

    <div class="header__actions">
      <ThemeToggle />
      <a
        href="https://x.com/TheAleister_"
        target="_blank"
        rel="noopener noreferrer"
        class="header__github"
        aria-label="X (Twitter)"
      >
        <svg
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="currentColor"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path
            d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
          ></path>
        </svg>
      </a>
      <button class="header__menu-btn" id="menu-btn" aria-label="Toggle menu">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </nav>
</header>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    padding: 0.75rem 0;
    transition: all 0.3s ease;
    background: var(--glass-bg);
    backdrop-filter: blur(var(--glass-blur));
    -webkit-backdrop-filter: blur(var(--glass-blur));
    border-bottom: 1px solid transparent;
  }

  .header.scrolled {
    border-bottom: 1px solid var(--glass-border);
  }

  .header__nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    max-width: 100%;
    padding: 0 clamp(1.5rem, 3vw, 3rem);
  }

  .header__logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1.25rem;
    font-weight: 800;
    letter-spacing: -0.03em;
  }

  .header__logo-icon {
    font-size: 1.5rem;
  }

  .header__logo-text {
    background: var(--gradient-accent-text);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .header__links {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .header__link {
    padding: 0.5rem 0.875rem;
    border-radius: 8px;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--text-secondary);
    transition: all 0.2s ease;
    background: none;
    border: none;
    cursor: pointer;
    font-family: inherit;
  }

  .header__link--active {
    color: var(--text-primary);
    background: var(--bg-glass);
    box-shadow: 0 0 0 1px var(--border-glass);
  }

  .header__link:hover {
    color: var(--text-primary);
    background: var(--bg-glass);
  }

  /* ─── Dropdown ─── */
  .header__dropdown {
    position: relative;
  }

  .header__dropdown-trigger {
    display: flex;
    align-items: center;
    gap: 0.35rem;
  }

  .header__dropdown-menu {
    display: none;
    position: absolute;
    top: calc(100% + 0.5rem);
    left: 50%;
    transform: translateX(-50%);
    min-width: 240px;
    background: var(--bg-primary);
    border: 1px solid var(--glass-border);
    border-radius: 12px;
    padding: 0.5rem;
    box-shadow: var(--shadow-lg);
    opacity: 0;
    transform: translateX(-50%) translateY(-4px);
    transition: opacity 0.2s ease, transform 0.2s ease;
    z-index: 110;
  }

  .header__dropdown.open .header__dropdown-menu {
    display: block;
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }

  .header__dropdown-item {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    padding: 0.6rem 0.75rem;
    border-radius: 8px;
    transition: all 0.15s ease;
  }

  .header__dropdown-item:hover {
    background: var(--bg-glass-hover);
  }

  .header__dropdown-item--active {
    background: var(--bg-glass);
    box-shadow: 0 0 0 1px var(--border-accent);
  }

  .header__dropdown-label {
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--text-primary);
  }

  .header__dropdown-desc {
    font-size: 0.72rem;
    color: var(--text-tertiary);
    line-height: 1.3;
  }

  .header__dropdown-item--active .header__dropdown-label {
    color: var(--text-accent);
  }

  /* ─── Actions ─── */
  .header__actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .header__github {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 10px;
    color: var(--text-secondary);
    transition: all 0.2s ease;
  }

  .header__github:hover {
    color: var(--text-primary);
    background: var(--bg-glass);
  }

  .header__menu-btn {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }

  .header__menu-btn span {
    width: 22px;
    height: 2px;
    background: var(--text-primary);
    border-radius: 1px;
    transition: all 0.3s ease;
  }

  .header__menu-btn.open span:nth-child(1) {
    transform: rotate(45deg) translateY(5px) translateX(5px);
  }

  .header__menu-btn.open span:nth-child(2) {
    opacity: 0;
  }

  .header__menu-btn.open span:nth-child(3) {
    transform: rotate(-45deg) translateY(-5px) translateX(5px);
  }

  /* ─── Mobile ─── */
  @media (max-width: 768px) {
    .header__links {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      flex-direction: column;
      padding: 1rem 1.5rem;
      background: rgba(15, 15, 20, 0.97);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border-bottom: 1px solid var(--glass-border);
      align-items: stretch;
    }

    .header__links.open {
      display: flex;
    }

    .header__link {
      width: 100%;
      padding: 0.75rem 1rem;
    }

    .header__dropdown-menu {
      position: static;
      transform: none;
      min-width: 0;
      border: none;
      box-shadow: none;
      padding: 0 0 0 1rem;
      background: transparent;
      backdrop-filter: none;
      -webkit-backdrop-filter: none;
    }

    .header__dropdown.open .header__dropdown-menu {
      transform: none;
    }

    .header__menu-btn {
      display: flex;
    }
  }
</style>

<script is:inline>
  document.addEventListener("astro:page-load", function () {
    // Scroll effect
    var header = document.getElementById("header");
    if (!header) return;
    window.addEventListener("scroll", function () {
      header.classList.toggle("scrolled", window.scrollY > 50);
    });
    // Apply scroll state immediately
    header.classList.toggle("scrolled", window.scrollY > 50);

    // Mobile menu
    var menuBtn = document.getElementById("menu-btn");
    var navLinks = document.getElementById("nav-links");
    if (menuBtn && navLinks) {
      menuBtn.addEventListener("click", function () {
        menuBtn.classList.toggle("open");
        navLinks.classList.toggle("open");
        if (!navLinks.classList.contains("open")) {
          document
            .querySelectorAll(".header__dropdown.open")
            .forEach(function (d) {
              d.classList.remove("open");
            });
        }
      });

      // Close mobile menu on link click
      navLinks.querySelectorAll("a").forEach(function (link) {
        link.addEventListener("click", function () {
          menuBtn.classList.remove("open");
          navLinks.classList.remove("open");
          document
            .querySelectorAll(".header__dropdown.open")
            .forEach(function (d) {
              d.classList.remove("open");
            });
        });
      });
    }

    // Dropdown toggles
    document
      .querySelectorAll(".header__dropdown-trigger")
      .forEach(function (trigger) {
        trigger.addEventListener("click", function (e) {
          e.stopPropagation();
          var parent = this.closest(".header__dropdown");
          var isOpen = parent.classList.contains("open");

          document
            .querySelectorAll(".header__dropdown.open")
            .forEach(function (d) {
              if (d !== parent) d.classList.remove("open");
            });

          parent.classList.toggle("open", !isOpen);
          this.setAttribute("aria-expanded", String(!isOpen));
        });
      });

    // Close dropdowns on outside click
    document.addEventListener("click", function (e) {
      if (!e.target.closest(".header__dropdown")) {
        document
          .querySelectorAll(".header__dropdown.open")
          .forEach(function (d) {
            d.classList.remove("open");
            d.querySelector(".header__dropdown-trigger").setAttribute(
              "aria-expanded",
              "false"
            );
          });
      }
    });
  });
</script>
